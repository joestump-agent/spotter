package albums

import (
	"encoding/json"
	"fmt"
	"net/url"
	"sort"
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
	"strings"
	"time"
)

// AlbumStats holds statistics for an album
type AlbumStats struct {
	TotalListens       int
	UniqueTracks       int
	FirstListen        time.Time
	LastListen         time.Time
	ListensByProvider  []components.ChartDataPoint
	ListensByHour      []components.ChartDataPoint
	ListensByDayOfWeek []components.ChartDataPoint
	ListensByMonth     []components.ChartDataPoint
	TrackListens       []components.ChartDataPoint
	ProviderHistory    components.StackedChartData
}

// TrackWithListens represents a track with its listen count
type TrackWithListens struct {
	Track       *ent.Track
	ListenCount int
}

func toTrackRowsFromAlbumStats(tracks []TrackWithListens) []components.TrackTableRow {
	rows := make([]components.TrackTableRow, len(tracks))
	for i, t := range tracks {
		index := i + 1
		if t.Track.TrackNumber != nil {
			index = *t.Track.TrackNumber
		}
		rows[i] = components.TrackTableRow{
			Track:     t.Track,
			PlayCount: t.ListenCount,
			Index:     index,
		}
	}
	return rows
}

func formatNumber(n int) string {
	return fmt.Sprintf("%d", n)
}

func formatDate(t time.Time) string {
	if t.IsZero() {
		return "N/A"
	}
	return t.Local().Format("Jan 2 '06")
}

func formatDuration(ms int) string {
	if ms <= 0 {
		return "N/A"
	}
	seconds := ms / 1000
	minutes := seconds / 60
	secs := seconds % 60
	if minutes >= 60 {
		hours := minutes / 60
		mins := minutes % 60
		return fmt.Sprintf("%d:%02d:%02d", hours, mins, secs)
	}
	return fmt.Sprintf("%d:%02d", minutes, secs)
}

func getPrimaryAlbumImage(album *ent.Album) string {
	if album.Edges.Images == nil || len(album.Edges.Images) == 0 {
		return ""
	}
	return fmt.Sprintf("/library/album/%d.png", album.ID)
}

func getOrDefault(value, defaultVal string) string {
	if value == "" {
		return defaultVal
	}
	return value
}

func toJSON(v interface{}) string {
	b, err := json.Marshal(v)
	if err != nil {
		return "[]"
	}
	return string(b)
}

func formatEnrichedTime(t time.Time) string {
	if t.IsZero() {
		return "Never"
	}
	return t.Local().Format("Jan 02, 2006 at 3:04 PM")
}

func formatAiEnrichedTime(t *time.Time) string {
	if t == nil || t.IsZero() {
		return "Never"
	}
	return t.Local().Format("Jan 02, 2006 at 3:04 PM")
}

func getAllTags(album *ent.Album, tracks []*ent.Track) []string {
	tagMap := make(map[string]bool)
	for _, tag := range album.Tags {
		tagMap[tag] = true
	}
	for _, track := range tracks {
		for _, tag := range track.Tags {
			tagMap[tag] = true
		}
	}
	tags := make([]string, 0, len(tagMap))
	for tag := range tagMap {
		tags = append(tags, tag)
	}
	return tags
}

func getAllGenres(album *ent.Album, tracks []*ent.Track) []string {
	genreMap := make(map[string]bool)
	if album.Genre != "" {
		genreMap[album.Genre] = true
	}
	for _, track := range tracks {
		for _, genre := range track.Genres {
			genreMap[genre] = true
		}
	}
	genres := make([]string, 0, len(genreMap))
	for genre := range genreMap {
		genres = append(genres, genre)
	}
	return genres
}

func getTotalDuration(tracks []*ent.Track) int {
	total := 0
	for _, track := range tracks {
		if track.DurationMs != nil {
			total += *track.DurationMs
		}
	}
	return total
}

func extractTracks(tracks []TrackWithListens) []*ent.Track {
	result := make([]*ent.Track, 0, len(tracks))
	for _, t := range tracks {
		result = append(result, t.Track)
	}
	return result
}

func collectAndSortAllTags(album *ent.Album, tracks []TrackWithListens) []string {
	tagsSet := make(map[string]struct{})
	for _, genre := range getAllGenres(album, extractTracks(tracks)) {
		tagsSet[strings.Title(strings.ToLower(genre))] = struct{}{}
	}
	for _, tag := range album.AiTags {
		tagsSet[strings.Title(strings.ToLower(tag))] = struct{}{}
	}
	for _, tag := range album.Tags {
		tagsSet[strings.Title(strings.ToLower(tag))] = struct{}{}
	}
	var allTags []string
	for tag := range tagsSet {
		allTags = append(allTags, tag)
	}
	sort.Strings(allTags)
	return allTags
}

func truncateText(text string, maxLen int) string {
	if len(text) <= maxLen {
		return text
	}
	return text[:maxLen] + "..."
}

func formatYear(year int) string {
	if year <= 0 {
		return "Unknown"
	}
	return fmt.Sprintf("%d", year)
}

func getMBAlbumLink(mbid string) string {
	if mbid == "" {
		return ""
	}
	return fmt.Sprintf("https://musicbrainz.org/release-group/%s", mbid)
}

func getSpotifyAlbumLink(spotifyID string) string {
	if spotifyID == "" {
		return ""
	}
	return fmt.Sprintf("https://open.spotify.com/album/%s", spotifyID)
}

templ Show(album *ent.Album, tracks []TrackWithListens, stats *AlbumStats, djs []*ent.DJ, cfg *config.Config, currentTimeframe string) {
	@layouts.Dashboard(fmt.Sprintf("%s | Albums | Spotter", album.Name), cfg, "/library/album") {
		<!-- AI Regenerate Modal -->
		<dialog id="ai-regenerate-modal" class="modal">
			<div class="modal-box">
				<h3 class="font-bold text-lg flex items-center gap-2">
					<span class="icon-[heroicons--sparkles] w-5 h-5 text-accent"></span>
					Regenerate AI Insights
				</h3>
				<p class="py-4">
					This will regenerate all AI-generated content for <strong>{ album.Name }</strong>, including the summary and tags.
				</p>
				<p class="text-sm text-base-content/60">
					This may take a few moments and will use your OpenAI API credits.
				</p>
				<div class="modal-action">
					<form method="dialog">
						<button class="btn btn-ghost">Cancel</button>
					</form>
					<button
						class="btn btn-primary"
						hx-post={ fmt.Sprintf("/library/album/%d/regenerate-ai", album.ID) }
						hx-swap="none"
						hx-indicator="#ai-regenerate-indicator"
						onclick="document.getElementById('ai-regenerate-modal').close()"
					>
						<span id="ai-regenerate-indicator" class="htmx-indicator loading loading-spinner loading-sm"></span>
						<span class="icon-[heroicons--sparkles] w-4 h-4"></span>
						Regenerate
					</button>
				</div>
			</div>
			<form method="dialog" class="modal-backdrop">
				<button>close</button>
			</form>
		</dialog>
		<!-- Hero Section -->
		<div class="relative -mx-6 lg:-mx-8 -mt-6 lg:-mt-8 mb-8">
			<!-- Background Blur -->
			<div class="absolute inset-0 h-96 overflow-hidden">
				@components.AlbumImage(album, "w-full h-full object-cover opacity-20 blur-2xl scale-110")
				<div class="absolute inset-0 bg-gradient-to-b from-transparent via-base-200/80 to-base-200"></div>
			</div>
			<!-- AI Menu (Top Right) -->
			<div class="absolute top-4 right-4 z-10">
				<details class="dropdown dropdown-end">
					<summary class="btn btn-sm btn-ghost bg-base-100/50 hover:bg-base-100/80 gap-1 list-none cursor-pointer">
						<span class="icon-[heroicons--sparkles] w-4 h-4 text-accent"></span>
						<span class="hidden sm:inline">AI</span>
						<span class="icon-[heroicons--chevron-down] w-3 h-3"></span>
					</summary>
					<ul class="dropdown-content z-[1] menu p-2 shadow-lg bg-base-100 rounded-box w-56">
						<li>
							if len(djs) > 0 {
								<button
									hx-get={ fmt.Sprintf("/library/album/%d/mixtape-modal", album.ID) }
									hx-target="#create-mixtape-modal"
									hx-swap="innerHTML"
									onclick="this.closest('details').removeAttribute('open')"
									_="on htmx:afterRequest document.getElementById('create-mixtape-modal').showModal()"
								>
									<span class="icon-[heroicons--musical-note] w-4 h-4"></span>
									Create Mixtape
								</button>
							} else {
								<a href="/vibes/djs" class="opacity-60">
									<span class="icon-[heroicons--musical-note] w-4 h-4"></span>
									Create Mixtape
									<span class="badge badge-xs">Create DJ first</span>
								</a>
							}
						</li>
						<li>
							if len(djs) > 0 {
								<button
									hx-get={ fmt.Sprintf("/library/album/%d/mixtape-modal", album.ID) }
									hx-target="#create-mixtape-modal"
									hx-swap="innerHTML"
									onclick="this.closest('details').removeAttribute('open')"
									_="on htmx:afterRequest document.getElementById('create-mixtape-modal').showModal()"
								>
									<span class="icon-[heroicons--musical-note] w-4 h-4"></span>
									Create Mixtape
								</button>
							} else {
								<a href="/vibes/djs" class="opacity-60">
									<span class="icon-[heroicons--musical-note] w-4 h-4"></span>
									Create Mixtape
									<span class="badge badge-xs">Create DJ first</span>
								</a>
							}
						</li>
					</ul>
				</details>
			</div>
			<!-- Album Info -->
			<div class="relative pt-8 px-6 lg:px-8 pb-8">
				<div class="max-w-7xl mx-auto">
					<div class="flex flex-col md:flex-row items-start gap-8">
						<!-- Album Cover -->
						<div class="flex-shrink-0">
							<div class="w-56 h-56 md:w-64 md:h-64 rounded-xl shadow-2xl ring ring-base-100 ring-offset-base-200 ring-offset-2 overflow-hidden">
								@components.AlbumImage(album, "w-full h-full object-cover")
							</div>
						</div>
						<!-- Album Details -->
						<div class="flex-1 min-w-0">
							<h1 class="text-4xl md:text-5xl font-bold mb-2 text-base-content">{ album.Name }</h1>
							<!-- Artist Link -->
							if album.Edges.Artist != nil {
								<a href={ templ.URL(fmt.Sprintf("/library/artist/%d", album.Edges.Artist.ID)) } class="text-xl text-base-content/70 hover:text-primary hover:underline flex items-center gap-2 mb-3">
									<span class="icon-[heroicons--user-circle] w-5 h-5"></span>
									{ album.Edges.Artist.Name }
								</a>
							}
							<!-- All Tags -->
							if allTags := collectAndSortAllTags(album, tracks); len(allTags) > 0 {
								<div class="flex flex-wrap gap-1.5 mb-3">
									for _, tag := range allTags {
										<span class="badge badge-sm badge-primary badge-outline px-2 py-0.5">{ tag }</span>
									}
								</div>
							}
							<!-- Metadata Table -->
							<div class="bg-base-100/50 rounded-lg p-3 mb-4">
								<table class="text-sm">
									<tbody>
										<tr>
											<td class="pr-6 py-1 text-base-content/60">Type</td>
											<td class="py-1 font-medium">
												if album.AlbumType != "" {
													{ album.AlbumType }
												} else {
													Album
												}
											</td>
											<td class="pr-6 py-1 text-base-content/60 pl-6">Year</td>
											<td class="py-1 font-medium">
												if album.Year > 0 {
													{ fmt.Sprintf("%d", album.Year) }
												} else {
													—
												}
											</td>
										</tr>
										<tr>
											<td class="pr-6 py-1 text-base-content/60">Tracks</td>
											<td class="py-1 font-medium">{ formatNumber(album.TotalTracks) }</td>
											<td class="pr-6 py-1 text-base-content/60 pl-6">Duration</td>
											<td class="py-1 font-medium">
												if totalDur := getTotalDuration(extractTracks(tracks)); totalDur > 0 {
													{ formatDuration(totalDur) }
												} else {
													—
												}
											</td>
										</tr>
										<tr>
											<td class="pr-6 py-1 text-base-content/60">Listens</td>
											<td class="py-1 font-medium">{ formatNumber(stats.TotalListens) }</td>
											<td class="pr-6 py-1 text-base-content/60 pl-6">Popularity</td>
											<td class="py-1 font-medium">
												if album.Popularity > 0 {
													{ fmt.Sprintf("%d%%", album.Popularity) }
												} else {
													—
												}
											</td>
										</tr>
									</tbody>
								</table>
							</div>
							<!-- External Links -->
							<div class="flex flex-wrap gap-2">
								if album.SpotifyID != "" {
									@components.ExternalLinkBadge("Spotify", fmt.Sprintf("https://open.spotify.com/album/%s", album.SpotifyID), "icon-[simple-icons--spotify]", "badge-success")
								}
								if album.MusicbrainzID != "" {
									@components.ExternalLinkBadge("MusicBrainz", fmt.Sprintf("https://musicbrainz.org/release-group/%s", album.MusicbrainzID), "icon-[heroicons--globe-alt]", "badge-warning")
								}
								if album.Edges.Artist != nil && album.Edges.Artist.LidarrID != "" && album.Edges.Artist.LidarrID != "0" && album.Edges.Artist.MusicbrainzID != "" {
									@components.ExternalLinkBadge("Lidarr", fmt.Sprintf("%s/artist/%s", cfg.Lidarr.BaseURL, album.Edges.Artist.MusicbrainzID), "icon-[heroicons--check-badge]", "badge-success")
								}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="max-w-7xl mx-auto">
			<!-- AI Summary Card -->
			@components.AISummaryCard(album.AiSummary, "AI Insights")
			<!-- Track Listing -->
			<div class="card bg-base-100 shadow-xl mb-8">
				<div class="card-body">
					<div class="flex items-center justify-between">
						<h3 class="card-title">
							<span class="icon-[heroicons--queue-list] w-5 h-5"></span>
							Tracks
						</h3>
						@components.TrackTableToolbar(components.TrackTableToolbarConfig{
							TableID:           "album-tracks-table",
							ShowArtworkToggle: true,
							ArtworkDefault:    false,
							ColumnOptions: []components.ColumnOption{
								{Value: "col-index", Label: "#", DefaultVisible: true},
								{Value: "col-track", Label: "Track", DefaultVisible: true},
								{Value: "col-artist", Label: "Artist", DefaultVisible: false},
								{Value: "col-album", Label: "Album", DefaultVisible: false},
								{Value: "col-duration", Label: "Duration", DefaultVisible: true},
								{Value: "col-popularity", Label: "Popularity", DefaultVisible: true},
								{Value: "col-plays", Label: "Plays", DefaultVisible: true},
							},
						})
					</div>
					@components.TrackTable("album-tracks-table", toTrackRowsFromAlbumStats(tracks), []string{"#", "track", "duration", "popularity", "plays"}, nil, components.SortConfig{})
				</div>
			</div>
			<!-- Metadata Table -->
			<div class="card bg-base-100 shadow-xl mb-8">
				<div class="card-body">
					<h3 class="card-title">
						<span class="icon-[heroicons--information-circle] w-5 h-5"></span>
						Metadata
					</h3>
					@components.MetadataTable([]components.MetadataRow{
						{Label: "Sort Name", Value: getOrDefault(album.SortName, album.Name)},
						{Label: "Release Date", Value: getOrDefault(album.ReleaseDate, "Unknown")},
						{Label: "Year", Value: formatYear(album.Year)},
						{Label: "Album Type", Value: getOrDefault(album.AlbumType, "album")},
						{Label: "Label", Value: getOrDefault(album.Label, "Unknown")},
						{Label: "Total Tracks", Value: formatNumber(album.TotalTracks)},
						{Label: "Genre", Value: getOrDefault(album.Genre, "N/A")},
						{Label: "AI Summary", Value: truncateText(getOrDefault(album.AiSummary, "N/A"), 100)},
						{Label: "MusicBrainz ID", Value: getOrDefault(album.MusicbrainzID, "N/A"), Link: getMBAlbumLink(album.MusicbrainzID)},
						{Label: "Spotify ID", Value: getOrDefault(album.SpotifyID, "N/A"), Link: getSpotifyAlbumLink(album.SpotifyID)},
						{Label: "Last Enriched", Value: formatEnrichedTime(album.LastEnrichedAt)},
						{Label: "AI Enriched", Value: formatAiEnrichedTime(album.LastAiEnrichedAt)},
						{Label: "Created", Value: formatDate(album.CreatedAt)},
						{Label: "Updated", Value: formatDate(album.UpdatedAt)},
					})
				</div>
			</div>
		</div>
		if len(album.Recommendations) > 0 {
			<div class="mt-8">
				<h2 class="text-2xl font-bold mb-4 flex items-center gap-2">
					<span class="icon-[ph--magic-wand-fill] text-accent"></span>
					Recommended Albums
				</h2>
				<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
					for _, rec := range album.Recommendations {
						<a href={ templ.URL(fmt.Sprintf("/library/albums?q=%s %s", url.QueryEscape(rec.Name), url.QueryEscape(rec.Artist))) } class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all hover:scale-105 group" title={ rec.Reason }>
							<figure class="aspect-square relative overflow-hidden">
								if rec.ImageURL != "" {
									<img src={ templ.URL(rec.ImageURL) } alt={ rec.Name } class="w-full h-full object-cover"/>
								} else {
									<div class="w-full h-full bg-base-300 flex items-center justify-center">
										<span class="icon-[ph--disc-fill] text-5xl text-base-content/20"></span>
									</div>
								}
								if rec.Year > 0 {
									<div class="absolute bottom-2 right-2 badge badge-neutral badge-sm px-2 py-0.5">
										<span>{ fmt.Sprintf("%d", rec.Year) }</span>
									</div>
								}
								<div class="absolute top-2 left-2 badge badge-accent badge-sm opacity-0 group-hover:opacity-100 transition-opacity">
									<span class="icon-[ph--brain-fill] w-3 h-3 mr-1"></span>
									AI
								</div>
							</figure>
							<div class="card-body p-4">
								<h3 class="card-title text-sm line-clamp-1">{ rec.Name }</h3>
								<p class="text-xs text-base-content/50 truncate mt-1">
									{ rec.Artist }
								</p>
							</div>
						</a>
					}
				</div>
			</div>
		}
		<!-- Create Mixtape Modal -->
		@components.CreateMixtapeModal()
	}
}

// CreateMixtapeModalContent renders just the modal content for HTMX requests.
templ CreateMixtapeModalContent(album *ent.Album, djs []*ent.DJ) {
	@components.CreateMixtapeModalContent(components.CreateMixtapeParams{
		SeedType: components.SeedAlbum,
		SeedID:   album.ID,
		SeedName: album.Name,
		DJs:      djs,
	})
}

templ ProviderHistoryChart(albumID int, data components.StackedChartData, currentTimeframe string) {
	<div class="card bg-base-100 shadow-xl">
		<div class="card-body">
			<div class="flex items-center justify-between mb-4">
				<h3 class="card-title">
					<span class="icon-[heroicons--chart-bar] w-5 h-5"></span>
					Listens Over Time
				</h3>
				<select
					class="select select-bordered select-sm w-40"
					hx-get={ fmt.Sprintf("/library/album/%d/chart", albumID) }
					hx-target="#provider-history-chart"
					hx-swap="innerHTML"
					name="timeframe"
				>
					<option value="30d" selected?={ currentTimeframe == "30d" }>Last 30 days</option>
					<option value="90d" selected?={ currentTimeframe == "90d" }>Last 90 days</option>
					<option value="6m" selected?={ currentTimeframe == "6m" }>Last 6 months</option>
					<option value="1y" selected?={ currentTimeframe == "1y" }>Last year</option>
					<option value="all" selected?={ currentTimeframe == "all" }>All time</option>
				</select>
			</div>
			<div id="provider-history-chart">
				@ProviderHistoryChartContent(albumID, data)
			</div>
		</div>
	</div>
}

templ ProviderHistoryChartContent(albumID int, data components.StackedChartData) {
	<div class="w-full" style="height: 300px">
		<canvas id={ fmt.Sprintf("album-%d-provider-history", albumID) }></canvas>
	</div>
	@providerHistoryScript(albumID, data)
}

templ providerHistoryScript(albumID int, data components.StackedChartData) {
	<script>
		(function() {
			const ctx = document.getElementById('album-' + {{ albumID }} + '-provider-history');
			if (!ctx) return;

			// Destroy existing chart if any
			const existingChart = Chart.getChart(ctx);
			if (existingChart) {
				existingChart.destroy();
			}

			const chartData = JSON.parse('{{ toJSON(data) }}');

			new Chart(ctx, {
				type: 'bar',
				data: {
					labels: chartData.labels,
					datasets: chartData.datasets.map(ds => ({
						label: ds.label,
						data: ds.data,
						backgroundColor: ds.backgroundColor,
						borderColor: ds.borderColor,
						borderWidth: 1,
						borderRadius: 2
					}))
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					plugins: {
						legend: {
							display: true,
							position: 'bottom',
							labels: {
								color: 'oklch(var(--bc))',
								usePointStyle: true,
								padding: 20
							}
						}
					},
					scales: {
						y: {
							stacked: true,
							beginAtZero: true,
							ticks: {
								color: 'oklch(var(--bc) / 0.7)'
							},
							grid: {
								color: 'oklch(var(--bc) / 0.1)'
							}
						},
						x: {
							stacked: true,
							ticks: {
								color: 'oklch(var(--bc) / 0.7)',
								maxRotation: 45,
								minRotation: 0
							},
							grid: {
								display: false
							}
						}
					}
				}
			});
		})();
	</script>
}
