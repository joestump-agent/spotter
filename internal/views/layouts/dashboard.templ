package layouts

import (
	"spotter/internal/config"
	"spotter/internal/views/components"
	"strings"
)

func isActive(currentPath, targetPath string) bool {
	return currentPath == targetPath
}

func isPreferencesSection(currentPath string) bool {
	return strings.HasPrefix(currentPath, "/preferences")
}

func isPreferencesActive(currentPath string) bool {
	return isPreferencesSection(currentPath) &&
		!isActive(currentPath, "/preferences/appearance") &&
		!isActive(currentPath, "/preferences/providers") &&
		!isActive(currentPath, "/preferences/tasks")
}

func isLibrarySection(currentPath string) bool {
	return strings.HasPrefix(currentPath, "/library") ||
		strings.HasPrefix(currentPath, "/recent") ||
		strings.HasPrefix(currentPath, "/playlists")
}

func isVibesSection(currentPath string) bool {
	return strings.HasPrefix(currentPath, "/vibes")
}

templ Dashboard(title string, cfg *config.Config, currentPath string) {
	@BaseWithTheme(title, cfg.Theme.Default) {
		<div class="drawer lg:drawer-open" hx-ext="sse" sse-connect="/events">
			<input id="drawer-toggle" type="checkbox" class="drawer-toggle"/>
			<!-- Main Content -->
			<div class="drawer-content flex flex-col">
				<!-- Navbar for mobile -->
				<div class="navbar bg-base-100 lg:hidden shadow-sm">
					<div class="flex-none">
						<label for="drawer-toggle" class="btn btn-square btn-ghost">
							<span class="icon-[heroicons--bars-3] w-6 h-6"></span>
						</label>
					</div>
					<div class="flex-1 flex items-center gap-2">
						<span class="icon-[heroicons--musical-note] w-6 h-6 text-primary"></span>
						<a href="/" class="btn btn-ghost text-xl font-bold text-primary tracking-wide">Spotter</a>
					</div>
				</div>
				<!-- Page Content -->
				<div class="flex-1 p-6 lg:p-8 bg-base-200 min-h-screen">
					{ children... }
				</div>
			</div>
			<!-- Sidebar -->
			<div class="drawer-side">
				<label for="drawer-toggle" aria-label="close sidebar" class="drawer-overlay"></label>
				<aside class="bg-base-100 w-80 min-h-full flex flex-col border-r border-base-300">
					<!-- Logo -->
					<div class="p-6 border-b border-base-300">
						<a href="/" class="block">
							<div class="flex items-center justify-center gap-3">
								<span class="icon-[heroicons--musical-note] w-10 h-10 text-primary"></span>
								<h1 class="text-3xl font-bold text-primary tracking-wide">Spotter</h1>
							</div>
						</a>
					</div>
					<!-- Navigation -->
					<nav class="flex-1 p-4">
						<ul class="menu menu-lg gap-1">
							<li>
								<a href="/" class={ "flex items-center gap-3", templ.KV("active", isActive(currentPath, "/")) }>
									<span class="icon-[heroicons--home] w-5 h-5"></span>
									<span>Home</span>
								</a>
							</li>
							<li>
								<details open?={ isVibesSection(currentPath) }>
									<summary class={ "flex items-center gap-3", templ.KV("active", false) }>
										<span class="icon-[heroicons--sparkles] w-5 h-5"></span>
										<span>Vibes</span>
									</summary>
									<ul>
										<li>
											<a href="/vibes/djs" class={ "flex items-center gap-3", templ.KV("active", isActive(currentPath, "/vibes/djs")) }>
												<span class="icon-[heroicons--user-circle] w-5 h-5"></span>
												<span>DJs</span>
											</a>
										</li>
										<li>
											<a href="/vibes/mixtapes" class={ "flex items-center gap-3", templ.KV("active", strings.HasPrefix(currentPath, "/vibes/mixtapes")) }>
												<span class="icon-[heroicons--musical-note] w-5 h-5"></span>
												<span>Mixtapes</span>
											</a>
										</li>
									</ul>
								</details>
							</li>
							<li>
								<details open?={ isLibrarySection(currentPath) }>
									<summary class={ "flex items-center gap-3", templ.KV("active", false) }>
										<span class="icon-[heroicons--folder] w-5 h-5"></span>
										<span>Library</span>
									</summary>
									<ul>
										<li>
											<a href="/recent" class={ "flex items-center gap-3", templ.KV("active", isActive(currentPath, "/recent")) }>
												<span class="icon-[heroicons--clock] w-5 h-5"></span>
												<span>Listens</span>
											</a>
										</li>
										<li>
											<a href="/playlists" class={ "flex items-center gap-3", templ.KV("active", strings.HasPrefix(currentPath, "/playlists")) }>
												<span class="icon-[heroicons--queue-list] w-5 h-5"></span>
												<span>Playlists</span>
											</a>
										</li>
										<li>
											<a href="/library/artists" class={ "flex items-center gap-3", templ.KV("active", strings.HasPrefix(currentPath, "/library/artist")) }>
												<span class="icon-[heroicons--user-group] w-5 h-5"></span>
												<span>Artists</span>
											</a>
										</li>
										<li>
											<a href="/library/albums" class={ "flex items-center gap-3", templ.KV("active", strings.HasPrefix(currentPath, "/library/album")) }>
												<span class="icon-[heroicons--square-3-stack-3d] w-5 h-5"></span>
												<span>Albums</span>
											</a>
										</li>
										<li>
											<a href="/library/tracks" class={ "flex items-center gap-3", templ.KV("active", strings.HasPrefix(currentPath, "/library/track")) }>
												<span class="icon-[heroicons--musical-note] w-5 h-5"></span>
												<span>Tracks</span>
											</a>
										</li>
									</ul>
								</details>
							</li>
							<li>
								<details open?={ isPreferencesSection(currentPath) }>
									<summary class={ "flex items-center gap-3", templ.KV("active", isPreferencesActive(currentPath)) }>
										<span class="icon-[heroicons--cog-6-tooth] w-5 h-5"></span>
										<span>Preferences</span>
									</summary>
									<ul>
										<li>
											<a href="/preferences/appearance" class={ "flex items-center gap-3", templ.KV("active", isActive(currentPath, "/preferences/appearance")) }>
												<span class="icon-[heroicons--paint-brush] w-5 h-5"></span>
												<span>Appearance</span>
											</a>
										</li>
										<li>
											<a href="/preferences/providers" class={ "flex items-center gap-3", templ.KV("active", isActive(currentPath, "/preferences/providers")) }>
												<span class="icon-[heroicons--link] w-5 h-5"></span>
												<span>Providers</span>
											</a>
										</li>
										<li>
											<a href="/preferences/tasks" class={ "flex items-center gap-3", templ.KV("active", isActive(currentPath, "/preferences/tasks")) }>
												<span class="icon-[heroicons--play-circle] w-5 h-5"></span>
												<span>Tasks</span>
											</a>
										</li>
									</ul>
								</details>
							</li>
						</ul>
					</nav>
					<!-- Logout -->
					<div class="p-4 border-t border-base-300">
						<a href="/logout" class="btn btn-ghost btn-block justify-start gap-3">
							<span class="icon-[heroicons--arrow-right-on-rectangle] w-5 h-5"></span>
							<span>Logout</span>
						</a>
					</div>
				</aside>
			</div>
			@components.ToastContainer()
		</div>
		<script>
			// Theme initialization - runs immediately
			(function() {
				const defaultTheme = '{ cfg.Theme.Default }';
				const savedTheme = localStorage.getItem('spotter-theme');
				const activeTheme = savedTheme || defaultTheme;
				document.documentElement.setAttribute('data-theme', activeTheme);
			})();
		</script>
	}
}
