package layouts

templ Base(title string) {
	@BaseWithTheme(title, "dark") {
		{ children... }
	}
}

templ BaseWithTheme(title string, defaultTheme string) {
	<!DOCTYPE html>
	<html
		lang="en"
		class="h-full"
		if defaultTheme != "" {
			data-theme={ defaultTheme }
		}
	>
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title }</title>
			<script src="https://unpkg.com/htmx.org@1.9.10"></script>
			<!-- Governing: SPEC event-bus-sse REQ-SSE-010 (load HTMX SSE extension) -->
			<script src="https://unpkg.com/htmx.org@1.9.10/dist/ext/sse.js"></script>
			// Hyperscript: required for _="..." attributes in create_mixtape_modal, enhance_vibes_modal
			<script src="https://unpkg.com/hyperscript.org@0.9.12"></script>
			<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.15.8/dist/cdn.min.js"></script>
			<!-- Governing: SPEC user-authentication REQ "Security Headers and Server Timeouts" —
			     timeago is served from cdn.jsdelivr.net (already allowed by the CSP script-src in
			     internal/middleware/security.go) instead of cdnjs.cloudflare.com, which the CSP
			     blocks. Keeping the CSP surface small is preferred over allowing another origin. -->
			<script src="https://cdn.jsdelivr.net/npm/timeago.js@4.0.2/dist/timeago.min.js"></script>
			<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
			<link href="/static/css/output.css" rel="stylesheet"/>
			<style>
				[x-cloak] { display: none !important; }
			</style>
		</head>
		<body class="h-full antialiased">
			{ children... }
		</body>
	</html>
}
