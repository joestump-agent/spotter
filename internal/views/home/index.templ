package home

import (
	"spotter/internal/views/layouts"
	"spotter/internal/config"
	"strconv"
	"time"
)

// ProviderStats holds statistics for a single provider
type ProviderStats struct {
	Name          string
	Connected     bool
	Username      string
	LastSyncedAt  time.Time
	UniqueArtists int
	UniqueAlbums  int
	TotalListens  int
	ServerURL     string // Only used for Navidrome
	ServerOnline  bool   // Only used for Navidrome
}

// HomeStats holds all statistics for the home HUD
type HomeStats struct {
	TotalListens  int
	UniqueArtists int
	UniqueAlbums  int
	NavidromeURL  string
	LoggedInUser  string
	Providers     []ProviderStats
}

func formatNumber(n int) string {
	return strconv.Itoa(n)
}

func formatISO(t time.Time) string {
	if t.IsZero() {
		return ""
	}
	return t.UTC().Format(time.RFC3339)
}

templ Index(cfg *config.Config, stats *HomeStats) {
	@layouts.Dashboard("Home | Spotter", cfg, "/") {
		<div class="max-w-6xl mx-auto">
			<!-- Welcome Header -->
			<div class="mb-8">
				<h2 class="text-3xl font-bold">Welcome back, { stats.LoggedInUser }</h2>
				<p class="text-base-content/60 mt-2">Here's an overview of your music library</p>
			</div>

			<!-- Main Stats HUD -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
				<!-- Total Listens -->
				<div class="stat bg-base-100 rounded-box shadow-xl">
					<div class="stat-figure text-primary">
						<span class="icon-[heroicons--play-circle] w-12 h-12"></span>
					</div>
					<div class="stat-title">Total Listens</div>
					<div class="stat-value text-primary">{ formatNumber(stats.TotalListens) }</div>
					<div class="stat-desc">across all providers</div>
				</div>

				<!-- Unique Artists -->
				<div class="stat bg-base-100 rounded-box shadow-xl">
					<div class="stat-figure text-secondary">
						<span class="icon-[heroicons--user-group] w-12 h-12"></span>
					</div>
					<div class="stat-title">Unique Artists</div>
					<div class="stat-value text-secondary">{ formatNumber(stats.UniqueArtists) }</div>
					<div class="stat-desc">you've listened to</div>
				</div>

				<!-- Unique Albums -->
				<div class="stat bg-base-100 rounded-box shadow-xl">
					<div class="stat-figure text-accent">
						<span class="icon-[heroicons--square-3-stack-3d] w-12 h-12"></span>
					</div>
					<div class="stat-title">Unique Albums</div>
					<div class="stat-value text-accent">{ formatNumber(stats.UniqueAlbums) }</div>
					<div class="stat-desc">in your history</div>
				</div>
			</div>

			<!-- Provider Stats Grid -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
				for _, provider := range stats.Providers {
					<div class="card bg-base-100 shadow-xl h-full">
						<div class="card-body flex flex-col">
							<div class="flex items-center justify-between">
								<h4 class="card-title text-lg">
									if provider.Name == "Navidrome" {
										<span class="icon-[heroicons--musical-note] w-5 h-5" style="color: #4285F4;"></span>
									} else if provider.Name == "Spotify" {
										<span class="icon-[simple-icons--spotify] w-5 h-5 text-success"></span>
									} else if provider.Name == "Last.fm" {
										<span class="icon-[simple-icons--lastdotfm] w-5 h-5 text-error"></span>
									}
									{ provider.Name }
								</h4>
								if provider.Name == "Navidrome" {
									<!-- Navidrome shows Online/Offline status -->
									if provider.ServerOnline {
										<div class="badge badge-success badge-sm gap-1">
											<span class="icon-[heroicons--signal] w-3 h-3"></span>
											Online
										</div>
									} else {
										<div class="badge badge-error badge-sm gap-1">
											<span class="icon-[heroicons--signal-slash] w-3 h-3"></span>
											Offline
										</div>
									}
								} else {
									<!-- Other providers show Connected/Not Connected -->
									if provider.Connected {
										<div class="badge badge-success badge-sm gap-1">
											<span class="icon-[heroicons--check-circle] w-3 h-3"></span>
											Connected
										</div>
									} else {
										<div class="badge badge-ghost badge-sm gap-1">
											<span class="icon-[heroicons--x-circle] w-3 h-3"></span>
											Not Connected
										</div>
									}
								}
							</div>

							if provider.Connected {
								<!-- User Info -->
								<div class="mt-4 space-y-3">
									<div class="flex items-center gap-2 text-sm">
										<span class="icon-[heroicons--user] w-4 h-4 text-base-content/60"></span>
										<span class="text-base-content/60">Logged in as:</span>
										<span class="font-medium">{ provider.Username }</span>
									</div>

									<!-- Last Synced -->
									<div class="flex items-center gap-2 text-sm">
										<span class="icon-[heroicons--clock] w-4 h-4 text-base-content/60"></span>
										<span class="text-base-content/60">Last synced:</span>
										if !provider.LastSyncedAt.IsZero() {
											<span class="font-medium timeago" datetime={ formatISO(provider.LastSyncedAt) }>
												{ provider.LastSyncedAt.Local().Format("Jan 02, 2006 at 3:04 PM") }
											</span>
										} else {
											<span class="text-warning">Never</span>
										}
									</div>

									<!-- Server URL (Navidrome only) -->
									if provider.Name == "Navidrome" && provider.ServerURL != "" {
										<div class="text-sm">
											<div class="flex items-center gap-2">
												<span class="icon-[heroicons--globe-alt] w-4 h-4 text-base-content/60"></span>
												<span class="text-base-content/60">Server:</span>
											</div>
											<code class="bg-base-200 px-2 py-1 rounded text-xs font-mono mt-1 block ml-6">{ provider.ServerURL }</code>
										</div>
									}
								</div>

								<!-- Provider Stats -->
								<div class="mt-auto">
									<div class="divider my-3"></div>
									<div class="grid grid-cols-3 gap-2 text-center">
									<div>
										<div class="text-2xl font-bold">{ formatNumber(provider.TotalListens) }</div>
										<div class="text-xs text-base-content/60">Listens</div>
									</div>
									<div>
										<div class="text-2xl font-bold">{ formatNumber(provider.UniqueArtists) }</div>
										<div class="text-xs text-base-content/60">Artists</div>
									</div>
									<div>
										<div class="text-2xl font-bold">{ formatNumber(provider.UniqueAlbums) }</div>
										<div class="text-xs text-base-content/60">Albums</div>
									</div>
								</div>
								</div>
							} else {
								<div class="mt-4 text-center py-6">
									<span class="icon-[heroicons--link] w-8 h-8 text-base-content/30"></span>
									<p class="text-sm text-base-content/60 mt-2">
										if provider.Name == "Last.fm" {
											Coming soon
										} else {
											Connect in <a href="/preferences/providers" class="link link-primary">Preferences</a>
										}
									</p>
								</div>
							}
						</div>
					</div>
				}
			</div>
		</div>

		<!-- Timeago script -->
		<script>
			// Initialize timeago for all elements with the timeago class
			(function() {
				if (typeof timeago !== 'undefined') {
					const nodes = document.querySelectorAll('.timeago');
					if (nodes.length > 0) {
						timeago.render(nodes);
					}
				}
			})();
		</script>
	}
}
