package home

import (
	"encoding/json"
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
	"time"
)

// ProviderStats holds statistics for a single provider
type ProviderStats struct {
	Name          string
	Connected     bool
	Username      string
	LastSyncedAt  time.Time
	UniqueArtists int
	UniqueAlbums  int
	TotalListens  int
	ServerURL     string // Only used for Navidrome
	ServerOnline  bool   // Only used for Navidrome
}

// TopArtist holds data for the top artists section
type TopArtist struct {
	Artist  *ent.Artist
	Listens int
}

// HomeStats holds all statistics for the home HUD
type HomeStats struct {
	TotalListens        int
	UniqueArtists       int
	UniqueAlbums        int
	UniqueTracks        int
	NavidromeURL        string
	LoggedInUser        string
	Providers           []ProviderStats
	EnrichedArtistCount int
	EnrichedAlbumCount  int
	EnrichedTrackCount  int
	TopArtists          []TopArtist
}

func formatISO(t time.Time) string {
	if t.IsZero() {
		return ""
	}
	return t.UTC().Format(time.RFC3339)
}

func toJSON(v interface{}) string {
	b, err := json.Marshal(v)
	if err != nil {
		return "[]"
	}
	return string(b)
}

func getProviderTileProps(name string) components.ProviderProps {
	switch name {
	case "Navidrome":
		return components.ProviderProps{
			Name:           "Navidrome",
			Description:    "Your primary music server. Authentication is managed through your login credentials.",
			IconClass:      "icon-[heroicons--musical-note]",
			IconColorStyle: "#4285F4",
			ButtonStyle:    "background-color: #4285F4; border-color: #4285F4; color: white;",
			IsConnected:    false,
			ConnectURL:     "",
		}
	case "Spotify":
		return components.ProviderProps{
			Name:           "Spotify",
			Description:    "Connect your Spotify account to import listening history and get better recommendations.",
			IconClass:      "icon-[simple-icons--spotify]",
			IconColorClass: "text-success",
			ButtonClass:    "btn-success",
			IsConnected:    false,
			ConnectURL:     "/auth/spotify/login",
		}
	case "Last.fm":
		return components.ProviderProps{
			Name:           "Last.fm",
			Description:    "Connect your Last.fm account to scrobble tracks and improve recommendations.",
			IconClass:      "icon-[simple-icons--lastdotfm]",
			IconColorClass: "text-error",
			ButtonClass:    "btn-error",
			IsConnected:    false,
			ConnectURL:     "/auth/lastfm/login",
		}
	default:
		return components.ProviderProps{Name: name}
	}
}

templ Index(cfg *config.Config, stats *HomeStats) {
	@layouts.Dashboard("Home | Spotter", cfg, "/") {
		<div class="max-w-7xl mx-auto">
			<!-- Welcome Header -->
			<div class="mb-8">
				<h2 class="text-3xl font-bold">Welcome back, { stats.LoggedInUser }</h2>
				<p class="text-base-content/60 mt-2">Here's an overview of your music library</p>
			</div>
			<!-- Main Stats HUD -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
				@components.StatCardLink("Total Listens", components.FormatNumber(stats.TotalListens), "across all providers", "icon-[heroicons--play-circle]", "text-primary", "/recent")
				@components.StatCardLink("Unique Artists", components.FormatNumber(stats.UniqueArtists), "you've listened to", "icon-[heroicons--user-group]", "text-secondary", "/library/artists")
				@components.StatCardLink("Unique Albums", components.FormatNumber(stats.UniqueAlbums), "in your history", "icon-[heroicons--square-3-stack-3d]", "text-accent", "/library/albums")
				@components.StatCardLink("Unique Tracks", components.FormatNumber(stats.UniqueTracks), "played", "icon-[heroicons--musical-note]", "text-info", "/library/tracks")
			</div>
			<!-- Provider Stats Grid -->
			<h3 class="text-xl font-bold mb-4 flex items-center gap-2">
				<span class="icon-[heroicons--link] w-5 h-5"></span>
				Connected Providers
			</h3>
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
				for _, provider := range stats.Providers {
					if provider.Connected {
						<div class="card bg-base-100 shadow-xl h-full">
							<div class="card-body flex flex-col">
								<div class="flex items-center justify-between">
									<h4 class="card-title text-lg">
										if provider.Name == "Navidrome" {
											<span class="icon-[heroicons--musical-note] w-5 h-5" style="color: #4285F4;"></span>
										} else if provider.Name == "Spotify" {
											<span class="icon-[simple-icons--spotify] w-5 h-5 text-success"></span>
										} else if provider.Name == "Last.fm" {
											<span class="icon-[simple-icons--lastdotfm] w-5 h-5 text-error"></span>
										}
										{ provider.Name }
									</h4>
									if provider.Name == "Navidrome" {
										<!-- Navidrome shows Online/Offline status -->
										if provider.ServerOnline {
											<div class="badge badge-success badge-sm gap-1">
												<span class="icon-[heroicons--signal] w-3 h-3"></span>
												Online
											</div>
										} else {
											<div class="badge badge-error badge-sm gap-1">
												<span class="icon-[heroicons--signal-slash] w-3 h-3"></span>
												Offline
											</div>
										}
									} else {
										<div class="badge badge-success badge-sm gap-1">
											<span class="icon-[heroicons--check-circle] w-3 h-3"></span>
											Connected
										</div>
									}
								</div>
								<!-- User Info -->
								<div class="mt-4 space-y-3">
									<div class="flex items-center gap-2 text-sm">
										<span class="icon-[heroicons--user] w-4 h-4 text-base-content/60"></span>
										<span class="text-base-content/60">Logged in as:</span>
										<span class="font-medium">{ provider.Username }</span>
									</div>
									<!-- Last Synced -->
									<div class="flex items-center gap-2 text-sm">
										<span class="icon-[heroicons--clock] w-4 h-4 text-base-content/60"></span>
										<span class="text-base-content/60">Last synced:</span>
										if !provider.LastSyncedAt.IsZero() {
											<span class="font-medium timeago" datetime={ formatISO(provider.LastSyncedAt) }>
												{ provider.LastSyncedAt.Local().Format("Jan 02, 2006 at 3:04 PM") }
											</span>
										} else {
											<span class="text-warning">Never</span>
										}
									</div>
									<!-- Server URL (Navidrome only) -->
									if provider.Name == "Navidrome" && provider.ServerURL != "" {
										<div class="text-sm">
											<div class="flex items-center gap-2">
												<span class="icon-[heroicons--globe-alt] w-4 h-4 text-base-content/60"></span>
												<span class="text-base-content/60">Server:</span>
											</div>
											<code class="bg-base-200 px-2 py-1 rounded text-xs font-mono mt-1 block ml-6">{ provider.ServerURL }</code>
										</div>
									}
								</div>
								<!-- Provider Stats -->
								<div class="mt-auto">
									<div class="divider my-3"></div>
									<div class="grid grid-cols-3 gap-2 text-center">
										<div>
											<div class="text-2xl font-bold">{ components.FormatNumber(provider.TotalListens) }</div>
											<div class="text-xs text-base-content/60">Listens</div>
										</div>
										<div>
											<div class="text-2xl font-bold">{ components.FormatNumber(provider.UniqueArtists) }</div>
											<div class="text-xs text-base-content/60">Artists</div>
										</div>
										<div>
											<div class="text-2xl font-bold">{ components.FormatNumber(provider.UniqueAlbums) }</div>
											<div class="text-xs text-base-content/60">Albums</div>
										</div>
									</div>
								</div>
							</div>
						</div>
					} else {
						@components.ProviderTile(getProviderTileProps(provider.Name))
					}
				}
			</div>
			<!-- Top Artists -->
			if len(stats.TopArtists) > 0 {
				<h3 class="text-xl font-bold mb-4 flex items-center gap-2">
					<span class="icon-[heroicons--trophy] w-5 h-5"></span>
					Top Artists
				</h3>
				<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 mb-8">
					for _, topArtist := range stats.TopArtists {
						@components.ArtistTile(topArtist.Artist)
					}
				</div>
			}
		</div>
		<!-- Timeago script -->
		<script>
			// Initialize timeago for all elements with the timeago class
			(function() {
				if (typeof timeago !== 'undefined') {
					const nodes = document.querySelectorAll('.timeago');
					if (nodes.length > 0) {
						timeago.render(nodes);
					}
				}
			})();
		</script>
	}
}

func max(a, b int) int {
	if a > b {
		return a
	}
	return b
}
