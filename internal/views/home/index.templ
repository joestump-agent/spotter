package home

import (
	"encoding/json"
	"fmt"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
	"strconv"
	"time"
)

// ProviderStats holds statistics for a single provider
type ProviderStats struct {
	Name          string
	Connected     bool
	Username      string
	LastSyncedAt  time.Time
	UniqueArtists int
	UniqueAlbums  int
	TotalListens  int
	ServerURL     string // Only used for Navidrome
	ServerOnline  bool   // Only used for Navidrome
}

// HomeStats holds all statistics for the home HUD
type HomeStats struct {
	TotalListens        int
	UniqueArtists       int
	UniqueAlbums        int
	UniqueTracks        int
	NavidromeURL        string
	LoggedInUser        string
	Providers           []ProviderStats
	ListensByHour       []components.ChartDataPoint
	ListensByDayOfWeek  []components.ChartDataPoint
	ListensByMonth      []components.ChartDataPoint
	GenreBreakdown      []components.ChartDataPoint
	TopArtists          []components.ChartDataPoint
	TopAlbums           []components.ChartDataPoint
	RecentActivity      components.StackedChartData
	TagCloud            []string
	EnrichedArtistCount int
	EnrichedAlbumCount  int
	EnrichedTrackCount  int
}

func formatNumber(n int) string {
	return strconv.Itoa(n)
}

func formatISO(t time.Time) string {
	if t.IsZero() {
		return ""
	}
	return t.UTC().Format(time.RFC3339)
}

func toJSON(v interface{}) string {
	b, err := json.Marshal(v)
	if err != nil {
		return "[]"
	}
	return string(b)
}

func getGenreRadarColors(count int) []string {
	colors := []string{
		"#8b5cf6", "#06b6d4", "#f59e0b", "#ef4444", "#10b981",
		"#f97316", "#ec4899", "#3b82f6", "#84cc16", "#6366f1",
	}
	if count <= len(colors) {
		return colors[:count]
	}
	result := make([]string, count)
	for i := 0; i < count; i++ {
		result[i] = colors[i%len(colors)]
	}
	return result
}

templ Index(cfg *config.Config, stats *HomeStats) {
	@layouts.Dashboard("Home | Spotter", cfg, "/") {
		@components.ChartJSScript()
		<div class="max-w-7xl mx-auto">
			<!-- Welcome Header -->
			<div class="mb-8">
				<h2 class="text-3xl font-bold">Welcome back, { stats.LoggedInUser }</h2>
				<p class="text-base-content/60 mt-2">Here's an overview of your music library</p>
			</div>
			<!-- Main Stats HUD -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
				@components.StatCardLink("Total Listens", formatNumber(stats.TotalListens), "across all providers", "icon-[heroicons--play-circle]", "text-primary", "/recent")
				@components.StatCardLink("Unique Artists", formatNumber(stats.UniqueArtists), "you've listened to", "icon-[heroicons--user-group]", "text-secondary", "/library/artists")
				@components.StatCardLink("Unique Albums", formatNumber(stats.UniqueAlbums), "in your history", "icon-[heroicons--square-3-stack-3d]", "text-accent", "/library/albums")
				@components.StatCardLink("Unique Tracks", formatNumber(stats.UniqueTracks), "played", "icon-[heroicons--musical-note]", "text-info", "/library/tracks")
			</div>
			<!-- Recent Activity Chart -->
			<div class="card bg-base-100 shadow-xl mb-8">
				<div class="card-body">
					<div class="flex items-center justify-between mb-4">
						<h3 class="card-title">
							<span class="icon-[heroicons--chart-bar] w-5 h-5"></span>
							Listening Activity (Last 30 Days)
						</h3>
					</div>
					<div class="w-full" style="height: 300px">
						<canvas id="recent-activity-chart"></canvas>
					</div>
				</div>
			</div>
			@recentActivityScript(stats.RecentActivity)
			<!-- Genre & Top Content Row -->
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
				<!-- Genre Spider Chart -->
				if len(stats.GenreBreakdown) > 0 {
					<div class="card bg-base-100 shadow-xl">
						<div class="card-body">
							<h3 class="card-title">
								<span class="icon-[heroicons--tag] w-5 h-5"></span>
								Listening by Genre
							</h3>
							<div class="w-full" style="height: 350px">
								<canvas id="genre-radar-chart"></canvas>
							</div>
						</div>
					</div>
					@genreRadarScript(stats.GenreBreakdown)
				}
				<!-- Top Artists -->
				if len(stats.TopArtists) > 0 {
					<div class="card bg-base-100 shadow-xl">
						<div class="card-body">
							<h3 class="card-title">
								<span class="icon-[heroicons--fire] w-5 h-5 text-error"></span>
								Top Artists
							</h3>
							@components.HorizontalBarChart(
								"top-artists-chart",
								"",
								stats.TopArtists,
								"oklch(var(--p))",
								fmt.Sprintf("%dpx", max(200, len(stats.TopArtists)*35)),
							)
						</div>
					</div>
				}
			</div>
			<!-- Listening Patterns Row -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
				<!-- By Hour -->
				<div class="card bg-base-100 shadow-xl">
					<div class="card-body">
						<h3 class="card-title text-base">
							<span class="icon-[heroicons--clock] w-5 h-5"></span>
							Listens by Hour
						</h3>
						@components.BarChart(
							"home-hour-chart",
							"",
							stats.ListensByHour,
							"oklch(var(--p))",
							"200px",
						)
					</div>
				</div>
				<!-- By Day of Week -->
				<div class="card bg-base-100 shadow-xl">
					<div class="card-body">
						<h3 class="card-title text-base">
							<span class="icon-[heroicons--calendar-days] w-5 h-5"></span>
							Listens by Day
						</h3>
						@components.BarChart(
							"home-day-chart",
							"",
							stats.ListensByDayOfWeek,
							"oklch(var(--s))",
							"200px",
						)
					</div>
				</div>
				<!-- By Month -->
				<div class="card bg-base-100 shadow-xl">
					<div class="card-body">
						<h3 class="card-title text-base">
							<span class="icon-[heroicons--calendar] w-5 h-5"></span>
							Listens by Month
						</h3>
						@components.BarChart(
							"home-month-chart",
							"",
							stats.ListensByMonth,
							"oklch(var(--a))",
							"200px",
						)
					</div>
				</div>
			</div>
			<!-- Tags Cloud -->
			if len(stats.TagCloud) > 0 {
				<div class="card bg-base-100 shadow-xl mb-8">
					<div class="card-body">
						<h3 class="card-title">
							<span class="icon-[heroicons--hashtag] w-5 h-5"></span>
							Popular Tags
						</h3>
						<div class="flex flex-wrap gap-2 mt-4">
							for i, tag := range stats.TagCloud {
								if i < 30 {
									<span class={ "badge", getBadgeClass(i) }>{ tag }</span>
								}
							}
						</div>
					</div>
				</div>
			}
			<!-- Provider Stats Grid -->
			<h3 class="text-xl font-bold mb-4 flex items-center gap-2">
				<span class="icon-[heroicons--link] w-5 h-5"></span>
				Connected Providers
			</h3>
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
				for _, provider := range stats.Providers {
					<div class="card bg-base-100 shadow-xl h-full">
						<div class="card-body flex flex-col">
							<div class="flex items-center justify-between">
								<h4 class="card-title text-lg">
									if provider.Name == "Navidrome" {
										<span class="icon-[heroicons--musical-note] w-5 h-5" style="color: #4285F4;"></span>
									} else if provider.Name == "Spotify" {
										<span class="icon-[simple-icons--spotify] w-5 h-5 text-success"></span>
									} else if provider.Name == "Last.fm" {
										<span class="icon-[simple-icons--lastdotfm] w-5 h-5 text-error"></span>
									}
									{ provider.Name }
								</h4>
								if provider.Name == "Navidrome" {
									<!-- Navidrome shows Online/Offline status -->
									if provider.ServerOnline {
										<div class="badge badge-success badge-sm gap-1">
											<span class="icon-[heroicons--signal] w-3 h-3"></span>
											Online
										</div>
									} else {
										<div class="badge badge-error badge-sm gap-1">
											<span class="icon-[heroicons--signal-slash] w-3 h-3"></span>
											Offline
										</div>
									}
								} else {
									<!-- Other providers show Connected/Not Connected -->
									if provider.Connected {
										<div class="badge badge-success badge-sm gap-1">
											<span class="icon-[heroicons--check-circle] w-3 h-3"></span>
											Connected
										</div>
									} else {
										<div class="badge badge-ghost badge-sm gap-1">
											<span class="icon-[heroicons--x-circle] w-3 h-3"></span>
											Not Connected
										</div>
									}
								}
							</div>
							if provider.Connected {
								<!-- User Info -->
								<div class="mt-4 space-y-3">
									<div class="flex items-center gap-2 text-sm">
										<span class="icon-[heroicons--user] w-4 h-4 text-base-content/60"></span>
										<span class="text-base-content/60">Logged in as:</span>
										<span class="font-medium">{ provider.Username }</span>
									</div>
									<!-- Last Synced -->
									<div class="flex items-center gap-2 text-sm">
										<span class="icon-[heroicons--clock] w-4 h-4 text-base-content/60"></span>
										<span class="text-base-content/60">Last synced:</span>
										if !provider.LastSyncedAt.IsZero() {
											<span class="font-medium timeago" datetime={ formatISO(provider.LastSyncedAt) }>
												{ provider.LastSyncedAt.Local().Format("Jan 02, 2006 at 3:04 PM") }
											</span>
										} else {
											<span class="text-warning">Never</span>
										}
									</div>
									<!-- Server URL (Navidrome only) -->
									if provider.Name == "Navidrome" && provider.ServerURL != "" {
										<div class="text-sm">
											<div class="flex items-center gap-2">
												<span class="icon-[heroicons--globe-alt] w-4 h-4 text-base-content/60"></span>
												<span class="text-base-content/60">Server:</span>
											</div>
											<code class="bg-base-200 px-2 py-1 rounded text-xs font-mono mt-1 block ml-6">{ provider.ServerURL }</code>
										</div>
									}
								</div>
								<!-- Provider Stats -->
								<div class="mt-auto">
									<div class="divider my-3"></div>
									<div class="grid grid-cols-3 gap-2 text-center">
										<div>
											<div class="text-2xl font-bold">{ formatNumber(provider.TotalListens) }</div>
											<div class="text-xs text-base-content/60">Listens</div>
										</div>
										<div>
											<div class="text-2xl font-bold">{ formatNumber(provider.UniqueArtists) }</div>
											<div class="text-xs text-base-content/60">Artists</div>
										</div>
										<div>
											<div class="text-2xl font-bold">{ formatNumber(provider.UniqueAlbums) }</div>
											<div class="text-xs text-base-content/60">Albums</div>
										</div>
									</div>
								</div>
							} else {
								<div class="mt-4 text-center py-6">
									<span class="icon-[heroicons--link] w-8 h-8 text-base-content/30"></span>
									<p class="text-sm text-base-content/60 mt-2">
										if provider.Name == "Last.fm" {
											Coming soon
										} else {
											Connect in <a href="/preferences/providers" class="link link-primary">Preferences</a>
										}
									</p>
								</div>
							}
						</div>
					</div>
				}
			</div>
		</div>
		<!-- Timeago script -->
		<script>
			// Initialize timeago for all elements with the timeago class
			(function() {
				if (typeof timeago !== 'undefined') {
					const nodes = document.querySelectorAll('.timeago');
					if (nodes.length > 0) {
						timeago.render(nodes);
					}
				}
			})();
		</script>
	}
}

templ recentActivityScript(data components.StackedChartData) {
	<script>
		(function() {
			const ctx = document.getElementById('recent-activity-chart');
			if (!ctx) return;

			const chartData = JSON.parse('{{ toJSON(data) }}');

			new Chart(ctx, {
				type: 'bar',
				data: {
					labels: chartData.labels,
					datasets: chartData.datasets.map(ds => ({
						label: ds.label,
						data: ds.data,
						backgroundColor: ds.backgroundColor,
						borderColor: ds.borderColor,
						borderWidth: 1,
						borderRadius: 2
					}))
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					plugins: {
						legend: {
							display: true,
							position: 'bottom',
							labels: {
								color: 'oklch(var(--bc))',
								usePointStyle: true,
								padding: 20
							}
						}
					},
					scales: {
						y: {
							stacked: true,
							beginAtZero: true,
							ticks: {
								color: 'oklch(var(--bc) / 0.7)'
							},
							grid: {
								color: 'oklch(var(--bc) / 0.1)'
							}
						},
						x: {
							stacked: true,
							ticks: {
								color: 'oklch(var(--bc) / 0.7)',
								maxRotation: 45,
								minRotation: 0
							},
							grid: {
								display: false
							}
						}
					}
				}
			});
		})();
	</script>
}

templ genreRadarScript(data []components.ChartDataPoint) {
	<script>
		(function() {
			const ctx = document.getElementById('genre-radar-chart');
			if (!ctx) return;

			const chartData = JSON.parse('{{ toJSON(data) }}');
			const labels = chartData.map(d => d.label);
			const values = chartData.map(d => d.value);
			const maxValue = Math.max(...values);

			new Chart(ctx, {
				type: 'radar',
				data: {
					labels: labels,
					datasets: [{
						label: 'Listens by Genre',
						data: values,
						backgroundColor: 'oklch(var(--p) / 0.3)',
						borderColor: 'oklch(var(--p))',
						borderWidth: 2,
						pointBackgroundColor: 'oklch(var(--p))',
						pointBorderColor: '#fff',
						pointHoverBackgroundColor: '#fff',
						pointHoverBorderColor: 'oklch(var(--p))'
					}]
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					plugins: {
						legend: {
							display: false
						}
					},
					scales: {
						r: {
							beginAtZero: true,
							max: maxValue > 0 ? Math.ceil(maxValue * 1.1) : 100,
							ticks: {
								color: 'oklch(var(--bc) / 0.7)',
								backdropColor: 'transparent',
								stepSize: Math.ceil(maxValue / 5)
							},
							grid: {
								color: 'oklch(var(--bc) / 0.2)'
							},
							pointLabels: {
								color: 'oklch(var(--bc))',
								font: {
									size: 11
								}
							},
							angleLines: {
								color: 'oklch(var(--bc) / 0.2)'
							}
						}
					}
				}
			});
		})();
	</script>
}

func getBadgeClass(index int) string {
	classes := []string{
		"badge-primary",
		"badge-secondary",
		"badge-accent",
		"badge-info",
		"badge-success",
		"badge-warning",
		"badge-error",
		"badge-primary badge-outline",
		"badge-secondary badge-outline",
		"badge-accent badge-outline",
	}
	return classes[index%len(classes)]
}

func max(a, b int) int {
	if a > b {
		return a
	}
	return b
}
