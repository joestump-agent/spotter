package tracks

import (
	"encoding/json"
	"fmt"
	"sort"
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
	"time"
)

// TrackStats holds statistics for a track
type TrackStats struct {
	TotalListens       int
	FirstListen        time.Time
	LastListen         time.Time
	ListensByProvider  []components.ChartDataPoint
	ListensByHour      []components.ChartDataPoint
	ListensByDayOfWeek []components.ChartDataPoint
	ListensByMonth     []components.ChartDataPoint
	ProviderHistory    components.StackedChartData
}

func formatDate(t time.Time) string {
	if t.IsZero() {
		return "N/A"
	}
	return t.Local().Format("Jan 2 '06")
}

func formatDuration(ms int) string {
	if ms <= 0 {
		return "N/A"
	}
	seconds := ms / 1000
	minutes := seconds / 60
	secs := seconds % 60
	if minutes >= 60 {
		hours := minutes / 60
		mins := minutes % 60
		return fmt.Sprintf("%d:%02d:%02d", hours, mins, secs)
	}
	return fmt.Sprintf("%d:%02d", minutes, secs)
}

func getOrDefault(value, defaultVal string) string {
	if value == "" {
		return defaultVal
	}
	return value
}

func getStringPtrOrDefault(value *string, defaultVal string) string {
	if value == nil || *value == "" {
		return defaultVal
	}
	return *value
}

func toJSON(v interface{}) string {
	b, err := json.Marshal(v)
	if err != nil {
		return "[]"
	}
	return string(b)
}

func formatEnrichedTime(t *time.Time) string {
	if t == nil || t.IsZero() {
		return "Never"
	}
	return t.Local().Format("Jan 02, 2006 at 3:04 PM")
}

func formatAiEnrichedTime(t *time.Time) string {
	if t == nil || t.IsZero() {
		return "Never"
	}
	return t.Local().Format("Jan 02, 2006 at 3:04 PM")
}

func getAlbumImage(track *ent.Track) string {
	if track.Edges.Album == nil || track.Edges.Album.Edges.Images == nil || len(track.Edges.Album.Edges.Images) == 0 {
		return ""
	}
	return fmt.Sprintf("/library/album/%d.png", track.Edges.Album.ID)
}

func hasAudioFeatures(track *ent.Track) bool {
	return (track.Energy != nil && *track.Energy > 0) ||
		(track.Danceability != nil && *track.Danceability > 0) ||
		(track.Valence != nil && *track.Valence > 0) ||
		(track.Acousticness != nil && *track.Acousticness > 0) ||
		(track.Instrumentalness != nil && *track.Instrumentalness > 0)
}

func getFloatValue(f *float64) float64 {
	if f == nil {
		return 0
	}
	return *f
}

func getIntValue(i *int) int {
	if i == nil {
		return 0
	}
	return *i
}

func formatBPM(bpm *float64) string {
	if bpm == nil || *bpm <= 0 {
		return "N/A"
	}
	return fmt.Sprintf("%.0f BPM", *bpm)
}

func formatPercent(f *float64) string {
	if f == nil {
		return "N/A"
	}
	return fmt.Sprintf("%.0f%%", *f*100)
}

type TagInfo struct {
	Name    string
	IsGenre bool
	IsAITag bool
}

func processTags(track *ent.Track) []TagInfo {
	// Combine and sort all tags
	var allTags []string
	allTags = append(allTags, track.Genres...)
	allTags = append(allTags, track.Tags...)
	allTags = append(allTags, track.AiTags...)
	// Deduplicate and sort
	tagMap := make(map[string]bool)
	for _, tag := range allTags {
		tagMap[tag] = true
	}
	uniqueTags := make([]string, 0, len(tagMap))
	for tag := range tagMap {
		uniqueTags = append(uniqueTags, tag)
	}
	sort.Strings(uniqueTags)
	aiTagsMap := make(map[string]struct{})
	for _, t := range track.AiTags {
		aiTagsMap[t] = struct{}{}
	}
	genresMap := make(map[string]struct{})
	for _, g := range track.Genres {
		genresMap[g] = struct{}{}
	}
	var result []TagInfo
	for _, tag := range uniqueTags {
		_, isAiTag := aiTagsMap[tag]
		_, isGenre := genresMap[tag]
		result = append(result, TagInfo{
			Name:    tag,
			IsGenre: isGenre,
			IsAITag: isAiTag,
		})
	}
	return result
}

templ Show(track *ent.Track, playlists []*ent.Playlist, stats *TrackStats, cfg *config.Config, currentTimeframe string) {
	@layouts.Dashboard(fmt.Sprintf("%s | Tracks | Spotter", track.Name), cfg, "/library/track") {
		<!-- AI Regenerate Modal -->
		<dialog id="ai-regenerate-modal" class="modal">
			<div class="modal-box">
				<h3 class="font-bold text-lg flex items-center gap-2">
					<span class="icon-[heroicons--sparkles] w-5 h-5 text-accent"></span>
					Regenerate AI Insights
				</h3>
				<p class="py-4">
					This will regenerate all AI-generated content for <strong>{ track.Name }</strong>, including the summary and tags.
				</p>
				<p class="text-sm text-base-content/60">
					This may take a few moments and will use your OpenAI API credits.
				</p>
				<div class="modal-action">
					<form method="dialog">
						<button class="btn btn-ghost">Cancel</button>
					</form>
					<button
						class="btn btn-primary"
						hx-post={ fmt.Sprintf("/library/track/%d/regenerate-ai", track.ID) }
						hx-swap="none"
						hx-indicator="#ai-regenerate-indicator"
						onclick="document.getElementById('ai-regenerate-modal').close()"
					>
						<span id="ai-regenerate-indicator" class="htmx-indicator loading loading-spinner loading-sm"></span>
						<span class="icon-[heroicons--sparkles] w-4 h-4"></span>
						Regenerate
					</button>
				</div>
			</div>
			<form method="dialog" class="modal-backdrop">
				<button>close</button>
			</form>
		</dialog>
		<!-- Hero Section -->
		<div class="relative -mx-6 lg:-mx-8 -mt-6 lg:-mt-8 mb-8">
			<!-- Background Blur -->
			if img := getAlbumImage(track); img != "" {
				<div class="absolute inset-0 h-80 overflow-hidden">
					<img src={ img } alt="" class="w-full h-full object-cover opacity-20 blur-2xl scale-110"/>
					<div class="absolute inset-0 bg-gradient-to-b from-transparent via-base-200/80 to-base-200"></div>
				</div>
			} else {
				<div class="absolute inset-0 h-80 bg-gradient-to-b from-accent/20 to-base-200"></div>
			}
			<!-- AI Menu (Top Right) -->
			<div class="absolute top-4 right-4 z-10">
				<details class="dropdown dropdown-end">
					<summary class="btn btn-sm btn-ghost bg-base-100/50 hover:bg-base-100/80 gap-1 list-none cursor-pointer">
						<span class="icon-[heroicons--sparkles] w-4 h-4 text-accent"></span>
						<span class="hidden sm:inline">AI</span>
						<span class="icon-[heroicons--chevron-down] w-3 h-3"></span>
					</summary>
					<ul class="dropdown-content z-[1] menu p-2 shadow-lg bg-base-100 rounded-box w-56">
						<li>
							<button onclick="document.getElementById('ai-regenerate-modal').showModal(); this.closest('details').removeAttribute('open');">
								<span class="icon-[heroicons--arrow-path] w-4 h-4"></span>
								Regenerate AI Enrichment
							</button>
						</li>
						<li>
							<button disabled class="opacity-50">
								<span class="icon-[heroicons--musical-note] w-4 h-4"></span>
								Generate Mixtape
								<span class="badge badge-xs">Soon</span>
							</button>
						</li>
					</ul>
				</details>
			</div>
			<!-- Track Info -->
			<div class="relative pt-8 px-6 lg:px-8 pb-8">
				<div class="max-w-7xl mx-auto">
					<div class="flex flex-col md:flex-row items-start gap-8">
						<!-- Album Cover -->
						<div class="flex-shrink-0">
							<div class="w-48 h-48 md:w-56 md:h-56 rounded-xl shadow-2xl ring ring-base-100 ring-offset-base-200 ring-offset-2 overflow-hidden">
								if img := getAlbumImage(track); img != "" {
									<img src={ img } alt={ track.Name } class="w-full h-full object-cover"/>
								} else {
									<div class="bg-base-300 w-full h-full flex items-center justify-center">
										<span class="icon-[heroicons--musical-note] w-24 h-24 text-base-content/30"></span>
									</div>
								}
							</div>
						</div>
						<!-- Track Details -->
						<div class="flex-1 min-w-0">
							<h1 class="text-4xl md:text-5xl font-bold mb-2 text-base-content">{ track.Name }</h1>
							<!-- Artist, Album, Genre, and other metadata -->
							<div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-3">
								if track.Edges.Artist != nil {
									<a href={ templ.URL(fmt.Sprintf("/library/artist/%d", track.Edges.Artist.ID)) } class="text-xl text-base-content/70 hover:text-primary hover:underline flex items-center gap-2">
										<span class="icon-[heroicons--user-circle] w-5 h-5"></span>
										{ track.Edges.Artist.Name }
									</a>
								}
								if track.Edges.Album != nil {
									<span class="text-lg text-base-content/60 flex items-center gap-2">
										<span class="icon-[heroicons--square-3-stack-3d] w-5 h-5"></span>
										<a href={ templ.URL(fmt.Sprintf("/library/album/%d", track.Edges.Album.ID)) } class="hover:text-secondary hover:underline">
											{ track.Edges.Album.Name }
										</a>
									</span>
								}
								if len(track.Genres) > 0 {
									<span class="badge badge-primary badge-outline">{ track.Genres[0] }</span>
								}
								if track.DurationMs != nil && *track.DurationMs > 0 {
									<span class="badge badge-ghost font-mono">{ formatDuration(*track.DurationMs) }</span>
								}
								if track.Bpm != nil && *track.Bpm > 0 {
									<span class="badge badge-ghost font-mono">{ formatBPM(track.Bpm) }</span>
								}
							</div>
							<!-- External Links -->
							<div class="flex flex-wrap gap-2 mb-4">
								if track.SpotifyID != nil && *track.SpotifyID != "" {
									@components.ExternalLinkBadge("Spotify", fmt.Sprintf("https://open.spotify.com/track/%s", *track.SpotifyID), "icon-[simple-icons--spotify]", "badge-success")
								}
								if track.MusicbrainzID != nil && *track.MusicbrainzID != "" {
									@components.ExternalLinkBadge("MusicBrainz", fmt.Sprintf("https://musicbrainz.org/recording/%s", *track.MusicbrainzID), "icon-[heroicons--globe-alt]", "badge-warning")
								}
							</div>
							// Governing: SPEC-0014 REQ "UI Tag Visual Differentiation"
							<!-- Typed tags (Tag entities); legacy JSON fields as fallback during migration -->
							if len(track.Edges.TagEntities) > 0 {
								<div class="flex flex-wrap gap-1.5 mb-4">
									for _, tv := range components.TagViewsFromEnt(track.Edges.TagEntities) {
										@components.TypedTagBadge(tv)
									}
								</div>
							} else if len(track.Genres) > 0 || len(track.Tags) > 0 || len(track.AiTags) > 0 {
								<div class="flex flex-wrap gap-1.5 mb-4">
									for _, tagInfo := range processTags(track) {
										if tagInfo.IsAITag {
											<span class="badge badge-sm badge-accent gap-1 px-2 py-0.5">
												<span class="icon-[heroicons--sparkles] w-2.5 h-2.5"></span>
												{ tagInfo.Name }
											</span>
										} else if tagInfo.IsGenre {
											<span class="badge badge-sm badge-primary px-2 py-0.5">{ tagInfo.Name }</span>
										} else {
											<span class="badge badge-sm badge-secondary badge-outline px-2 py-0.5">{ tagInfo.Name }</span>
										}
									}
								</div>
							}
							<!-- Popularity -->
							if track.Popularity != nil && *track.Popularity > 0 {
								<div class="flex items-center gap-2">
									<label class="text-sm font-medium text-base-content/60" for="popularity">Popularity</label>
									<progress id="popularity" class="progress progress-primary w-56" value={ fmt.Sprintf("%d", *track.Popularity) } max="100"></progress>
								</div>
							}
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="max-w-7xl mx-auto">
			<!-- Stats Grid -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
				@components.StatCard("Total Listens", components.FormatNumber(stats.TotalListens), "all time", "icon-[heroicons--play-circle]", "text-primary")
				@components.StatCard("First Listen", formatDate(stats.FirstListen), "discovered", "icon-[heroicons--calendar]", "text-secondary")
				@components.StatCard("Last Listen", formatDate(stats.LastListen), "most recent", "icon-[heroicons--clock]", "text-accent")
				if track.DurationMs != nil {
					@components.StatCard("Duration", formatDuration(*track.DurationMs), "", "icon-[heroicons--clock]", "text-info")
				} else {
					@components.StatCard("Duration", "N/A", "", "icon-[heroicons--clock]", "text-info")
				}
			</div>
			<!-- AI Summary Card -->
			@components.AISummaryCard(track.AiSummary, "AI Insights")
		</div>
		<!-- Playlists containing this Track -->
		if len(playlists) > 0 {
			<div class="mb-8">
				<h3 class="text-2xl font-bold mb-6 flex items-center gap-2">
					<span class="icon-[heroicons--queue-list] w-6 h-6"></span>
					In Playlists
				</h3>
				<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
					for _, pl := range playlists {
						@components.PlaylistTile(pl, "Includes this track")
					}
				</div>
			</div>
		}
	}
}

templ ProviderHistoryChart(trackID int, data components.StackedChartData, currentTimeframe string) {
	<div class="card bg-base-100 shadow-xl">
		<div class="card-body">
			<div class="flex items-center justify-between mb-4">
				<h3 class="card-title">
					<span class="icon-[heroicons--chart-bar] w-5 h-5"></span>
					Listens Over Time
				</h3>
				<select
					class="select select-bordered select-sm w-40"
					hx-get={ fmt.Sprintf("/library/track/%d/chart", trackID) }
					hx-target="#provider-history-chart"
					hx-swap="innerHTML"
					name="timeframe"
				>
					<option value="30d" selected?={ currentTimeframe == "30d" }>Last 30 days</option>
					<option value="90d" selected?={ currentTimeframe == "90d" }>Last 90 days</option>
					<option value="6m" selected?={ currentTimeframe == "6m" }>Last 6 months</option>
					<option value="1y" selected?={ currentTimeframe == "1y" }>Last year</option>
					<option value="all" selected?={ currentTimeframe == "all" }>All time</option>
				</select>
			</div>
			<div id="provider-history-chart">
				@ProviderHistoryChartContent(trackID, data)
			</div>
		</div>
	</div>
}

templ ProviderHistoryChartContent(trackID int, data components.StackedChartData) {
	<div class="w-full" style="height: 300px">
		<canvas id={ fmt.Sprintf("track-%d-provider-history", trackID) }></canvas>
	</div>
	@providerHistoryScript(trackID, data)
}

templ providerHistoryScript(trackID int, data components.StackedChartData) {
	<script>
		(function() {
			const ctx = document.getElementById('track-' + {{ trackID }} + '-provider-history');
			if (!ctx) return;

			// Destroy existing chart if any
			const existingChart = Chart.getChart(ctx);
			if (existingChart) {
				existingChart.destroy();
			}

			const chartData = JSON.parse('{{ toJSON(data) }}');

			new Chart(ctx, {
				type: 'bar',
				data: {
					labels: chartData.labels,
					datasets: chartData.datasets.map(ds => ({
						label: ds.label,
						data: ds.data,
						backgroundColor: ds.backgroundColor,
						borderColor: ds.borderColor,
						borderWidth: 1,
						borderRadius: 2
					}))
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					plugins: {
						legend: {
							display: true,
							position: 'bottom',
							labels: {
								color: 'oklch(var(--bc))',
								usePointStyle: true,
								padding: 20
							}
						}
					},
					scales: {
						y: {
							stacked: true,
							beginAtZero: true,
							ticks: {
								color: 'oklch(var(--bc) / 0.7)'
							},
							grid: {
								color: 'oklch(var(--bc) / 0.1)'
							}
						},
						x: {
							stacked: true,
							ticks: {
								color: 'oklch(var(--bc) / 0.7)',
								maxRotation: 45,
								minRotation: 0
							},
							grid: {
								display: false
							}
						}
					}
				}
			});
		})();
	</script>
}

func getArtistImageURL(artist *ent.Artist) string {
	if artist.Edges.Images == nil || len(artist.Edges.Images) == 0 {
		return ""
	}
	return fmt.Sprintf("/library/artist/%d.png", artist.ID)
}

func buildTrackMetadataRows(track *ent.Track) []components.MetadataRow {
	rows := []components.MetadataRow{
		{Label: "Track Number", Value: formatIntPtr(track.TrackNumber)},
		{Label: "Disc Number", Value: formatIntPtr(track.DiscNumber)},
		{Label: "Duration", Value: formatDurationPtr(track.DurationMs)},
		{Label: "ISRC", Value: getStringPtrOrDefault(track.Isrc, "N/A")},
		{Label: "Musical Key", Value: getStringPtrOrDefault(track.MusicalKey, "N/A")},
		{Label: "BPM", Value: formatBPM(track.Bpm)},
	}

	if track.MusicbrainzID != nil && *track.MusicbrainzID != "" {
		rows = append(rows, components.MetadataRow{
			Label: "MusicBrainz ID",
			Value: *track.MusicbrainzID,
			Link:  fmt.Sprintf("https://musicbrainz.org/recording/%s", *track.MusicbrainzID),
		})
	} else {
		rows = append(rows, components.MetadataRow{Label: "MusicBrainz ID", Value: "N/A"})
	}

	if track.SpotifyID != nil && *track.SpotifyID != "" {
		rows = append(rows, components.MetadataRow{
			Label: "Spotify ID",
			Value: *track.SpotifyID,
			Link:  fmt.Sprintf("https://open.spotify.com/track/%s", *track.SpotifyID),
		})
	} else {
		rows = append(rows, components.MetadataRow{Label: "Spotify ID", Value: "N/A"})
	}

	if track.NavidromeID != nil && *track.NavidromeID != "" {
		rows = append(rows, components.MetadataRow{Label: "Navidrome ID", Value: *track.NavidromeID})
	}

	rows = append(rows, components.MetadataRow{Label: "Enriched", Value: formatEnrichedTime(track.LastEnrichedAt)})
	rows = append(rows, components.MetadataRow{Label: "AI Enriched", Value: formatAiEnrichedTime(track.LastAiEnrichedAt)})
	rows = append(rows, components.MetadataRow{Label: "Created", Value: formatDate(track.CreatedAt)})
	rows = append(rows, components.MetadataRow{Label: "Updated", Value: formatDate(track.UpdatedAt)})

	return rows
}

func formatIntPtr(i *int) string {
	if i == nil {
		return "N/A"
	}
	return components.FormatNumber(*i)
}

func formatDurationPtr(ms *int) string {
	if ms == nil {
		return "N/A"
	}
	return formatDuration(*ms)
}
