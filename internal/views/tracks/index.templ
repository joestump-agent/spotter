package tracks

import (
	"fmt"
	"net/url"
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
)

func buildTrackPaginationURL(page int, artistFilter, sortCol, sortDir string) string {
	u := fmt.Sprintf("/library/tracks?page=%d", page)
	if artistFilter != "" {
		u += "&artist=" + url.QueryEscape(artistFilter)
	}
	if sortCol != "" {
		u += "&sort=" + sortCol + "&dir=" + sortDir
	}
	return u
}

func buildTrackSortBaseURL(currentPage int, artistFilter string) string {
	u := fmt.Sprintf("/library/tracks?page=%d", currentPage)
	if artistFilter != "" {
		u += "&artist=" + url.QueryEscape(artistFilter)
	}
	return u
}

func toTrackRows(tracks []*ent.Track) []components.TrackTableRow {
	rows := make([]components.TrackTableRow, len(tracks))
	for i, t := range tracks {
		rows[i] = components.TrackTableRow{
			Track: t,
		}
	}
	return rows
}

templ Index(tracks []*ent.Track, currentPage int, totalPages int, cfg *config.Config, artistFilter, sortCol, sortDir string) {
	@layouts.Dashboard("Tracks | Spotter", cfg, "/library/tracks") {
		<div class="max-w-7xl mx-auto">
			if len(tracks) == 0 {
				<div class="card bg-base-200">
					<div class="card-body items-center text-center">
						<span class="icon-[heroicons--musical-note] w-16 h-16 text-base-content/30"></span>
						if artistFilter != "" {
							<h3 class="card-title">No tracks found for this artist</h3>
							<p class="text-base-content/60">Try clearing the filter to see all tracks.</p>
							<a href="/library/tracks" class="btn btn-primary btn-sm mt-4">Clear Filter</a>
						} else {
							<h3 class="card-title">No tracks found</h3>
							<p class="text-base-content/60">Tracks will appear here once your music catalog is enriched.</p>
						}
					</div>
				</div>
			} else {
				<div class="card bg-base-100 shadow-xl">
					<div class="card-body">
						<div class="flex items-center justify-between mb-4">
							<div>
								<h3 class="card-title">
									<span class="icon-[heroicons--musical-note] w-5 h-5"></span>
									Tracks
								</h3>
								if artistFilter != "" {
									<p class="text-base-content/60 text-sm mt-1">
										Filtered by artist: <span class="font-medium text-primary">{ artistFilter }</span>
										<a href="/library/tracks" class="ml-2 link link-primary text-xs">Clear</a>
									</p>
								} else {
									<p class="text-base-content/60 text-sm mt-1">All tracks from your enriched music catalog</p>
								}
							</div>
							<div class="flex items-center gap-2">
								@components.TrackTableToolbar(components.TrackTableToolbarConfig{
									TableID:           "tracks-table",
									ShowArtworkToggle: true,
									ArtworkDefault:    true,
									ColumnOptions: []components.ColumnOption{
										{Value: "col-track", Label: "Track", DefaultVisible: true},
										{Value: "col-artist", Label: "Artist", DefaultVisible: true},
										{Value: "col-album", Label: "Album", DefaultVisible: true},
										{Value: "col-duration", Label: "Duration", DefaultVisible: true},
										{Value: "col-popularity", Label: "Popularity", DefaultVisible: true},
										{Value: "col-plays", Label: "Plays", DefaultVisible: false},
									},
								})
							</div>
						</div>
						@components.TrackTable("tracks-table", toTrackRows(tracks), []string{"track", "artist", "album", "duration", "popularity"}, nil, components.SortConfig{
							Column:    sortCol,
							Direction: sortDir,
							BaseURL:   buildTrackSortBaseURL(currentPage, artistFilter),
						})
					</div>
				</div>
				if totalPages > 1 {
					<div class="flex justify-center mt-8">
						<div class="join">
							if currentPage > 1 {
								<a href={ templ.URL(buildTrackPaginationURL(currentPage-1, artistFilter, sortCol, sortDir)) } class="join-item btn btn-sm">«</a>
							} else {
								<button class="join-item btn btn-sm btn-disabled" disabled>«</button>
							}
							for i := 1; i <= totalPages; i++ {
								if i == currentPage {
									<button class="join-item btn btn-sm btn-active">{ fmt.Sprintf("%d", i) }</button>
								} else if i == 1 || i == totalPages || (i >= currentPage-2 && i <= currentPage+2) {
									<a href={ templ.URL(buildTrackPaginationURL(i, artistFilter, sortCol, sortDir)) } class="join-item btn btn-sm">{ fmt.Sprintf("%d", i) }</a>
								} else if i == currentPage-3 || i == currentPage+3 {
									<button class="join-item btn btn-sm btn-disabled" disabled>...</button>
								}
							}
							if currentPage < totalPages {
								<a href={ templ.URL(buildTrackPaginationURL(currentPage+1, artistFilter, sortCol, sortDir)) } class="join-item btn btn-sm">»</a>
							} else {
								<button class="join-item btn btn-sm btn-disabled" disabled>»</button>
							}
						</div>
					</div>
				}
			}
		</div>
	}
}
