package auth

import "spotter/internal/views/layouts"

templ Login(navidromeURL string) {
	@layouts.Base("Login | Spotter") {
		<div class="hero min-h-screen bg-base-200">
			<div class="hero-content flex-col">
				<div class="card w-full max-w-lg shadow-2xl bg-base-100">
					<div class="card-body">
						<!-- Logo -->
						<div class="flex items-center justify-center gap-4 mb-6">
							<div class="relative">
								<span class="icon-[heroicons--musical-note] w-12 h-12 text-primary"></span>
								<span class="absolute inset-0 icon-[heroicons--musical-note] w-12 h-12 text-primary opacity-30 blur-sm"></span>
							</div>
							<h1 class="text-4xl font-bold text-primary tracking-wide">Spotter</h1>
						</div>

						<form class="space-y-4" hx-post="/login" hx-target="body">
							<div class="form-control">
								<label class="label" for="username">
									<span class="label-text font-medium">Username</span>
								</label>
								<input
									id="username"
									name="username"
									type="text"
									placeholder="Enter your username"
									autocomplete="username"
									required
									class="input input-bordered w-full"
									autofocus
								/>
							</div>

							<div class="form-control">
								<label class="label" for="password">
									<span class="label-text font-medium">Password</span>
								</label>
								<input
									id="password"
									name="password"
									type="password"
									placeholder="Enter your password"
									autocomplete="current-password"
									required
									class="input input-bordered w-full"
								/>
							</div>

							<div class="form-control mt-6">
								<button type="submit" class="btn btn-primary w-full gap-2">
									<span class="icon-[heroicons--arrow-right-on-rectangle] w-5 h-5"></span>
									Log in with Navidrome
								</button>
							</div>
						</form>

						<div class="divider"></div>

						<div class="alert alert-info">
							<span class="icon-[heroicons--information-circle] w-5 h-5 flex-shrink-0 self-start mt-0.5"></span>
							<div class="text-sm">
								<p class="font-medium">Spotter uses your Navidrome credentials</p>
								<p class="text-xs mt-1">Use your Navidrome username and password to log in. This Spotter instance is connected to:</p>
								<p class="text-xs mt-2 font-mono bg-info-content/10 px-2 py-1 rounded break-all">{ navidromeURL }</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	}
}
