package preferences

import (
	"fmt"
	"spotter/ent"
	"spotter/ent/syncevent"
	"spotter/internal/config"
	"spotter/internal/types"
	"spotter/internal/views/layouts"
	"time"
)

func formatEventTime(t time.Time) string {
	return t.Local().Format("Jan 02, 2006 at 3:04 PM")
}

func formatEventTimeISO(t time.Time) string {
	return t.UTC().Format(time.RFC3339)
}

func formatEventType(et syncevent.EventType) string {
	switch et {
	case syncevent.EventTypeSyncStarted:
		return "Sync Started"
	case syncevent.EventTypeTrackAdded:
		return "Track Added"
	case syncevent.EventTypeTrackSkipped:
		return "Track Skipped"
	case syncevent.EventTypePlaylistAdded:
		return "Playlist Added"
	case syncevent.EventTypePlaylistSkipped:
		return "Playlist Skipped"
	case syncevent.EventTypeSyncCompleted:
		return "Sync Completed"
	case syncevent.EventTypeSyncFailed:
		return "Sync Failed"
	// Playlist sync events (to Navidrome)
	case syncevent.EventTypePlaylistSyncStarted:
		return "Playlist Sync Started"
	case syncevent.EventTypePlaylistSyncCompleted:
		return "Playlist Sync Completed"
	case syncevent.EventTypePlaylistSyncFailed:
		return "Playlist Sync Failed"
	case syncevent.EventTypePlaylistSyncRemoved:
		return "Playlist Sync Removed"
	case syncevent.EventTypeMetadataStarted:
		return "Metadata Started"
	case syncevent.EventTypeMetadataCompleted:
		return "Metadata Completed"
	case syncevent.EventTypeMetadataFailed:
		return "Metadata Failed"
	case syncevent.EventTypeArtistEnriched:
		return "Artist Enriched"
	case syncevent.EventTypeAlbumEnriched:
		return "Album Enriched"
	case syncevent.EventTypeTrackEnriched:
		return "Track Enriched"
	case syncevent.EventTypeImageDownloaded:
		return "Image Downloaded"
	case syncevent.EventTypeCatalogBuilt:
		return "Catalog Built"
	case syncevent.EventTypeCleanupStarted:
		return "Cleanup Started"
	case syncevent.EventTypeCleanupCompleted:
		return "Cleanup Completed"
	case syncevent.EventTypeDataReset:
		return "Data Reset"
	default:
		// Handle dynamic lidarr events
		if len(string(et)) > 7 && string(et)[:7] == "lidarr_" {
			return formatLidarrEvent(string(et))
		}
		return string(et)
	}
}

func formatLidarrEvent(s string) string {
	switch s {
	case "lidarr_artist_matched":
		return "Lidarr Artist Matched"
	case "lidarr_album_matched":
		return "Lidarr Album Matched"
	case "lidarr_track_matched":
		return "Lidarr Track Matched"
	case "lidarr_import_grabbed":
		return "Lidarr Grabbed"
	case "lidarr_import_imported":
		return "Lidarr Imported"
	default:
		return s
	}
}

func eventTypeClass(et syncevent.EventType) string {
	switch et {
	case syncevent.EventTypeSyncStarted, syncevent.EventTypeMetadataStarted, syncevent.EventTypeCleanupStarted,
		syncevent.EventTypePlaylistSyncStarted:
		return "badge-info"
	case syncevent.EventTypeTrackAdded, syncevent.EventTypePlaylistAdded, syncevent.EventTypeSyncCompleted,
		syncevent.EventTypeMetadataCompleted, syncevent.EventTypeCleanupCompleted,
		syncevent.EventTypeArtistEnriched, syncevent.EventTypeAlbumEnriched, syncevent.EventTypeTrackEnriched,
		syncevent.EventTypeImageDownloaded, syncevent.EventTypeCatalogBuilt,
		syncevent.EventTypePlaylistSyncCompleted:
		return "badge-success"
	case syncevent.EventTypeTrackSkipped, syncevent.EventTypePlaylistSkipped, syncevent.EventTypeDataReset,
		syncevent.EventTypePlaylistSyncRemoved:
		return "badge-warning"
	case syncevent.EventTypeSyncFailed, syncevent.EventTypeMetadataFailed,
		syncevent.EventTypePlaylistSyncFailed:
		return "badge-error"
	default:
		if len(string(et)) > 7 && string(et)[:7] == "lidarr_" {
			return "badge-success"
		}
		return "badge-ghost"
	}
}

func formatProvider(provider string) string {
	switch provider {
	case "spotify":
		return "Spotify"
	case "navidrome":
		return "Navidrome"
	case "lastfm":
		return "Last.fm"
	case "metadata":
		return "Metadata"
	case "system":
		return "System"
	case "lidarr":
		return "Lidarr"
	default:
		return provider
	}
}

templ providerBadge(provider string) {
	if provider == "spotify" {
		<div class="badge badge-success gap-2">
			<span class="icon-[simple-icons--spotify] w-3 h-3"></span>
			Spotify
		</div>
	} else if provider == "navidrome" {
		<div class="badge badge-primary gap-2">
			<span class="icon-[heroicons--musical-note] w-3 h-3"></span>
			Navidrome
		</div>
	} else if provider == "lastfm" {
		<div class="badge badge-error gap-2">
			<span class="icon-[simple-icons--lastdotfm] w-3 h-3"></span>
			Last.fm
		</div>
	} else if provider == "metadata" {
		<div class="badge badge-secondary gap-2">
			<span class="icon-[heroicons--sparkles] w-3 h-3"></span>
			Metadata
		</div>
	} else if provider == "system" {
		<div class="badge badge-neutral gap-2">
			<span class="icon-[heroicons--cog-6-tooth] w-3 h-3"></span>
			System
		</div>
	} else if provider == "lidarr" {
		<div class="badge badge-info gap-2">
			<span class="icon-[heroicons--server] w-3 h-3"></span>
			Lidarr
		</div>
	} else {
		<div class="badge badge-ghost">{ provider }</div>
	}
}

func formatLastRun(t *time.Time) string {
	if t == nil {
		return "Never"
	}
	return t.Local().Format("Jan 02, 2006 at 3:04 PM")
}

func formatLastRunISO(t *time.Time) string {
	if t == nil {
		return ""
	}
	return t.UTC().Format(time.RFC3339)
}

templ Tasks(user *ent.User, tasks []types.Task, events []*ent.SyncEvent, selectedProvider string, selectedEventType string, providers []string, eventTypes []syncevent.EventType, cfg *config.Config) {
	@layouts.Dashboard("Tasks | Spotter", cfg, "/preferences/tasks") {
		<div class="max-w-6xl mx-auto">
			<div class="mb-8">
				<h2 class="text-3xl font-bold">Tasks</h2>
				<p class="text-base-content/60 mt-2">Run background tasks and view task history</p>
			</div>
			<div class="space-y-6">
				<!-- Tasks Table Card -->
				<div class="card bg-base-100 shadow-xl">
					<div class="card-body">
						<h3 class="card-title">
							<span class="icon-[heroicons--play-circle] w-6 h-6"></span>
							Background Tasks
						</h3>
						<p class="text-base-content/60 text-sm mb-4">
							Run tasks manually or view when they last ran automatically.
						</p>
						<div class="overflow-x-auto">
							<table class="table">
								<thead>
									<tr>
										<th>Task</th>
										<th>Last Run</th>
										<th class="text-right">Action</th>
									</tr>
								</thead>
								<tbody>
									for _, task := range tasks {
										<tr>
											<td>
												<div class="font-medium">{ task.Name }</div>
												<div class="text-sm text-base-content/60">{ task.Description }</div>
											</td>
											<td class="whitespace-nowrap">
												if task.LastRanAt != nil {
													<span class="timeago text-sm" datetime={ formatLastRunISO(task.LastRanAt) } title={ formatLastRun(task.LastRanAt) }>
														{ formatLastRun(task.LastRanAt) }
													</span>
												} else {
													<span class="text-base-content/40 text-sm">Never</span>
												}
											</td>
											<td class="text-right">
												@taskButton(task.ID, task.Name)
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				</div>
				<!-- Event History Card -->
				<div class="card bg-base-100 shadow-xl">
					<div class="card-body">
						<div class="flex flex-wrap items-center justify-between gap-4">
							<h3 class="card-title">
								<span class="icon-[heroicons--clock] w-6 h-6"></span>
								History
								<span class="badge badge-neutral">{ lenStr(events) } events</span>
							</h3>
							<!-- Filters -->
							<form method="GET" action="/preferences/tasks" class="flex flex-wrap items-center gap-2">
								<select name="provider" class="select select-bordered select-sm" onchange="this.form.submit()">
									<option value="">All Sources</option>
									for _, p := range providers {
										<option value={ p } selected?={ selectedProvider == p }>{ formatProvider(p) }</option>
									}
								</select>
								<select name="event_type" class="select select-bordered select-sm" onchange="this.form.submit()">
									<option value="">All Events</option>
									for _, et := range eventTypes {
										<option value={ string(et) } selected?={ selectedEventType == string(et) }>{ formatEventType(et) }</option>
									}
								</select>
								if selectedProvider != "" || selectedEventType != "" {
									<a href="/preferences/tasks" class="btn btn-ghost btn-sm">
										<span class="icon-[heroicons--x-mark] w-4 h-4"></span>
										Clear
									</a>
								}
							</form>
						</div>
						if len(events) == 0 {
							<div class="text-center py-12">
								<span class="icon-[heroicons--inbox] w-16 h-16 text-base-content/30 mx-auto"></span>
								<p class="text-base-content/60 mt-4">No events found</p>
								if selectedProvider != "" || selectedEventType != "" {
									<p class="text-sm text-base-content/40 mt-2">Try adjusting your filters</p>
								}
							</div>
						} else {
							<div class="overflow-x-auto mt-4">
								<table class="table table-zebra">
									<thead>
										<tr>
											<th>Time</th>
											<th>Source</th>
											<th>Type</th>
											<th>Message</th>
										</tr>
									</thead>
									<tbody>
										for _, event := range events {
											<tr>
												<td class="whitespace-nowrap">
													<span class="timeago text-sm" datetime={ formatEventTimeISO(event.CreatedAt) } title={ formatEventTime(event.CreatedAt) }>
														{ formatEventTime(event.CreatedAt) }
													</span>
												</td>
												<td>
													@providerBadge(event.Provider)
												</td>
												<td>
													<span class={ "badge badge-sm h-6 px-3", eventTypeClass(event.EventType) }>
														{ formatEventType(event.EventType) }
													</span>
												</td>
												<td class="max-w-md">
													<span class="text-sm">{ event.Message }</span>
												</td>
											</tr>
										}
									</tbody>
								</table>
							</div>
						}
					</div>
				</div>
			</div>
		</div>
		<!-- Reset Data Confirmation Modal -->
		<dialog id="reset-confirm-modal" class="modal">
			<div class="modal-box">
				<h3 class="font-bold text-lg text-error">
					<span class="icon-[heroicons--exclamation-triangle] w-6 h-6 inline-block mr-2"></span>
					Confirm Data Reset
				</h3>
				<p class="py-4">
					This will <strong>permanently delete</strong> all your:
				</p>
				<ul class="list-disc list-inside mb-4 text-base-content/80">
					<li>Listening history</li>
					<li>Playlists</li>
					<li>Artist catalog and metadata</li>
					<li>Album catalog and metadata</li>
					<li>Track metadata</li>
					<li>Downloaded images and artwork</li>
					<li>All enriched data (MusicBrainz IDs, Spotify IDs, bios, etc.)</li>
				</ul>
				<p class="text-sm text-base-content/60">
					After deletion, data will be re-synced from your connected providers. This action cannot be undone.
				</p>
				<div class="modal-action">
					<form method="dialog">
						<button class="btn btn-ghost">Cancel</button>
					</form>
					<button
						class="btn btn-error"
						hx-post="/preferences/tasks/reset"
						hx-swap="none"
						onclick="document.getElementById('reset-confirm-modal').close()"
					>
						<span class="icon-[heroicons--trash] w-4 h-4"></span>
						Yes, Reset All Data
					</button>
				</div>
			</div>
			<form method="dialog" class="modal-backdrop">
				<button>close</button>
			</form>
		</dialog>
		<!-- Timeago script -->
		<script>
			(function() {
				if (typeof timeago !== 'undefined') {
					const nodes = document.querySelectorAll('.timeago');
					if (nodes.length > 0) {
						timeago.render(nodes);
					}
				}
			})();
		</script>
	}
}

templ taskButton(taskID string, taskName string) {
	if taskID == "reset-data" {
		<button
			class="btn btn-error btn-sm w-24 gap-2"
			onclick="document.getElementById('reset-confirm-modal').showModal()"
		>
			<span class="icon-[heroicons--arrow-path] w-4 h-4"></span>
			<span>Reset</span>
		</button>
	} else if taskID == "sync-listens" {
		<button
			class="btn btn-primary btn-sm w-24 gap-2 relative"
			hx-post="/preferences/tasks/sync-listens"
			hx-swap="none"
		>
			<span class="icon-[heroicons--play] w-4 h-4 htmx-indicator-hide"></span>
			<span class="htmx-indicator-hide">Run</span>
			<span class="loading loading-spinner loading-xs htmx-indicator absolute"></span>
		</button>
	} else if taskID == "sync-playlists" {
		<button
			class="btn btn-primary btn-sm w-24 gap-2 relative"
			hx-post="/preferences/tasks/sync-playlists"
			hx-swap="none"
		>
			<span class="icon-[heroicons--play] w-4 h-4 htmx-indicator-hide"></span>
			<span class="htmx-indicator-hide">Run</span>
			<span class="loading loading-spinner loading-xs htmx-indicator absolute"></span>
		</button>
	} else if taskID == "enrich-metadata" {
		<button
			class="btn btn-primary btn-sm w-24 gap-2 relative"
			hx-post="/preferences/tasks/enrich-metadata"
			hx-swap="none"
		>
			<span class="icon-[heroicons--play] w-4 h-4 htmx-indicator-hide"></span>
			<span class="htmx-indicator-hide">Run</span>
			<span class="loading loading-spinner loading-xs htmx-indicator absolute"></span>
		</button>
	} else if taskID == "sync-artist-images" {
		<button
			class="btn btn-primary btn-sm w-24 gap-2 relative"
			hx-post="/preferences/tasks/sync-artist-images"
			hx-swap="none"
		>
			<span class="icon-[heroicons--play] w-4 h-4 htmx-indicator-hide"></span>
			<span class="htmx-indicator-hide">Run</span>
			<span class="loading loading-spinner loading-xs htmx-indicator absolute"></span>
		</button>
	} else if taskID == "sync-album-images" {
		<button
			class="btn btn-primary btn-sm w-24 gap-2 relative"
			hx-post="/preferences/tasks/sync-album-images"
			hx-swap="none"
		>
			<span class="icon-[heroicons--play] w-4 h-4 htmx-indicator-hide"></span>
			<span class="htmx-indicator-hide">Run</span>
			<span class="loading loading-spinner loading-xs htmx-indicator absolute"></span>
		</button>
	} else if taskID == "cleanup" {
		<button
			class="btn btn-primary btn-sm w-24 gap-2 relative"
			hx-post="/preferences/tasks/cleanup"
			hx-swap="none"
		>
			<span class="icon-[heroicons--play] w-4 h-4 htmx-indicator-hide"></span>
			<span class="htmx-indicator-hide">Run</span>
			<span class="loading loading-spinner loading-xs htmx-indicator absolute"></span>
		</button>
	} else {
		<button class="btn btn-primary btn-sm w-24 gap-2" disabled>
			<span class="icon-[heroicons--play] w-4 h-4"></span>
			<span>Run</span>
		</button>
	}
}

func lenStr(events []*ent.SyncEvent) string {
	return fmt.Sprintf("%d", len(events))
}
