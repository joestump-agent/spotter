	<dialog id="lastfm-disconnect-modal" class="modal">
		<div class="modal-box">
			<h3 class="font-bold text-lg">Disconnect from Last.fm</h3>
			<p class="py-4">Are you sure you want to disconnect your Last.fm account? Your synced data will remain, but no new data will be imported.</p>
			<div class="modal-action">
				<form method="dialog">
					<button class="btn btn-ghost">Cancel</button>
				</form>
				<button
					class="btn btn-error"
					hx-post="/preferences/lastfm/disconnect"
					hx-target="body"
