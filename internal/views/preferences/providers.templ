package preferences

import (
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
	"time"
)

templ Providers(user *ent.User, spotifyAuth *ent.SpotifyAuth, lastfmAuth *ent.LastFMAuth, listenbrainzAuth *ent.ListenBrainzAuth, navidromeAuth *ent.NavidromeAuth, cfg *config.Config, errorMsg string) {
	@layouts.Dashboard("Providers | Spotter", cfg, "/preferences/providers") {
		<div class="max-w-7xl mx-auto">
			<div class="mb-8">
				<h2 class="text-3xl font-bold">Providers</h2>
				<p class="text-base-content/60 mt-2">Manage your connected music services</p>
			</div>
			if errorMsg != "" {
				<div class="alert alert-error shadow-sm mb-6">
					<span class="icon-[heroicons--exclamation-triangle] w-5 h-5"></span>
					<span>{ errorMsg }</span>
				</div>
			}
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				<!-- Navidrome -->
				@components.ProviderTile(components.ProviderProps{
					Name:           "Navidrome",
					Description:    "Your primary music server. Authentication is managed through your login credentials.",
					IconClass:      "icon-[heroicons--musical-note]",
					IconColorStyle: "#4285F4",
					ButtonStyle:    "background-color: #4285F4; border-color: #4285F4; color: white;",
					IsConnected:    navidromeAuth != nil,
					DisplayName: func() string {
						if navidromeAuth != nil {
							return user.Username
						} else {
							return ""
						}
					}(),
					LastSyncedAt: func() time.Time {
						if navidromeAuth != nil {
							return navidromeAuth.LastSyncedAt
						} else {
							return time.Time{}
						}
					}(),
					ConnectURL:             "", // Navidrome doesn't have a connect URL from here
					SyncURL:                "/preferences/navidrome/sync",
					ModalIDRebuild:         "navidrome-rebuild-modal",
					ModalIDDisconnect:      "navidrome-logout-modal",
					RebuildModalContent:    NavidromeRebuildModal(),
					DisconnectModalContent: NavidromeLogoutModal(),
				})
				<!-- Spotify -->
				@components.ProviderTile(components.ProviderProps{
					Name:           "Spotify",
					Description:    "Connect your Spotify account to import listening history and get better recommendations.",
					IconClass:      "icon-[simple-icons--spotify]",
					IconColorClass: "text-success",
					ButtonClass:    "btn-success",
					IsConnected:    spotifyAuth != nil,
					DisplayName: func() string {
						if spotifyAuth != nil && spotifyAuth.DisplayName != "" {
							return spotifyAuth.DisplayName
						} else if spotifyAuth != nil {
							return "Connected"
						}
						return ""
					}(),
					LastSyncedAt: func() time.Time {
						if spotifyAuth != nil {
							return spotifyAuth.LastSyncedAt
						} else {
							return time.Time{}
						}
					}(),
					ConnectURL:             "/auth/spotify/login",
					SyncURL:                "/preferences/spotify/sync",
					ModalIDRebuild:         "spotify-rebuild-modal",
					ModalIDDisconnect:      "spotify-disconnect-modal",
					RebuildModalContent:    SpotifyRebuildModal(),
					DisconnectModalContent: SpotifyDisconnectModal(),
				})
				<!-- Last.fm -->
				@components.ProviderTile(components.ProviderProps{
					Name:           "Last.fm",
					Description:    "Connect your Last.fm account to scrobble tracks and improve recommendations.",
					IconClass:      "icon-[simple-icons--lastdotfm]",
					IconColorClass: "text-error",
					ButtonClass:    "btn-error",
					IsConnected:    lastfmAuth != nil,
					DisplayName: func() string {
						if lastfmAuth != nil {
							return lastfmAuth.Username
						} else {
							return ""
						}
					}(),
					LastSyncedAt: func() time.Time {
						if lastfmAuth != nil {
							return lastfmAuth.LastSyncedAt
						} else {
							return time.Time{}
						}
					}(),
					ConnectURL:             "/auth/lastfm/login",
					SyncURL:                "/preferences/lastfm/sync",
					ModalIDRebuild:         "lastfm-rebuild-modal",
					ModalIDDisconnect:      "lastfm-disconnect-modal",
					RebuildModalContent:    LastFMRebuildModal(),
					DisconnectModalContent: LastFMDisconnectModal(),
				})
				<!-- ListenBrainz -->
				<!-- Governing: SPEC music-provider-integration REQ "ListenBrainz Provider" (REQ-PROV-046) -->
				@components.ProviderTile(components.ProviderProps{
					Name:           "ListenBrainz",
					Description:    "Connect your ListenBrainz account with your user token to sync your listen history.",
					IconClass:      "icon-[simple-icons--listenbrainz]",
					IconColorStyle: "#EB743B",
					ButtonStyle:    "background-color: #EB743B; border-color: #EB743B; color: white;",
					IsConnected:    listenbrainzAuth != nil,
					DisplayName: func() string {
						if listenbrainzAuth != nil {
							return listenbrainzAuth.Username
						} else {
							return ""
						}
					}(),
					LastSyncedAt: func() time.Time {
						if listenbrainzAuth != nil {
							return listenbrainzAuth.LastSyncedAt
						} else {
							return time.Time{}
						}
					}(),
					ConnectURL:             "/auth/listenbrainz/connect",
					SyncURL:                "/preferences/listenbrainz/sync",
					ModalIDRebuild:         "listenbrainz-rebuild-modal",
					ModalIDDisconnect:      "listenbrainz-disconnect-modal",
					RebuildModalContent:    ListenBrainzRebuildModal(),
					DisconnectModalContent: ListenBrainzDisconnectModal(),
					ExtraContent: func() templ.Component {
						if listenbrainzAuth != nil {
							return ListenBrainzSubmitToggle(listenbrainzAuth.SubmitListens)
						}
						return nil
					}(),
				})
			</div>
		</div>
		<!-- Timeago script -->
		<script>
			// Initialize timeago for all elements with the timeago class
			(function() {
				if (typeof timeago !== 'undefined') {
					const nodes = document.querySelectorAll('.timeago');
					if (nodes.length > 0) {
						timeago.render(nodes);
					}
				}
			})();

			// Close dropdowns when clicking outside
			document.addEventListener('click', function(e) {
				if (!e.target.closest('details.dropdown')) {
					document.querySelectorAll('details.dropdown[open]').forEach(function(details) {
						details.removeAttribute('open');
					});
				}
			});
		</script>
	}
}

templ NavidromeLogoutModal() {
	<dialog id="navidrome-logout-modal" class="modal">
		<div class="modal-box">
			<h3 class="font-bold text-lg">Log Out from Navidrome</h3>
			<p class="py-4">Are you sure you want to log out? You will need to log in again to access Spotter.</p>
			<div class="modal-action">
				<form method="dialog">
					<button class="btn btn-ghost">Cancel</button>
				</form>
				<!-- Governing: ADR-0028 — logout is state-changing, so it must POST (SameSite=Lax does not cover GET navigations) -->
				<form method="POST" action="/logout">
					<button type="submit" class="btn btn-error">
						<span class="icon-[heroicons--arrow-right-on-rectangle] w-5 h-5"></span>
						Log Out
					</button>
				</form>
			</div>
		</div>
		<form method="dialog" class="modal-backdrop">
			<button>close</button>
		</form>
	</dialog>
}

templ NavidromeRebuildModal() {
	<dialog id="navidrome-rebuild-modal" class="modal">
		<div class="modal-box">
			<h3 class="font-bold text-lg flex items-center gap-2">
				<span class="icon-[heroicons--exclamation-triangle] w-6 h-6 text-warning"></span>
				Rebuild Navidrome Data
			</h3>
			<p class="py-4">This will <strong>delete all listening history and playlists</strong> from Navidrome and re-sync everything from scratch. This action cannot be undone.</p>
			<div class="modal-action">
				<form method="dialog">
					<button class="btn btn-ghost">Cancel</button>
				</form>
				<button
					class="btn btn-warning"
					hx-post="/preferences/navidrome/rebuild"
					hx-target="#toasts"
					hx-swap="beforeend"
					onclick="document.getElementById('navidrome-rebuild-modal').close()"
				>
					<span class="icon-[heroicons--trash] w-5 h-5"></span>
					Delete &amp; Rebuild
				</button>
			</div>
		</div>
		<form method="dialog" class="modal-backdrop">
			<button>close</button>
		</form>
	</dialog>
}

templ SpotifyDisconnectModal() {
	<dialog id="spotify-disconnect-modal" class="modal">
		<div class="modal-box">
			<h3 class="font-bold text-lg">Disconnect from Spotify</h3>
			<p class="py-4">Are you sure you want to disconnect your Spotify account? Your synced data will remain, but no new data will be imported.</p>
			<div class="modal-action">
				<form method="dialog">
					<button class="btn btn-ghost">Cancel</button>
				</form>
				<button
					class="btn btn-error"
					hx-post="/preferences/spotify/disconnect"
					hx-target="body"
					onclick="document.getElementById('spotify-disconnect-modal').close()"
				>
					<span class="icon-[heroicons--x-mark] w-5 h-5"></span>
					Disconnect
				</button>
			</div>
		</div>
		<form method="dialog" class="modal-backdrop">
			<button>close</button>
		</form>
	</dialog>
}

