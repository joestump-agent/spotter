package playlists

import (
	"fmt"
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
	"time"
)

func showFormatDate(t time.Time) string {
	if t.IsZero() {
		return "N/A"
	}
	return t.Local().Format("Jan 2 '06")
}

func showGetOrDefault(value, defaultVal string) string {
	if value == "" {
		return defaultVal
	}
	return value
}

templ Show(playlist *ent.Playlist, tracks []components.TrackTableRow, cfg *config.Config) {
	@layouts.Dashboard(fmt.Sprintf("%s | Playlists | Spotter", playlist.Name), cfg, "/playlists") {
		<!-- Hero Section -->
		<div class="relative -mx-6 lg:-mx-8 -mt-6 lg:-mt-8 mb-8">
			<!-- Background Blur -->
			if playlist.ImageURL != "" {
				<div class="absolute inset-0 h-80 overflow-hidden">
					<img src={ playlist.ImageURL } alt="" class="w-full h-full object-cover opacity-20 blur-2xl scale-110"/>
					<div class="absolute inset-0 bg-gradient-to-b from-transparent via-base-200/80 to-base-200"></div>
				</div>
			} else {
				<div class="absolute inset-0 h-80 bg-gradient-to-b from-info/20 to-base-200"></div>
			}
			<!-- Playlist Info -->
			<div class="relative pt-8 px-6 lg:px-8 pb-8">
				<div class="max-w-7xl mx-auto">
					<div class="flex flex-col md:flex-row items-start gap-8">
						<!-- Playlist Cover -->
						<div class="flex-shrink-0">
							<div class="w-56 h-56 md:w-64 md:h-64 rounded-xl shadow-2xl ring ring-base-100 ring-offset-base-200 ring-offset-2 overflow-hidden">
								if playlist.ImageURL != "" {
									<img src={ playlist.ImageURL } alt={ playlist.Name } class="w-full h-full object-cover"/>
								} else {
									<div class="bg-base-300 w-full h-full flex items-center justify-center">
										<span class="icon-[heroicons--queue-list] w-24 h-24 text-base-content/30"></span>
									</div>
								}
							</div>
						</div>
						<!-- Playlist Details -->
						<div class="flex-1 min-w-0">
							<div class="flex items-center gap-3 mb-2">
								<span class="badge badge-outline badge-lg">Playlist</span>
								@providerBadge(playlist.Source)
							</div>
							<h1 class="text-4xl md:text-5xl font-bold mb-2 text-base-content">{ playlist.Name }</h1>
							if playlist.Description != "" {
								<p class="text-base-content/60 mb-4 max-w-2xl">{ playlist.Description }</p>
							}
							<!-- Quick Stats -->
							<div class="flex flex-wrap gap-4 mb-4">
								<div class="flex items-center gap-2 text-base-content/70">
									<span class="icon-[heroicons--musical-note] w-5 h-5"></span>
									<span class="font-semibold">{ formatNumber(playlist.TrackCount) }</span> tracks
								</div>
								<div class="flex items-center gap-2 text-base-content/70">
									<span class="icon-[heroicons--user-group] w-5 h-5"></span>
									<span class="font-semibold">{ formatNumber(playlist.UniqueArtists) }</span> artists
								</div>
								<div class="flex items-center gap-2 text-base-content/70">
									<span class="icon-[heroicons--square-3-stack-3d] w-5 h-5"></span>
									<span class="font-semibold">{ formatNumber(playlist.UniqueAlbums) }</span> albums
								</div>
							</div>
							<!-- External Link -->
							<div class="flex flex-wrap gap-2">
								if playlist.ExternalURL != "" {
									@components.ExternalLinkBadge(
										fmt.Sprintf("Open in %s", capitalizeFirst(playlist.Source)),
										playlist.ExternalURL,
										components.ProviderIcon(playlist.Source),
										components.ProviderBadgeClass(playlist.Source),
									)
								}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="max-w-7xl mx-auto">
			<!-- Tracks -->
			<div class="card bg-base-100 shadow-xl mb-8">
				<div class="card-body">
					<div class="flex items-center justify-between">
						<h3 class="card-title">
							<span class="icon-[heroicons--queue-list] w-5 h-5"></span>
							Tracks
							<span class="badge badge-ghost badge-sm">{ fmt.Sprintf("%d", len(tracks)) }</span>
						</h3>
						@components.ColumnToggleMenu("playlist-tracks-table", []components.ColumnOption{
							{Value: "col-index", Label: "#", DefaultVisible: true},
							{Value: "col-track", Label: "Track", DefaultVisible: true},
							{Value: "col-artist", Label: "Artist", DefaultVisible: true},
							{Value: "col-album", Label: "Album", DefaultVisible: true},
							{Value: "col-duration", Label: "Duration", DefaultVisible: true},
							{Value: "col-popularity", Label: "Popularity", DefaultVisible: false},
						})
					</div>
					if len(tracks) == 0 {
						<div class="text-center py-8">
							<span class="icon-[heroicons--musical-note] w-12 h-12 text-base-content/30 mx-auto mb-4"></span>
							<p class="text-base-content/60">No tracks in this playlist yet.</p>
							<p class="text-base-content/40 text-sm mt-1">Sync your playlists to import tracks.</p>
						</div>
					} else {
						@components.TrackTable("playlist-tracks-table", tracks, []string{"#", "track", "artist", "album", "duration"}, nil, components.SortConfig{})
					}
				</div>
			</div>
			<!-- Metadata Table -->
			<div class="card bg-base-100 shadow-xl mb-8">
				<div class="card-body">
					<h3 class="card-title">
						<span class="icon-[heroicons--information-circle] w-5 h-5"></span>
						Metadata
					</h3>
					@components.MetadataTable([]components.MetadataRow{
						{Label: "Name", Value: playlist.Name},
						{Label: "Source", Value: capitalizeFirst(playlist.Source)},
						{Label: "Remote ID", Value: playlist.RemoteID},
						{Label: "Track Count", Value: formatNumber(playlist.TrackCount)},
						{Label: "Unique Artists", Value: formatNumber(playlist.UniqueArtists)},
						{Label: "Unique Albums", Value: formatNumber(playlist.UniqueAlbums)},
						{Label: "External URL", Value: showGetOrDefault(playlist.ExternalURL, "N/A"), Link: playlist.ExternalURL},
						{Label: "Created", Value: showFormatDate(playlist.CreatedAt)},
						{Label: "Updated", Value: showFormatDate(playlist.UpdatedAt)},
					})
				</div>
			</div>
		</div>
	}
}

func capitalizeFirst(s string) string {
	if s == "" {
		return s
	}
	return string(s[0]-32) + s[1:]
}
