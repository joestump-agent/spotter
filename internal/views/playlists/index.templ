package playlists

import (
	"fmt"
	"sort"
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
	"strings"
	"time"
)

func formatPlaylistTime(t time.Time) string {
	return t.Local().Format("Jan 02, 2006 at 3:04 PM")
}

func formatPlaylistTimeISO(t time.Time) string {
	return t.UTC().Format(time.RFC3339)
}

func formatNumber(n int) string {
	return fmt.Sprintf("%d", n)
}

func isNavidromeSource(source string) bool {
	return source == "navidrome"
}

// sortPlaylistsByName returns a copy of playlists sorted alphabetically by name (case-insensitive)
func sortPlaylistsByName(playlists []*ent.Playlist) []*ent.Playlist {
	sorted := make([]*ent.Playlist, len(playlists))
	copy(sorted, playlists)
	sort.Slice(sorted, func(i, j int) bool {
		return strings.ToLower(sorted[i].Name) < strings.ToLower(sorted[j].Name)
	})
	return sorted
}

templ providerBadge(source string) {
	if source == "spotify" {
		<div class="badge badge-success gap-2">
			<span class="icon-[simple-icons--spotify] w-3 h-3"></span>
			Spotify
		</div>
	} else if source == "navidrome" {
		<div class="badge badge-primary gap-2">
			<span class="icon-[heroicons--musical-note] w-3 h-3"></span>
			Navidrome
		</div>
	} else if source == "lastfm" {
		<div class="badge badge-error gap-2">
			<span class="icon-[simple-icons--lastdotfm] w-3 h-3"></span>
			Last.fm
		</div>
	} else {
		<div class="badge badge-ghost">{ source }</div>
	}
}

templ Index(playlists []*ent.Playlist, currentPage int, totalPages int, cfg *config.Config) {
	@layouts.Dashboard("Playlists | Spotter", cfg, "/playlists") {
		<div class="max-w-7xl mx-auto">
			<div class="flex items-center justify-between mb-8">
				<div>
					<h2 class="text-3xl font-bold">Playlists</h2>
					<p class="text-base-content/60 mt-2">All playlists synced from your connected music services</p>
				</div>
				<!-- View Toggle -->
				<div class="join">
					<button
						id="table-view-btn"
						class="join-item btn btn-sm btn-square"
						onclick="setView('table')"
						title="Table view"
					>
						<span class="icon-[heroicons--table-cells] w-4 h-4"></span>
					</button>
					<button
						id="tile-view-btn"
						class="join-item btn btn-sm btn-square btn-active"
						onclick="setView('tile')"
						title="Tile view"
					>
						<span class="icon-[heroicons--squares-2x2] w-4 h-4"></span>
					</button>
				</div>
			</div>
			if len(playlists) == 0 {
				<div class="card bg-base-200">
					<div class="card-body items-center text-center">
						<span class="icon-[heroicons--queue-list] w-16 h-16 text-base-content/30"></span>
						<h3 class="card-title">No playlists found</h3>
						<p class="text-base-content/60">Playlists will appear here once they are synced from your connected services.</p>
					</div>
				</div>
			} else {
				<!-- Table View -->
				<div id="table-view" class="hidden card bg-base-100 shadow-xl">
					<div class="card-body p-0">
						<div class="overflow-x-auto">
							<table class="table table-zebra">
								<thead>
									<tr>
										<th class="w-12"></th>
										<th>Name</th>
										<th>Description</th>
										<th>Tracks</th>
										<th>Artists</th>
										<th>Albums</th>
										<th>Source</th>
										<th>Sync</th>
										<th>Last Updated</th>
									</tr>
								</thead>
								<tbody>
									for _, pl := range sortPlaylistsByName(playlists) {
										<tr class="hover">
											<td>
												<div class="avatar">
													<div class="w-10 h-10 rounded">
														if pl.ImageURL != "" {
															<img src={ pl.ImageURL } alt={ pl.Name }/>
														} else {
															<div class="bg-base-300 w-full h-full flex items-center justify-center">
																<span class="icon-[heroicons--queue-list] w-5 h-5 text-base-content/40"></span>
															</div>
														}
													</div>
												</div>
											</td>
											<td>
												<a href={ templ.URL(fmt.Sprintf("/playlists/%d", pl.ID)) } class="font-medium hover:text-primary hover:underline">
													{ pl.Name }
												</a>
												if pl.ExternalURL != "" {
													<a href={ templ.URL(pl.ExternalURL) } target="_blank" rel="noopener noreferrer" class="ml-2 opacity-50 hover:opacity-100">
														<span class="icon-[heroicons--arrow-top-right-on-square] w-3 h-3"></span>
													</a>
												}
											</td>
											<td>
												<div class="text-sm text-base-content/60 max-w-md truncate">
													if pl.Description != "" {
														{ pl.Description }
													} else {
														<span class="italic opacity-50">No description</span>
													}
												</div>
											</td>
											<td>
												<div class="text-sm font-medium">{ formatNumber(pl.TrackCount) }</div>
											</td>
											<td>
												<div class="text-sm">{ formatNumber(pl.UniqueArtists) }</div>
											</td>
											<td>
												<div class="text-sm">{ formatNumber(pl.UniqueAlbums) }</div>
											</td>
											<td>
												@providerBadge(pl.Source)
											</td>
											<td>
												@components.PlaylistSyncIndicator(pl.SyncToNavidrome, isNavidromeSource(pl.Source))
											</td>
											<td class="whitespace-nowrap">
												<span class="timeago text-sm text-base-content/60" datetime={ formatPlaylistTimeISO(pl.UpdatedAt) } title={ formatPlaylistTime(pl.UpdatedAt) }>
													{ formatPlaylistTime(pl.UpdatedAt) }
												</span>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				</div>
				<!-- Tile View -->
				<div id="tile-view" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
					for _, pl := range sortPlaylistsByName(playlists) {
						<a href={ templ.URL(fmt.Sprintf("/playlists/%d", pl.ID)) } class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all hover:scale-105">
							<!-- Cover Art -->
							<figure class="aspect-square bg-base-300 relative">
								if pl.ImageURL != "" {
									<img src={ pl.ImageURL } alt={ pl.Name } class="w-full h-full object-cover"/>
								} else {
									<div class="w-full h-full flex items-center justify-center">
										<span class="icon-[heroicons--queue-list] w-16 h-16 text-base-content/20"></span>
									</div>
								}
								<!-- Sync indicator overlay -->
								@components.PlaylistSyncBadge(components.PlaylistSyncBadgeConfig{
									SyncToNavidrome:  pl.SyncToNavidrome,
									IsNavidromeOwned: isNavidromeSource(pl.Source),
									NavidromeID:      pl.NavidromePlaylistID,
									MatchedTracks:    pl.MatchedTrackCount,
									TotalTracks:      pl.TrackCount,
									SyncError:        pl.SyncError,
								})
							</figure>
							<div class="card-body p-4">
								<!-- Title & Provider -->
								<div class="flex items-start justify-between gap-2">
									<h3 class="card-title text-base line-clamp-1">
										{ pl.Name }
									</h3>
									@providerBadge(pl.Source)
								</div>
								<!-- Description -->
								<p class="text-sm text-base-content/60 line-clamp-2 min-h-[2.5rem]">
									if pl.Description != "" {
										{ pl.Description }
									} else {
										<span class="italic opacity-50">No description</span>
									}
								</p>
								<!-- Stats -->
								<div class="divider my-2"></div>
								<div class="grid grid-cols-3 gap-2 text-center">
									<div>
										<div class="text-lg font-bold">{ formatNumber(pl.TrackCount) }</div>
										<div class="text-xs text-base-content/60">Tracks</div>
									</div>
									<div>
										<div class="text-lg font-bold">{ formatNumber(pl.UniqueArtists) }</div>
										<div class="text-xs text-base-content/60">Artists</div>
									</div>
									<div>
										<div class="text-lg font-bold">{ formatNumber(pl.UniqueAlbums) }</div>
										<div class="text-xs text-base-content/60">Albums</div>
									</div>
								</div>
								<!-- Last Updated -->
								<div class="text-xs text-base-content/50 mt-2 text-center">
									Updated <span class="timeago" datetime={ formatPlaylistTimeISO(pl.UpdatedAt) } title={ formatPlaylistTime(pl.UpdatedAt) }>{ formatPlaylistTime(pl.UpdatedAt) }</span>
								</div>
							</div>
						</a>
					}
				</div>
				if totalPages > 1 {
					<div class="flex justify-center mt-8">
						<div class="join">
							if currentPage > 1 {
								<a href={ templ.URL(fmt.Sprintf("/playlists?page=%d", currentPage-1)) } class="join-item btn btn-sm">«</a>
							} else {
								<button class="join-item btn btn-sm btn-disabled">«</button>
							}
							for i := 1; i <= totalPages; i++ {
								if i == currentPage {
									<button class="join-item btn btn-sm btn-active">{ fmt.Sprintf("%d", i) }</button>
								} else if i == 1 || i == totalPages || (i >= currentPage-2 && i <= currentPage+2) {
									<a href={ templ.URL(fmt.Sprintf("/playlists?page=%d", i)) } class="join-item btn btn-sm">{ fmt.Sprintf("%d", i) }</a>
								} else if i == currentPage-3 || i == currentPage+3 {
									<button class="join-item btn btn-sm btn-disabled">...</button>
								}
							}
							if currentPage < totalPages {
								<a href={ templ.URL(fmt.Sprintf("/playlists?page=%d", currentPage+1)) } class="join-item btn btn-sm">»</a>
							} else {
								<button class="join-item btn btn-sm btn-disabled">»</button>
							}
						</div>
					</div>
				}
			}
		</div>
		<script>
			// View toggle functionality
			function setView(view) {
				const tableView = document.getElementById('table-view');
				const tileView = document.getElementById('tile-view');
				const tableBtn = document.getElementById('table-view-btn');
				const tileBtn = document.getElementById('tile-view-btn');

				if (view === 'table') {
					tableView.classList.remove('hidden');
					tileView.classList.add('hidden');
					tableBtn.classList.add('btn-active');
					tileBtn.classList.remove('btn-active');
				} else {
					tableView.classList.add('hidden');
					tileView.classList.remove('hidden');
					tableBtn.classList.remove('btn-active');
					tileBtn.classList.add('btn-active');
				}

				// Save preference
				localStorage.setItem('spotter-playlists-view', view);
			}

			// Restore saved preference (default is tile)
			(function() {
				const savedView = localStorage.getItem('spotter-playlists-view');
				if (savedView === 'table') {
					setView('table');
				}
			})();

			// Initialize timeago
			(function() {
				if (typeof timeago !== 'undefined') {
					const nodes = document.querySelectorAll('.timeago');
					if (nodes.length > 0) {
						timeago.render(nodes);
					}
				}
			})();
		</script>
	}
}
