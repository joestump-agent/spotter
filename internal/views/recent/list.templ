package recent

import (
	"fmt"
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/layouts"
	"time"
)

templ Index(listens []*ent.Listen, currentPage int, totalPages int, cfg *config.Config) {
	@layouts.Dashboard("Listens | Spotter", cfg, "/recent") {
		<div class="max-w-7xl mx-auto">
			<div class="flex items-center justify-between mb-8">
				<div>
					<h2 class="text-3xl font-bold">Listens</h2>
					<p class="text-base-content/60 mt-2">Your listening history from all connected services</p>
				</div>
			</div>
			if len(listens) == 0 {
				<div class="card bg-base-200">
					<div class="card-body items-center text-center">
						<span class="icon-[heroicons--musical-note] w-16 h-16 text-base-content/30"></span>
						<h3 class="card-title">No listens found</h3>
						<p class="text-base-content/60">Your listening history will appear here once you start playing music.</p>
					</div>
				</div>
			} else {
				<div class="card bg-base-100 shadow-xl">
					<div class="card-body p-0">
						<div class="overflow-x-auto">
							<table class="table table-zebra">
								<thead>
									<tr>
										<th>Source</th>
										<th>Played At</th>
										<th>Artist</th>
										<th>Album</th>
										<th>Track</th>
									</tr>
								</thead>
								<tbody sse-swap="recent-listen" hx-swap="afterbegin">
									for _, listen := range listens {
										@ListenRow(listen)
									}
								</tbody>
							</table>
						</div>
					</div>
				</div>
				if totalPages > 1 {
					<div class="flex justify-center mt-8">
						<div class="join">
							if currentPage > 1 {
								<a href={ templ.URL(fmt.Sprintf("/recent?page=%d", currentPage-1)) } class="join-item btn btn-sm">«</a>
							} else {
								<button class="join-item btn btn-sm btn-disabled">«</button>
							}
							for i := 1; i <= totalPages; i++ {
								if i == currentPage {
									<button class="join-item btn btn-sm btn-active">{ fmt.Sprintf("%d", i) }</button>
								} else if i == 1 || i == totalPages || (i >= currentPage-2 && i <= currentPage+2) {
									<a href={ templ.URL(fmt.Sprintf("/recent?page=%d", i)) } class="join-item btn btn-sm">{ fmt.Sprintf("%d", i) }</a>
								} else if i == currentPage-3 || i == currentPage+3 {
									<button class="join-item btn btn-sm btn-disabled">...</button>
								}
							}
							if currentPage < totalPages {
								<a href={ templ.URL(fmt.Sprintf("/recent?page=%d", currentPage+1)) } class="join-item btn btn-sm">»</a>
							} else {
								<button class="join-item btn btn-sm btn-disabled">»</button>
							}
						</div>
					</div>
				}
			}
		</div>
	}
}

func getArtistURL(listen *ent.Listen) string {
	if listen.Edges.Artist != nil {
		return fmt.Sprintf("/library/artist/%d", listen.Edges.Artist.ID)
	}
	return fmt.Sprintf("/library/artists?search=%s", listen.ArtistName)
}

func getAlbumURL(listen *ent.Listen) string {
	if listen.Edges.Album != nil {
		return fmt.Sprintf("/library/album/%d", listen.Edges.Album.ID)
	}
	return fmt.Sprintf("/library/albums?search=%s", listen.AlbumName)
}

func getTrackURL(listen *ent.Listen) string {
	if listen.Edges.Track != nil {
		return fmt.Sprintf("/library/track/%d", listen.Edges.Track.ID)
	}
	return fmt.Sprintf("/library/tracks?search=%s", listen.TrackName)
}

templ ListenRow(listen *ent.Listen) {
	<tr class="hover">
		<td>
			if listen.Source == "spotify" {
				<div class="badge badge-success gap-2">
					<span class="icon-[simple-icons--spotify] w-3 h-3"></span>
					Spotify
				</div>
			} else if listen.Source == "navidrome" {
				<div class="badge badge-primary gap-2">
					<span class="icon-[heroicons--musical-note] w-3 h-3"></span>
					Navidrome
				</div>
			} else if listen.Source == "lastfm" {
				<div class="badge badge-error gap-2">
					<span class="icon-[simple-icons--lastdotfm] w-3 h-3"></span>
					Last.fm
				</div>
			} else {
				<div class="badge badge-ghost">{ listen.Source }</div>
			}
		</td>
		<td class="whitespace-nowrap">
			<time class="text-sm text-base-content/60" datetime={ listen.PlayedAt.Format(time.RFC3339) }>
				{ listen.PlayedAt.Local().Format("Jan 02, 3:04 PM") }
			</time>
		</td>
		<td>
			<a
				href={ templ.URL(getArtistURL(listen)) }
				class="text-sm hover:text-primary hover:underline"
				hx-boost="true"
			>
				{ listen.ArtistName }
			</a>
		</td>
		<td>
			<a
				href={ templ.URL(getAlbumURL(listen)) }
				class="text-sm text-base-content/60 hover:text-secondary hover:underline"
				hx-boost="true"
			>
				{ listen.AlbumName }
			</a>
		</td>
		<td>
			<a
				href={ templ.URL(getTrackURL(listen)) }
				class="font-medium hover:text-accent hover:underline"
				hx-boost="true"
			>
				{ listen.TrackName }
			</a>
		</td>
	</tr>
}
