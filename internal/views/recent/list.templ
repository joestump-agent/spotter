package recent

import (
	"fmt"
	"net/url"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
)

func buildPaginationURL(page int, artistFilter, sortCol, sortDir string) string {
	u := fmt.Sprintf("/recent?page=%d", page)
	if artistFilter != "" {
		u += "&artist=" + url.QueryEscape(artistFilter)
	}
	if sortCol != "" {
		u += "&sort=" + sortCol + "&dir=" + sortDir
	}
	return u
}

func buildSortBaseURL(currentPage int, artistFilter string) string {
	u := fmt.Sprintf("/recent?page=%d", currentPage)
	if artistFilter != "" {
		u += "&artist=" + url.QueryEscape(artistFilter)
	}
	return u
}

templ Index(rows []components.TrackTableRow, currentPage int, totalPages int, cfg *config.Config, artistFilter, sortCol, sortDir string) {
	@layouts.Dashboard("Listens | Spotter", cfg, "/recent") {
		<div class="max-w-7xl mx-auto">
			if len(rows) == 0 {
				<div class="card bg-base-200">
					<div class="card-body items-center text-center">
						<span class="icon-[heroicons--musical-note] w-16 h-16 text-base-content/30"></span>
						if artistFilter != "" {
							<h3 class="card-title">No listens found for this artist</h3>
							<p class="text-base-content/60">Try clearing the filter to see all listens.</p>
							<a href="/recent" class="btn btn-primary btn-sm mt-4">Clear Filter</a>
						} else {
							<h3 class="card-title">No listens found</h3>
							<p class="text-base-content/60">Your listening history will appear here once you start playing music.</p>
						}
					</div>
				</div>
			} else {
				<div class="card bg-base-100 shadow-xl">
					<div class="card-body">
						<div class="flex items-center justify-between mb-4">
							<div>
								<h3 class="card-title">
									<span class="icon-[heroicons--clock] w-5 h-5"></span>
									Listens
								</h3>
								if artistFilter != "" {
									<p class="text-base-content/60 text-sm mt-1">
										Filtered by artist: <span class="font-medium text-primary">{ artistFilter }</span>
										<a href="/recent" class="ml-2 link link-primary text-xs">Clear</a>
									</p>
								} else {
									<p class="text-base-content/60 text-sm mt-1">Your listening history from all connected services</p>
								}
							</div>
							<div class="flex items-center gap-2">
								@components.TrackTableToolbar(components.TrackTableToolbarConfig{
									TableID:           "listens-table",
									ShowArtworkToggle: true,
									ArtworkDefault:    true,
									ColumnOptions: []components.ColumnOption{
										{Value: "col-source", Label: "Source", DefaultVisible: true},
										{Value: "col-played_at", Label: "Played At", DefaultVisible: true},
										{Value: "col-track", Label: "Track", DefaultVisible: true},
										{Value: "col-artist", Label: "Artist", DefaultVisible: true},
										{Value: "col-album", Label: "Album", DefaultVisible: true},
										{Value: "col-duration", Label: "Duration", DefaultVisible: false},
										{Value: "col-popularity", Label: "Popularity", DefaultVisible: false},
									},
								})
							</div>
						</div>
						@components.TrackTable("listens-table", rows, []string{"source", "played_at", "track", "artist", "album"}, templ.Attributes{"sse-swap": "recent-listen", "hx-swap": "afterbegin"}, components.SortConfig{
							Column:    sortCol,
							Direction: sortDir,
							BaseURL:   buildSortBaseURL(currentPage, artistFilter),
						})
					</div>
				</div>
				if totalPages > 1 {
					<div class="flex justify-center mt-8">
						<div class="join">
							if currentPage > 1 {
								<a href={ templ.URL(buildPaginationURL(currentPage-1, artistFilter, sortCol, sortDir)) } class="join-item btn btn-sm">«</a>
							} else {
								<button class="join-item btn btn-sm btn-disabled" disabled>«</button>
							}
							for i := 1; i <= totalPages; i++ {
								if i == currentPage {
									<button class="join-item btn btn-sm btn-active">{ fmt.Sprintf("%d", i) }</button>
								} else if i == 1 || i == totalPages || (i >= currentPage-2 && i <= currentPage+2) {
									<a href={ templ.URL(buildPaginationURL(i, artistFilter, sortCol, sortDir)) } class="join-item btn btn-sm">{ fmt.Sprintf("%d", i) }</a>
								} else if i == currentPage-3 || i == currentPage+3 {
									<button class="join-item btn btn-sm btn-disabled" disabled>...</button>
								}
							}
							if currentPage < totalPages {
								<a href={ templ.URL(buildPaginationURL(currentPage+1, artistFilter, sortCol, sortDir)) } class="join-item btn btn-sm">»</a>
							} else {
								<button class="join-item btn btn-sm btn-disabled" disabled>»</button>
							}
						</div>
					</div>
				}
			}
		</div>
	}
}
