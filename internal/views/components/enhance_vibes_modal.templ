package components

import (
	"fmt"
	"spotter/ent"
)

// EnhanceVibesModalParams holds the data needed to render the enhance vibes modal.
type EnhanceVibesModalParams struct {
	PlaylistID   int
	PlaylistName string
	TrackCount   int
	DJs          []*ent.DJ
}

// EnhanceVibesModal provides an empty dialog shell for HTMX to target.
templ EnhanceVibesModal() {
	<dialog id="enhance-vibes-modal" class="modal"></dialog>
}

// EnhanceVibesModalContent renders the inner content of the enhance vibes modal.
templ EnhanceVibesModalContent(params EnhanceVibesModalParams) {
	<div class="modal-box max-w-2xl">
		<form method="dialog">
			<button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
		</form>
		<h3 class="font-bold text-lg flex items-center gap-2">
			<span class="icon-[heroicons--sparkles] w-5 h-5 text-accent"></span>
			Enhance Vibes
		</h3>
		<p class="text-sm text-base-content/60 py-2">
			Let a DJ persona enhance your playlist "{ params.PlaylistName }" with better flow and new track suggestions.
		</p>
		<!-- Guarantee Badge -->
		<div class="alert alert-info mb-4">
			<span class="icon-[heroicons--shield-check] w-5 h-5"></span>
			<div>
				<div class="font-medium">Your tracks are safe</div>
				<div class="text-xs">All { fmt.Sprintf("%d", params.TrackCount) } existing tracks will be kept. The DJ will only reorder them and suggest additions.</div>
			</div>
		</div>
		<form
			hx-post={ fmt.Sprintf("/playlists/%d/enhance-vibes", params.PlaylistID) }
			hx-swap="none"
			_="on htmx:afterRequest if this.closest('dialog') this.closest('dialog').close()"
		>
			<!-- DJ Selection -->
			<div class="form-control mb-4">
				<label class="label">
					<span class="label-text">
						DJ Persona
						<span class="text-error">*</span>
					</span>
				</label>
				if len(params.DJs) == 0 {
					<div class="alert alert-warning">
						<span class="icon-[heroicons--exclamation-triangle] w-5 h-5"></span>
						<span>No DJs available. <a href="/vibes/djs" class="link link-primary">Create a DJ first</a>.</span>
					</div>
				} else {
					<select name="dj_id" class="select select-bordered w-full" required>
						<option value="" disabled selected>Select a DJ to guide the enhancement</option>
						for _, d := range params.DJs {
							<option value={ fmt.Sprintf("%d", d.ID) }>{ d.Name }</option>
						}
					</select>
					<label class="label">
						<span class="label-text-alt">The DJ's personality will influence track ordering and suggestions</span>
					</label>
				}
			</div>
			<!-- Max New Tracks -->
			<div class="form-control mb-4">
				<label class="label">
					<span class="label-text">New Tracks to Add</span>
				</label>
				<input
					type="number"
					name="max_new_tracks"
					class="input input-bordered"
					min="0"
					max="20"
					value="5"
				/>
				<label class="label">
					<span class="label-text-alt">How many new tracks should the DJ suggest? (0-20)</span>
				</label>
			</div>
			<!-- Enhancement Mode Selection -->
			<div class="form-control mb-6">
				<label class="label">
					<span class="label-text font-medium">Enhancement Mode</span>
				</label>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
					<!-- One-time Enhancement -->
					<label class="cursor-pointer">
						<input type="radio" name="mode" value="one_time" class="peer hidden" checked/>
						<div class="card bg-base-200 border-2 border-transparent peer-checked:border-primary peer-checked:bg-primary/10 transition-all">
							<div class="card-body p-4">
								<div class="flex items-center gap-2 mb-2">
									<span class="icon-[heroicons--bolt] w-5 h-5 text-primary"></span>
									<span class="font-semibold">One-time Enhance</span>
								</div>
								<p class="text-xs text-base-content/70">
									Apply the changes directly to Navidrome. The playlist remains yours to edit manually afterward.
								</p>
								<div class="flex flex-wrap gap-1 mt-2">
									<span class="badge badge-sm badge-ghost">Quick</span>
									<span class="badge badge-sm badge-ghost">One-off</span>
								</div>
							</div>
						</div>
					</label>
					<!-- Convert to Mixtape -->
					<label class="cursor-pointer">
						<input type="radio" name="mode" value="convert_to_mixtape" class="peer hidden"/>
						<div class="card bg-base-200 border-2 border-transparent peer-checked:border-secondary peer-checked:bg-secondary/10 transition-all">
							<div class="card-body p-4">
								<div class="flex items-center gap-2 mb-2">
									<span class="icon-[heroicons--arrow-path] w-5 h-5 text-secondary"></span>
									<span class="font-semibold">Convert to Mixtape</span>
								</div>
								<p class="text-xs text-base-content/70">
									The DJ takes over this playlist. It becomes a Mixtape that can be regenerated and scheduled.
								</p>
								<div class="flex flex-wrap gap-1 mt-2">
									<span class="badge badge-sm badge-ghost">Managed</span>
									<span class="badge badge-sm badge-ghost">Recurring</span>
								</div>
							</div>
						</div>
					</label>
				</div>
			</div>
			<!-- Mode Details Accordion -->
			<div class="collapse collapse-arrow bg-base-200 mb-4">
				<input type="checkbox"/>
				<div class="collapse-title text-sm font-medium">
					<span class="icon-[heroicons--question-mark-circle] w-4 h-4 inline-block mr-1"></span>
					What's the difference?
				</div>
				<div class="collapse-content">
					<div class="overflow-x-auto">
						<table class="table table-xs">
							<thead>
								<tr>
									<th></th>
									<th>One-time Enhance</th>
									<th>Convert to Mixtape</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td class="font-medium">Updates</td>
									<td>Manual only</td>
									<td>DJ can regenerate</td>
								</tr>
								<tr>
									<td class="font-medium">Scheduling</td>
									<td>None</td>
									<td>Daily/Weekly/Monthly</td>
								</tr>
								<tr>
									<td class="font-medium">Original Playlist</td>
									<td>Modified in place</td>
									<td>Linked to Mixtape</td>
								</tr>
								<tr>
									<td class="font-medium">Best for</td>
									<td>Quick fixes</td>
									<td>Evolving playlists</td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>
			</div>
			<!-- Actions -->
			<div class="modal-action">
				<button type="button" class="btn btn-ghost" onclick="this.closest('dialog').close()">Cancel</button>
				if len(params.DJs) > 0 {
					<button type="submit" class="btn btn-accent gap-2">
						<span class="icon-[heroicons--sparkles] w-4 h-4"></span>
						Enhance Playlist
					</button>
				} else {
					<button type="submit" class="btn btn-accent gap-2" disabled>
						<span class="icon-[heroicons--sparkles] w-4 h-4"></span>
						Enhance Playlist
					</button>
				}
			</div>
		</form>
	</div>
	<form method="dialog" class="modal-backdrop">
		<button>close</button>
	</form>
}

// EnhanceVibesButton renders the button that opens the enhance vibes modal.
// This replaces the old "Enhance" button on playlist views.
// Governing: SPEC vibes-ai-mixtape-engine REQ "modal opens only after HTMX content is loaded"
templ EnhanceVibesButton(playlistID int, size string) {
	<button
		class={ "btn btn-accent gap-2", templ.KV("btn-sm", size == "sm") }
		hx-get={ fmt.Sprintf("/playlists/%d/enhance-vibes-modal", playlistID) }
		hx-target="#enhance-vibes-modal"
		hx-swap="innerHTML"
		_="on htmx:afterSettle from #enhance-vibes-modal call #enhance-vibes-modal.showModal()"
	>
		<span class="icon-[heroicons--sparkles] w-4 h-4"></span>
		Enhance Vibes
	</button>
}
