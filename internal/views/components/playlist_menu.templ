package components

import (
	"fmt"
	"time"
)

// PlaylistMenuConfig defines the configuration for the playlist menu bar.
type PlaylistMenuConfig struct {
	PlaylistID       int        // Database ID of the playlist
	PlaylistName     string     // Name of the playlist for display
	Source           string     // Source provider (e.g., "spotify", "navidrome", "lastfm")
	SyncToNavidrome  bool       // Whether this playlist is being synced to Navidrome
	NavidromeID      string     // Navidrome playlist ID if synced (empty if not synced)
	IsNavidromeOwned bool       // True if this playlist originated from Navidrome
	LastSyncedAt     *time.Time // When the playlist was last synced
	MatchedTracks    int        // Number of tracks matched in Navidrome
	TotalTracks      int        // Total number of tracks in playlist
	SyncError        string     // Current sync error message (if any)
}

// PlaylistSyncDropdownConfig defines configuration for the playlist sync dropdown.
// This is used to render the sync controls on playlist detail pages.
type PlaylistSyncDropdownConfig struct {
	PlaylistID      int        // Database ID of the playlist
	PlaylistName    string     // Name of the playlist for display
	Source          string     // Source provider (e.g., "spotify", "lastfm")
	SyncToNavidrome bool       // Whether sync is currently enabled
	NavidromeID     string     // Navidrome playlist ID if synced
	LastSyncedAt    *time.Time // When the playlist was last synced
	MatchedTracks   int        // Number of tracks matched
	TotalTracks     int        // Total number of tracks
	SyncError       string     // Current sync error message
}

// toSyncStatusConfig converts PlaylistSyncDropdownConfig to SyncStatusConfig
// for use with the unified getSyncState function.
func toSyncStatusConfig(config PlaylistSyncDropdownConfig) SyncStatusConfig {
	return SyncStatusConfig{
		EntityType:     "playlist",
		EntityID:       config.PlaylistID,
		SyncEnabled:    config.SyncToNavidrome,
		LastSyncedAt:   config.LastSyncedAt,
		SyncError:      config.SyncError,
		TargetProvider: "navidrome",
		MatchedTracks:  config.MatchedTracks,
		TotalTracks:    config.TotalTracks,
		NavidromeID:    config.NavidromeID,
	}
}

// PlaylistMenuBar renders a menu bar for playlist actions.
// Different options are shown based on the playlist source and sync state.
templ PlaylistMenuBar(config PlaylistMenuConfig) {
	<div id="playlist-menu-bar" class="flex items-center gap-3 flex-wrap">
		if !config.IsNavidromeOwned {
			// Non-Navidrome playlist: Show sync dropdown
			@PlaylistSyncDropdown(PlaylistSyncDropdownConfig{
				PlaylistID:      config.PlaylistID,
				PlaylistName:    config.PlaylistName,
				Source:          config.Source,
				SyncToNavidrome: config.SyncToNavidrome,
				NavidromeID:     config.NavidromeID,
				LastSyncedAt:    config.LastSyncedAt,
				MatchedTracks:   config.MatchedTracks,
				TotalTracks:     config.TotalTracks,
				SyncError:       config.SyncError,
			})
		} else {
			// Navidrome playlist: Show Enhance Vibes button and AI dropdown
			@EnhanceVibesButton(config.PlaylistID, "sm")
			@PlaylistAIDropdown(config)
		}
		// Render the Enhance Vibes modal shell (content loaded via HTMX)
		@EnhanceVibesModal()
	</div>
}

// PlaylistSyncDropdown renders a dropdown for managing playlist sync to Navidrome.
// When sync is enabled, shows a split-button with Sync Now, Rebuild, and Disable actions.
// When sync is disabled, shows a simple Enable Sync button.
// The progress bar is now rendered inside the dropdown menu header.
templ PlaylistSyncDropdown(config PlaylistSyncDropdownConfig) {
	<div id="playlist-sync-dropdown" class="flex flex-col gap-2">
		@ActionButtonDropdown(buildPlaylistSyncDropdownConfig(config))
		// Render modals
		@PlaylistRebuildModal(config.PlaylistID, config.PlaylistName)
		@PlaylistDisableSyncModal(config.PlaylistID, config.PlaylistName)
	</div>
}

// playlistSyncMenuHeader renders the header section of the sync dropdown menu.
// This shows the progress bar at the top of the menu.
templ playlistSyncMenuHeader(config PlaylistSyncDropdownConfig) {
	<li class="pointer-events-none">
		<div class="flex flex-col gap-2 px-2 py-3 w-full">
			@SyncProgressBar(toSyncStatusConfig(config))
		</div>
	</li>
	<div class="divider my-1"></div>
}

// playlistSyncMenuFooter renders the footer section of the sync dropdown menu.
// This shows the last synced timestamp and any sync errors at the bottom.
templ playlistSyncMenuFooter(config PlaylistSyncDropdownConfig) {
	<div class="divider my-1"></div>
	<li class="pointer-events-none">
		<div class="flex flex-col gap-2 px-2 py-2 w-full">
			// Error message display (if present)
			if config.SyncError != "" {
				<div class="flex items-start gap-2 text-xs text-error">
					<span class="icon-[heroicons--exclamation-circle] w-4 h-4 flex-shrink-0 mt-0.5"></span>
					<span class="break-words">{ config.SyncError }</span>
				</div>
			}
			// Last synced timestamp
			<div class="text-xs text-base-content/60">
				if config.LastSyncedAt != nil && !config.LastSyncedAt.IsZero() {
					<span>
						Last synced:
						<span class="timeago" datetime={ formatISOTime(config.LastSyncedAt) }>
							{ formatRelativeTime(config.LastSyncedAt) }
						</span>
					</span>
				} else {
					<span>Never synced</span>
				}
			</div>
		</div>
	</li>
}

// buildPlaylistSyncDropdownConfig builds the ActionButtonDropdownConfig for playlist sync.
// Uses the unified getSyncState from sync_status.templ as the single source of truth.
func buildPlaylistSyncDropdownConfig(config PlaylistSyncDropdownConfig) ActionButtonDropdownConfig {
	// Convert to SyncStatusConfig to use unified getSyncState logic
	syncConfig := toSyncStatusConfig(config)
	state := getSyncState(syncConfig)

	// Build actions for enabled state
	actions := []DropdownAction{
		{
			Label:       "Sync Now",
			Description: "Sync tracks to Navidrome",
			IconClass:   "icon-[heroicons--arrow-path]",
			HtmxPost:    fmt.Sprintf("/playlists/%d/sync", config.PlaylistID),
			HtmxTarget:  "#playlist-sync-dropdown",
		},
		{
			Label:       "Rebuild",
			Description: "Clear and re-sync from scratch",
			IconClass:   "icon-[heroicons--arrow-path-rounded-square]",
			IconColor:   "text-warning",
			ModalID:     fmt.Sprintf("playlist-rebuild-modal-%d", config.PlaylistID),
		},
		{
			// Governing: SPEC playlist-sync-navidrome REQ-PLSYNC-071, REQ-PLSYNC-072
			Label:       "Link to Navidrome Playlist",
			Description: "Pair with an existing playlist",
			IconClass:   "icon-[heroicons--link]",
			HtmxGet:     fmt.Sprintf("/playlists/%d/link", config.PlaylistID),
			HtmxTarget:  "#playlist-sync-dropdown",
		},
		{
			IsDivider: true,
		},
		{
			Label:     "Disable Sync",
			IconClass: "icon-[heroicons--pause-circle]",
			IconColor: "text-error",
			ModalID:   fmt.Sprintf("playlist-disable-sync-modal-%d", config.PlaylistID),
		},
	}

	// Use unified getSyncStateLabel for consistent terminology
	label := getSyncStateLabel(state, syncConfig)

	// Use unified getButtonClass for consistent styling
	buttonClass := getButtonClass(state)

	// Get appropriate icon based on state
	iconClass := "icon-[heroicons--check-circle]"
	if state == SyncStateError {
		iconClass = "icon-[heroicons--exclamation-circle]"
	} else if state == SyncStatePending {
		iconClass = "icon-[heroicons--arrow-path]"
	} else if state == SyncStateWarning {
		iconClass = "icon-[heroicons--exclamation-triangle]"
	}

	dropdownConfig := ActionButtonDropdownConfig{
		ID:          fmt.Sprintf("playlist-sync-%d", config.PlaylistID),
		Label:       label,
		IconClass:   iconClass,
		ButtonClass: buttonClass,
		Size:        "sm",
		IsEnabled:   config.SyncToNavidrome,
		MenuWidth:   "w-64",
		// StatusBadge removed - the Label is sufficient and having both is redundant
		Actions:         actions,
		EnableLabel:     "Enable Sync to Navidrome",
		EnableIconClass: "icon-[heroicons--arrow-path]",
		EnableHtmxPost:  fmt.Sprintf("/playlists/%d/toggle-sync", config.PlaylistID),
		EnableTarget:    "#playlist-sync-dropdown",
	}

	// Add menu header and footer when sync is enabled
	if config.SyncToNavidrome {
		dropdownConfig.MenuHeader = playlistSyncMenuHeader(config)
		dropdownConfig.MenuFooter = playlistSyncMenuFooter(config)
	}

	return dropdownConfig
}

// PlaylistRebuildModal renders the confirmation modal for rebuilding playlist sync.
templ PlaylistRebuildModal(playlistID int, playlistName string) {
	<dialog id={ fmt.Sprintf("playlist-rebuild-modal-%d", playlistID) } class="modal">
		<div class="modal-box">
			<h3 class="font-bold text-lg flex items-center gap-2">
				<span class="icon-[heroicons--exclamation-triangle] w-6 h-6 text-warning"></span>
				Rebuild Playlist Sync
			</h3>
			<p class="py-4">
				This will <strong>delete the synced playlist from Navidrome</strong> and re-create it from scratch.
				All track matches will be re-calculated.
			</p>
			<p class="text-sm text-base-content/60">
				Playlist: <strong>{ playlistName }</strong>
			</p>
			<div class="modal-action">
				<form method="dialog">
					<button class="btn btn-ghost">Cancel</button>
				</form>
				<button
					class="btn btn-warning"
					hx-post={ fmt.Sprintf("/playlists/%d/rebuild-sync", playlistID) }
					hx-target="#playlist-sync-dropdown"
					hx-swap="outerHTML"
					onclick={ closeModal(fmt.Sprintf("playlist-rebuild-modal-%d", playlistID)) }
				>
					<span class="icon-[heroicons--arrow-path-rounded-square] w-5 h-5"></span>
					Rebuild
				</button>
			</div>
		</div>
		<form method="dialog" class="modal-backdrop">
			<button>close</button>
		</form>
	</dialog>
}

// PlaylistDisableSyncModal renders the confirmation modal for disabling playlist sync.
// The user chooses whether the synced Navidrome playlist is kept or deleted; the
// choice is sent as the navidrome_action parameter and overrides the server-wide
// delete_on_unsync config for this request.
// Governing: SPEC playlist-sync-navidrome REQ-PLSYNC-033 (per-request keep/delete override)
templ PlaylistDisableSyncModal(playlistID int, playlistName string) {
	<dialog id={ fmt.Sprintf("playlist-disable-sync-modal-%d", playlistID) } class="modal">
		<div class="modal-box">
			<h3 class="font-bold text-lg flex items-center gap-2">
				<span class="icon-[heroicons--pause-circle] w-6 h-6 text-error"></span>
				Disable Playlist Sync
			</h3>
			<p class="py-4">
				Are you sure you want to disable sync for this playlist?
				You can keep the synced playlist in Navidrome or delete it.
			</p>
			<p class="text-sm text-base-content/60">
				Playlist: <strong>{ playlistName }</strong>
			</p>
			<div class="modal-action flex-wrap">
				<form method="dialog">
					<button class="btn btn-ghost">Cancel</button>
				</form>
				<button
					class="btn btn-warning"
					hx-post={ fmt.Sprintf("/playlists/%d/toggle-sync", playlistID) }
					hx-vals='{"navidrome_action": "keep"}'
					hx-target="#playlist-sync-dropdown"
					hx-swap="outerHTML"
					onclick={ closeModal(fmt.Sprintf("playlist-disable-sync-modal-%d", playlistID)) }
				>
					<span class="icon-[heroicons--pause-circle] w-5 h-5"></span>
					Disable sync &amp; keep Navidrome playlist
				</button>
				<button
					class="btn btn-error"
					hx-post={ fmt.Sprintf("/playlists/%d/toggle-sync", playlistID) }
					hx-vals='{"navidrome_action": "delete"}'
					hx-target="#playlist-sync-dropdown"
					hx-swap="outerHTML"
					onclick={ closeModal(fmt.Sprintf("playlist-disable-sync-modal-%d", playlistID)) }
				>
					<span class="icon-[heroicons--trash] w-5 h-5"></span>
					Disable sync &amp; delete Navidrome playlist
				</button>
			</div>
		</div>
		<form method="dialog" class="modal-backdrop">
			<button>close</button>
		</form>
	</dialog>
}

// closeModal returns a script to close a modal by ID

script closeModal(modalID string) {
	document.getElementById(modalID).close();
}

// PlaylistSyncToggle renders a simple toggle for syncing non-Navidrome playlists to Navidrome.
// DEPRECATED: Use PlaylistSyncDropdown instead for a more consistent UX.
templ PlaylistSyncToggle(config PlaylistMenuConfig) {
	<div
		id="playlist-sync-toggle"
		class="flex items-center gap-3 bg-base-100 rounded-lg px-4 py-2 shadow"
	>
		<div class="flex items-center gap-2">
			<span class="icon-[heroicons--arrow-path] w-4 h-4 text-primary"></span>
			<span class="text-sm font-medium">Sync to Navidrome</span>
		</div>
		<label class="swap swap-flip">
			<input
				type="checkbox"
				class="toggle toggle-primary toggle-sm"
				checked?={ config.SyncToNavidrome }
				hx-post={ fmt.Sprintf("/playlists/%d/toggle-sync", config.PlaylistID) }
				hx-target="#playlist-sync-toggle"
				hx-swap="outerHTML"
			/>
		</label>
		if config.SyncToNavidrome {
			<span class="badge badge-success badge-sm gap-1">
				<span class="icon-[heroicons--check-circle] w-3 h-3"></span>
				Synced
			</span>
		}
	</div>
}

// PlaylistAIDropdown renders an AI actions dropdown for Navidrome playlists.
templ PlaylistAIDropdown(config PlaylistMenuConfig) {
	<div class="dropdown dropdown-end">
		<div tabindex="0" role="button" class="btn btn-sm btn-accent gap-2">
			<span class="icon-[heroicons--sparkles] w-4 h-4"></span>
			AI Actions
			<span class="icon-[heroicons--chevron-down] w-3 h-3"></span>
		</div>
		<ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow-lg bg-base-100 rounded-box w-64">
			<li class="menu-title">
				<span class="text-xs uppercase tracking-wider">Content Generation</span>
			</li>
			<li>
				<button
					hx-post={ fmt.Sprintf("/playlists/%d/ai/generate-metadata", config.PlaylistID) }
					hx-swap="none"
					hx-indicator="#ai-indicator"
					class="flex items-center gap-3"
					onclick="this.closest('details')?.removeAttribute('open'); this.closest('.dropdown')?.blur();"
				>
					<span class="icon-[heroicons--document-text] w-5 h-5 text-accent"></span>
					<div class="flex flex-col items-start">
						<span class="font-medium">Generate Title &amp; Description</span>
						<span class="text-xs text-base-content/60">AI-powered metadata</span>
					</div>
				</button>
			</li>
			<li>
				<button
					hx-post={ fmt.Sprintf("/playlists/%d/ai/generate-artwork", config.PlaylistID) }
					hx-swap="none"
					hx-indicator="#ai-indicator"
					class="flex items-center gap-3"
					onclick="this.closest('details')?.removeAttribute('open'); this.closest('.dropdown')?.blur();"
				>
					<span class="icon-[heroicons--photo] w-5 h-5 text-accent"></span>
					<div class="flex flex-col items-start">
						<span class="font-medium">Generate Album Art</span>
						<span class="text-xs text-base-content/60">AI-generated cover image</span>
					</div>
				</button>
			</li>
			<div class="divider my-1"></div>
			<li class="menu-title">
				<span class="text-xs uppercase tracking-wider">Playlist Info</span>
			</li>
			<li class="disabled">
				<div class="flex items-center gap-3 opacity-60">
					<span class="icon-[heroicons--musical-note] w-5 h-5"></span>
					<div class="flex flex-col items-start">
						<span class="text-sm">Navidrome Playlist</span>
						<span class="text-xs text-base-content/60">Native to your library</span>
					</div>
				</div>
			</li>
		</ul>
	</div>
	<!-- AI Loading Indicator -->
	<span id="ai-indicator" class="htmx-indicator loading loading-spinner loading-sm text-accent"></span>
}

// PlaylistSyncBadgeConfig holds the configuration for the playlist sync badge.
type PlaylistSyncBadgeConfig struct {
	SyncToNavidrome  bool
	IsNavidromeOwned bool
	NavidromeID      string
	MatchedTracks    int
	TotalTracks      int
	SyncError        string
}

// PlaylistSyncBadge renders a small badge indicating sync status for use in tiles/lists.
// Uses the 5-state logic and shows progress hints for partial sync.
templ PlaylistSyncBadge(config PlaylistSyncBadgeConfig) {
	if !config.IsNavidromeOwned && config.SyncToNavidrome {
		// Convert to SyncStatusConfig for unified state logic
		{{
			syncConfig := SyncStatusConfig{
				SyncEnabled:   config.SyncToNavidrome,
				NavidromeID:   config.NavidromeID,
				MatchedTracks: config.MatchedTracks,
				TotalTracks:   config.TotalTracks,
				SyncError:     config.SyncError,
			}
			state := getSyncState(syncConfig)
		}}
		<div class={ "absolute top-2 right-2 badge gap-1 text-xs", getBadgeClass(state) }>
			<span class={ getIconClass(state), "w-3 h-3", templ.KV("animate-spin", state == SyncStatePending) }></span>
			if state == SyncStateWarning || state == SyncStateSuccess {
				// Show progress for synced states
				{ fmt.Sprintf("%d/%d", config.MatchedTracks, config.TotalTracks) }
			} else if state == SyncStatePending {
				Syncing
			} else if state == SyncStateError {
				Error
			}
		</div>
	}
}

// PlaylistSyncBadgeSimple renders a simple sync badge (legacy, for backward compatibility).
// Prefer PlaylistSyncBadge with full config for accurate state display.
templ PlaylistSyncBadgeSimple(syncToNavidrome bool, isNavidromeOwned bool) {
	if !isNavidromeOwned && syncToNavidrome {
		<div class="absolute top-2 right-2 badge badge-primary gap-1 text-xs">
			<span class="icon-[heroicons--arrow-path] w-3 h-3"></span>
			Syncing
		</div>
	}
}

// PlaylistSyncIndicator renders an inline indicator for table rows.
templ PlaylistSyncIndicator(syncToNavidrome bool, isNavidromeOwned bool) {
	if !isNavidromeOwned && syncToNavidrome {
		<span class="tooltip tooltip-left" data-tip="Syncing to Navidrome">
			<span class="icon-[heroicons--arrow-path] w-4 h-4 text-primary"></span>
		</span>
	}
}
