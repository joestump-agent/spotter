package components

import "encoding/json"

// ChartDataPoint is a single data point for a chart.
type ChartDataPoint struct {
	Label string
	Value float64
}

// StackedChartData is for creating stacked bar charts.
type StackedChartData struct {
	Labels   []string
	Datasets []ChartDataset
}

// ChartDataset is a single dataset within a chart.
type ChartDataset struct {
	Label           string
	Data            []float64
	BackgroundColor string
	BorderColor     string
}

func (d StackedChartData) ToJSON() (string, error) {
	b, err := json.Marshal(d)
	if err != nil {
		return "", err
	}
	return string(b), nil
}

func (d ChartDataPoint) ToJSON() (string, error) {
	b, err := json.Marshal(d)
	if err != nil {
		return "", err
	}
	return string(b), nil
}

// ExternalLinkBadge creates a badge that links to an external site.
templ ExternalLinkBadge(label, url, icon, badgeClass string) {
	<a href={ templ.URL(url) } target="_blank" rel="noopener noreferrer" class={ "badge badge-outline gap-1.5", badgeClass }>
		if icon != "" {
			<span class={ icon, "w-3.5", "h-3.5" }></span>
		}
		{ label }
		<span class="icon-[heroicons--arrow-up-right] w-3 h-3"></span>
	</a>
}

// MetadataRow is a single row in a metadata table.
type MetadataRow struct {
	Label string
	Value string
	Link  string
}

// MetadataTable renders a table of metadata rows.
templ MetadataTable(rows []MetadataRow) {
	<table class="table table-sm w-full">
		<tbody>
			for _, row := range rows {
				if row.Value != "" && row.Value != "N/A" && row.Value != "0" {
					<tr>
						<td class="w-1/3 text-base-content/60">{ row.Label }</td>
						<td class="font-medium">
							if row.Link != "" {
								<a href={ templ.URL(row.Link) } target="_blank" class="link link-hover">{ row.Value }</a>
							} else {
								{ row.Value }
							}
						</td>
					</tr>
				}
			}
		</tbody>
	</table>
}

// StatCard shows a single large statistic.
templ StatCard(title, value, subtitle, icon, colorClass string) {
	<div class="card bg-base-100 shadow-xl">
		<div class="card-body">
			<div class="flex items-center gap-4">
				<div class={ "flex-shrink-0 w-16 h-16 rounded-lg flex items-center justify-center bg-opacity-20", colorClass }>
					<span class={ icon, "w-8", "h-8" }></span>
				</div>
				<div class="flex-1 min-w-0">
					<div class="text-base-content/60 text-sm truncate">{ title }</div>
					<div class="text-3xl font-bold truncate">{ value }</div>
					if subtitle != "" {
						<div class="text-base-content/50 text-xs mt-1 truncate">{ subtitle }</div>
					}
				</div>
			</div>
		</div>
	</div>
}

// StatCardLink is a stat card that links to a page.
templ StatCardLink(title, value, subtitle, icon, colorClass, link string) {
	<a href={ templ.URL(link) } class="card bg-base-100 shadow-xl hover:bg-base-200 transition-colors">
		<div class="card-body">
			<div class="flex items-center gap-4">
				<div class={ "flex-shrink-0 w-16 h-16 rounded-lg flex items-center justify-center bg-opacity-20", colorClass }>
					<span class={ icon, "w-8", "h-8" }></span>
				</div>
				<div class="flex-1 min-w-0">
					<div class="text-base-content/60 text-sm truncate">{ title }</div>
					<div class="text-3xl font-bold truncate">{ value }</div>
					if subtitle != "" {
						<div class="text-base-content/50 text-xs mt-1 truncate">{ subtitle }</div>
					}
				</div>
			</div>
		</div>
	</a>
}

// ProviderIcon returns the icon class for a provider.
func ProviderIcon(provider string) string {
	switch provider {
	case "spotify":
		return "icon-[simple-icons--spotify]"
	case "navidrome":
		return "icon-[heroicons--musical-note]"
	case "lastfm":
		return "icon-[simple-icons--lastdotfm]"
	default:
		return "icon-[heroicons--question-mark-circle]"
	}
}

// ProviderBadgeClass returns the badge class for a provider.
func ProviderBadgeClass(provider string) string {
	switch provider {
	case "spotify":
		return "badge-success"
	case "navidrome":
		return "badge-info"
	case "lastfm":
		return "badge-error"
	default:
		return "badge-ghost"
	}
}

// TagBadges renders a list of tags as badges.
templ TagBadges(tags []string, badgeClass string) {
	<div class="flex flex-wrap gap-1.5">
		for _, tag := range tags {
			<span class={ "badge badge-sm", badgeClass }>{ tag }</span>
		}
	</div>
}

// AISummaryCard displays an AI-generated summary in a styled card with accent color theming.
templ AISummaryCard(summary string, title string) {
	if summary != "" {
		<div class="card bg-base-100 border-l-4 border-accent shadow-xl shadow-accent/10 mb-8">
			<div class="card-body">
				<h3 class="card-title">
					<span class="icon-[heroicons--sparkles] w-5 h-5 text-accent"></span>
					if title != "" {
						{ title }
					} else {
						AI Insights
					}
				</h3>
				<p class="text-base-content/80 leading-relaxed">
					{ summary }
				</p>
				<div class="flex items-center gap-1 mt-2">
					<span class="icon-[heroicons--sparkles] w-3 h-3 text-accent"></span>
					<span class="text-xs text-base-content/40">AI-generated content</span>
				</div>
			</div>
		</div>
	}
}
