package components

import (
	"fmt"
	"time"
)

func toastID() string {
	return fmt.Sprintf("toast-%d", time.Now().UnixNano())
}

script initToast(id string) {
	var toast = document.getElementById(id);
	if (!toast) return;

	// Click anywhere on toast to dismiss
	toast.onclick = function() {
		toast.style.opacity = '0';
		toast.style.transform = 'translateY(-8px)';
		setTimeout(function() {
			if (toast.parentNode) toast.remove();
		}, 300);
	};

	// Auto-dismiss after 5 seconds
	setTimeout(function() {
		if (toast && toast.parentNode) {
			toast.style.opacity = '0';
			toast.style.transform = 'translateY(-8px)';
			setTimeout(function() {
				if (toast.parentNode) toast.remove();
			}, 300);
		}
	}, 5000);
}

templ Toast(title, message, iconType string) {
	{{ id := toastID() }}
	<div
		id={ id }
		class={
			"alert shadow-lg toast-item pointer-events-auto cursor-pointer relative w-80 max-w-[calc(100vw-2rem)]",
			templ.KV("alert-success", iconType == "play" || iconType == "success"),
			templ.KV("alert-info", iconType == "playlist" || iconType == "info" || iconType == ""),
			templ.KV("alert-warning", iconType == "warning"),
			templ.KV("alert-error", iconType == "error"),
		}
		role="alert"
		style="transition: opacity 0.3s ease, transform 0.3s ease;"
	>
		<div class="flex gap-3 items-start flex-1 min-w-0 overflow-hidden">
			if iconType == "play" || iconType == "success" {
				<span class="icon-[heroicons--check-circle] w-6 h-6 flex-shrink-0"></span>
			} else if iconType == "playlist" {
				<span class="icon-[heroicons--queue-list] w-6 h-6 flex-shrink-0"></span>
			} else if iconType == "warning" {
				<span class="icon-[heroicons--exclamation-triangle] w-6 h-6 flex-shrink-0"></span>
			} else if iconType == "error" {
				<span class="icon-[heroicons--x-circle] w-6 h-6 flex-shrink-0"></span>
			} else {
				<span class="icon-[heroicons--information-circle] w-6 h-6 flex-shrink-0"></span>
			}
			<div class="flex-1 min-w-0 pr-4 overflow-hidden">
				<h3 class="font-bold truncate">{ title }</h3>
				<div class="text-sm break-words whitespace-normal overflow-wrap-anywhere">{ message }</div>
			</div>
		</div>
		<span class="icon-[heroicons--x-mark] w-4 h-4 absolute top-2 right-2 opacity-60 hover:opacity-100"></span>
	</div>
	@initToast(id)
}

// Governing: SPEC event-bus-sse REQ-SSE-012 (sse-swap="notification" with hx-swap for DOM swapping)
// Governing: SPEC vibes-ai-mixtape-engine, SPEC event-bus-sse REQ-SSE-005 — the SSE
// handler emits lifecycle events under their own named event types (mixtape-*,
// playlist-enhanc*, similar-artists-*) so future consumers can target them
// individually; the toast container subscribes to every toast-rendering event
// name so those toasts actually appear in the DOM. The htmx SSE extension
// accepts a comma-separated list of event names in sse-swap.
templ ToastContainer() {
	<div
		id="toasts"
		class="toast toast-end toast-top z-50 gap-2 mt-4 mr-4"
		sse-swap="notification,mixtape-created,mixtape-updated,mixtape-deleted,mixtape-generating,mixtape-generated,mixtape-error,playlist-enhancing,playlist-enhanced,playlist-enhance-error,similar-artists-searching,similar-artists-found,similar-artists-error"
		hx-swap="beforeend"
	></div>
}
