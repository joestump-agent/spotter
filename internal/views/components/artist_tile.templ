package components

import (
	"fmt"
	"spotter/ent"
)

func formatFollowers(count *int) string {
	if count == nil || *count == 0 {
		return ""
	}
	if *count >= 1000000 {
		return fmt.Sprintf("%.1fM", float64(*count)/1000000)
	}
	if *count >= 1000 {
		return fmt.Sprintf("%.1fK", float64(*count)/1000)
	}
	return fmt.Sprintf("%d", *count)
}

// ArtistTileOptions contains optional configuration for ArtistTile.
type ArtistTileOptions struct {
	// ShowAIBadge displays an AI badge if the artist is an AI-generated recommendation
	ShowAIBadge bool
	// Provider indicates the source of the recommendation (e.g., "OpenAI", "LastFM")
	Provider string
	// Reason is an optional explanation for why this artist is recommended
	Reason string
	// Confidence is the similarity confidence score (0.0 to 1.0)
	Confidence float64
}

// ArtistTile is a reusable component for displaying an artist card,
// styled like the tiles on the main library artists page.
templ ArtistTile(artist *ent.Artist) {
	@ArtistTileWithOptions(artist, ArtistTileOptions{})
}

// ArtistTileWithOptions is a reusable component for displaying an artist card
// with additional options like AI badge.
templ ArtistTileWithOptions(artist *ent.Artist, opts ArtistTileOptions) {
	<a href={ templ.URL(fmt.Sprintf("/library/artist/%d", artist.ID)) } class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all hover:scale-105 relative group">
		<figure class="aspect-square relative">
			@ArtistImage(artist, "w-full h-full object-cover")
			if opts.ShowAIBadge {
				<div class="absolute top-2 right-2">
					@AIBadge(opts.Provider)
				</div>
			}
		</figure>
		<div class="card-body p-4">
			<h3 class="card-title text-sm line-clamp-1">{ artist.Name }</h3>
			<p class="text-xs text-base-content/60 line-clamp-1">
				if len(artist.Genres) > 0 {
					{ artist.Genres[0] }
				} else {
					// Fallback text if artist has no genres
					"Artist"
				}
			</p>
			<div class="flex items-center justify-between mt-2">
				if followers := formatFollowers(artist.FollowerCount); followers != "" {
					<span class="text-xs text-base-content/50">{ followers } followers</span>
				} else {
					<!-- Empty span to maintain layout -->
					<span></span>
				}
				if artist.Popularity != nil && *artist.Popularity > 70 {
					<span class="badge badge-warning badge-xs">Popular</span>
				}
			</div>
			if opts.ShowAIBadge && opts.Reason != "" {
				<div class="text-xs text-base-content/50 mt-2 line-clamp-2 italic">
					"{ opts.Reason }"
				</div>
			}
		</div>
	</a>
}

// SimilarArtistTile is a compact tile specifically for displaying similar artists.
// It includes an AI badge and optional reason tooltip.
templ SimilarArtistTile(artist *ent.Artist, provider string, reason string, confidence float64) {
	<a
		href={ templ.URL(fmt.Sprintf("/library/artist/%d", artist.ID)) }
		class="card bg-base-100 shadow-lg hover:shadow-xl transition-all hover:scale-105 relative group"
		if reason != "" {
			title={ reason }
		}
	>
		<figure class="aspect-square relative">
			@ArtistImage(artist, "w-full h-full object-cover")
			<div class="absolute top-2 right-2">
				@AIBadge(provider)
			</div>
			if confidence > 0 {
				<div class="absolute bottom-2 left-2">
					@ConfidenceBadge(confidence)
				</div>
			}
		</figure>
		<div class="card-body p-3">
			<h3 class="card-title text-sm line-clamp-1">{ artist.Name }</h3>
			if len(artist.Genres) > 0 {
				<p class="text-xs text-base-content/60 line-clamp-1">{ artist.Genres[0] }</p>
			}
		</div>
		if reason != "" {
			<div class="absolute inset-0 bg-base-300/95 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex items-center justify-center p-4 rounded-2xl">
				<p class="text-xs text-center text-base-content/80 leading-relaxed">{ reason }</p>
			</div>
		}
	</a>
}

// AIBadge displays a small badge indicating AI-generated content.
templ AIBadge(provider string) {
	<div class="tooltip tooltip-left" data-tip={ aiProviderTooltip(provider) }>
		<span class="badge badge-accent badge-sm gap-1 shadow-md">
			<span class="icon-[heroicons--sparkles] w-3 h-3"></span>
			if provider != "" {
				{ provider }
			} else {
				AI
			}
		</span>
	</div>
}

// ConfidenceBadge displays a similarity confidence score.
templ ConfidenceBadge(confidence float64) {
	<span class={ "badge badge-xs shadow-md", confidenceBadgeClass(confidence) }>
		{ fmt.Sprintf("%.0f%%", confidence*100) }
	</span>
}

// aiProviderTooltip returns a tooltip string for the AI provider badge.
func aiProviderTooltip(provider string) string {
	switch provider {
	case "OpenAI":
		return "AI-powered recommendation"
	case "LastFM":
		return "Recommended by Last.fm"
	case "Spotify":
		return "Recommended by Spotify"
	default:
		if provider != "" {
			return fmt.Sprintf("Recommended by %s", provider)
		}
		return "AI-generated recommendation"
	}
}

// confidenceBadgeClass returns the appropriate badge class based on confidence score.
func confidenceBadgeClass(confidence float64) string {
	if confidence >= 0.9 {
		return "badge-success"
	} else if confidence >= 0.7 {
		return "badge-info"
	} else if confidence >= 0.5 {
		return "badge-warning"
	}
	return "badge-ghost"
}
