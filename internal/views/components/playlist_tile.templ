package components

import (
	"fmt"
	"spotter/ent"
)

// isNavidromePlaylist checks if the playlist source is navidrome
func isNavidromePlaylist(source string) bool {
	return source == "navidrome"
}

templ PlaylistTile(playlist *ent.Playlist, subtitle string) {
	<a href={ templ.URL(fmt.Sprintf("/playlists/%d", playlist.ID)) } class="card bg-base-100 shadow-md hover:shadow-xl transition-all hover:-translate-y-1">
		<figure class="relative pt-[100%]">
			if playlist.ImageURL != "" {
				<img src={ playlist.ImageURL } alt={ playlist.Name } class="absolute inset-0 w-full h-full object-cover"/>
			} else {
				<div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center">
					<span class="icon-[heroicons--queue-list] w-16 h-16 text-base-content/20"></span>
				</div>
			}
			// Sync status badge overlay
			@PlaylistSyncBadge(PlaylistSyncBadgeConfig{
				SyncToNavidrome:  playlist.SyncToNavidrome,
				IsNavidromeOwned: isNavidromePlaylist(playlist.Source),
				NavidromeID:      playlist.NavidromePlaylistID,
				MatchedTracks:    playlist.MatchedTrackCount,
				TotalTracks:      playlist.TrackCount,
				SyncError:        playlist.SyncError,
			})
		</figure>
		<div class="card-body p-3">
			<h4 class="font-semibold text-sm line-clamp-1">{ playlist.Name }</h4>
			<div class="text-xs text-base-content/60">
				<span>{ subtitle }</span>
			</div>
		</div>
	</a>
}
