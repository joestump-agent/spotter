package components

import "time"

// ProviderProps defines the properties for a provider tile.
// This struct configures how a music provider connection is displayed.
type ProviderProps struct {
	Name                   string
	Description            string
	IconClass              string
	IconColorClass         string // Tailwind class (e.g., text-success)
	IconColorStyle         string // Hex code if class not available
	ButtonClass            string // Tailwind class (e.g., btn-success)
	ButtonStyle            string // Custom style string
	IsConnected            bool
	DisplayName            string
	LastSyncedAt           time.Time
	ConnectURL             string
	SyncURL                string
	RebuildURL             string
	DisconnectURL          string
	ModalIDRebuild         string
	ModalIDDisconnect      string
	RebuildModalContent    templ.Component
	DisconnectModalContent templ.Component
}

// buildProviderDropdownConfig converts ProviderProps to ActionButtonDropdownConfig
func buildProviderDropdownConfig(props ProviderProps) ActionButtonDropdownConfig {
	// Build the actions list
	actions := []DropdownAction{
		{
			Label:      "Sync Now",
			IconClass:  "icon-[heroicons--arrow-path]",
			HtmxPost:   props.SyncURL,
			HtmxTarget: "#toasts",
			HtmxSwap:   "beforeend",
		},
		{
			Label:     "Rebuild Data",
			IconClass: "icon-[heroicons--trash]",
			IconColor: "text-warning",
			ModalID:   props.ModalIDRebuild,
		},
		{
			IsDivider: true,
		},
		{
			Label:     "Disconnect",
			IconClass: "icon-[heroicons--arrow-right-on-rectangle]",
			IconColor: "text-error",
			ModalID:   props.ModalIDDisconnect,
		},
	}

	// Build last action time pointer
	var lastActionAt *time.Time
	if !props.LastSyncedAt.IsZero() {
		lastActionAt = &props.LastSyncedAt
	}

	return ActionButtonDropdownConfig{
		ID:              props.Name + "-provider-dropdown",
		Label:           props.DisplayName,
		IconClass:       "icon-[heroicons--check-circle]",
		ButtonClass:     props.ButtonClass,
		ButtonStyle:     props.ButtonStyle,
		IsEnabled:       props.IsConnected,
		LastActionAt:    lastActionAt,
		LastActionLabel: "Last synced",
		Actions:         actions,
		EnableLabel:     "Connect " + props.Name,
		EnableIconClass: props.IconClass,
		EnableHref:      props.ConnectURL,
	}
}

templ ProviderTile(props ProviderProps) {
	<div class="card bg-base-100 shadow-xl h-full flex flex-col">
		<div class="card-body flex-1 flex flex-col">
			<h3 class="card-title">
				if props.IconColorStyle != "" {
					<span class={ props.IconClass + " w-6 h-6" } style={ "color: " + props.IconColorStyle + ";" }></span>
				} else {
					<span class={ props.IconClass + " w-6 h-6 " + props.IconColorClass }></span>
				}
				{ props.Name }
			</h3>
			<p class="text-base-content/60 text-sm mt-2 flex-grow">
				{ props.Description }
			</p>
			<div class="mt-4">
				if props.IsConnected {
					@providerConnectedState(props)
				} else {
					@providerDisconnectedState(props)
				}
			</div>
		</div>
	</div>
}

// providerConnectedState renders the connected state with dropdown
templ providerConnectedState(props ProviderProps) {
	<div>
		@ActionButtonDropdown(buildProviderDropdownConfig(props))
	</div>
	// Render Modals
	@props.RebuildModalContent
	@props.DisconnectModalContent
}

// providerDisconnectedState renders the disconnected state
templ providerDisconnectedState(props ProviderProps) {
	if props.ConnectURL != "" {
		if props.ButtonStyle != "" {
			<a href={ templ.SafeURL(props.ConnectURL) } class="btn w-full gap-2" style={ props.ButtonStyle }>
				<span class={ props.IconClass + " w-5 h-5" }></span>
				Connect { props.Name }
			</a>
		} else {
			<a href={ templ.SafeURL(props.ConnectURL) } class={ "btn w-full gap-2 " + props.ButtonClass }>
				<span class={ props.IconClass + " w-5 h-5" }></span>
				Connect { props.Name }
			</a>
		}
	} else {
		<div class="badge badge-ghost badge-lg gap-2 w-full">
			<span class="icon-[heroicons--x-circle] w-4 h-4"></span>
			Not Connected
		</div>
	}
}
