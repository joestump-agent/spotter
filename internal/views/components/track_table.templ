package components

import (
	"fmt"
	"spotter/ent"
	"strings"
	"time"
)

// TrackTableRow abstracts the data source for a row in the track table.
// It can be constructed from a Track, a Listen, or a combination.
type TrackTableRow struct {
	Track     *ent.Track
	Listen    *ent.Listen
	PlayCount int
	Index     int
	// Explicit values for when full entities aren't available
	ExplicitTrackName  string
	ExplicitArtistName string
	ExplicitAlbumName  string
	ExplicitDurationMs *int
	ExplicitImageURL   string
	ExplicitTrackID    int
	ExplicitArtistID   int
	ExplicitAlbumID    int
	// LidarrBaseURL is the base URL of the Lidarr instance (e.g. "http://lidarr:8686").
	// When set, the Lidarr status icon links to the album's page in Lidarr.
	LidarrBaseURL string
}

// Helper methods to extract display data from the row
func (r TrackTableRow) HasTrack() bool {
	return r.Track != nil || r.ExplicitTrackName != ""
}

func (r TrackTableRow) HasListen() bool {
	return r.Listen != nil
}

func (r TrackTableRow) TrackName() string {
	if r.ExplicitTrackName != "" {
		return r.ExplicitTrackName
	}
	if r.Track != nil {
		return r.Track.Name
	}
	if r.Listen != nil {
		return r.Listen.TrackName
	}
	return "Unknown Track"
}

func (r TrackTableRow) ArtistName() string {
	if r.ExplicitArtistName != "" {
		return r.ExplicitArtistName
	}
	if r.Track != nil && r.Track.Edges.Artist != nil {
		return r.Track.Edges.Artist.Name
	}
	if r.Listen != nil {
		return r.Listen.ArtistName
	}
	return "Unknown Artist"
}

func (r TrackTableRow) AlbumName() string {
	if r.ExplicitAlbumName != "" {
		return r.ExplicitAlbumName
	}
	if r.Track != nil && r.Track.Edges.Album != nil {
		return r.Track.Edges.Album.Name
	}
	if r.Listen != nil {
		return r.Listen.AlbumName
	}
	return "-"
}

func (r TrackTableRow) DurationMs() *int {
	if r.ExplicitDurationMs != nil {
		return r.ExplicitDurationMs
	}
	if r.Track != nil {
		return r.Track.DurationMs
	}
	if r.Listen != nil && r.Listen.Edges.Track != nil {
		return r.Listen.Edges.Track.DurationMs
	}
	return nil
}

func (r TrackTableRow) Popularity() *int {
	if r.Track != nil {
		return r.Track.Popularity
	}
	if r.Listen != nil && r.Listen.Edges.Track != nil {
		return r.Listen.Edges.Track.Popularity
	}
	return nil
}

func (r TrackTableRow) ImageURL() string {
	if r.ExplicitImageURL != "" {
		return r.ExplicitImageURL
	}
	var albumEdge *ent.Album
	if r.Track != nil && r.Track.Edges.Album != nil {
		albumEdge = r.Track.Edges.Album
	} else if r.Listen != nil && r.Listen.Edges.Album != nil {
		albumEdge = r.Listen.Edges.Album
	}
	if albumEdge != nil && len(albumEdge.Edges.Images) > 0 {
		return fmt.Sprintf("/library/album/%d.png", albumEdge.ID)
	}
	return ""
}

func (r TrackTableRow) TrackURL() string {
	if r.ExplicitTrackID > 0 {
		return fmt.Sprintf("/library/track/%d", r.ExplicitTrackID)
	}
	if r.Track != nil {
		return fmt.Sprintf("/library/track/%d", r.Track.ID)
	}
	if r.Listen != nil && r.Listen.Edges.Track != nil {
		return fmt.Sprintf("/library/track/%d", r.Listen.Edges.Track.ID)
	}
	return ""
}

func (r TrackTableRow) ArtistURL() string {
	if r.ExplicitArtistID > 0 {
		return fmt.Sprintf("/library/artist/%d", r.ExplicitArtistID)
	}
	if r.Track != nil && r.Track.Edges.Artist != nil {
		return fmt.Sprintf("/library/artist/%d", r.Track.Edges.Artist.ID)
	}
	if r.Listen != nil && r.Listen.Edges.Artist != nil {
		return fmt.Sprintf("/library/artist/%d", r.Listen.Edges.Artist.ID)
	}
	return ""
}

func (r TrackTableRow) AlbumURL() string {
	if r.ExplicitAlbumID > 0 {
		return fmt.Sprintf("/library/album/%d", r.ExplicitAlbumID)
	}
	if r.Track != nil && r.Track.Edges.Album != nil {
		return fmt.Sprintf("/library/album/%d", r.Track.Edges.Album.ID)
	}
	if r.Listen != nil && r.Listen.Edges.Album != nil {
		return fmt.Sprintf("/library/album/%d", r.Listen.Edges.Album.ID)
	}
	return ""
}

func (r TrackTableRow) SourceValue() string {
	if r.Listen != nil {
		return r.Listen.Source
	}
	return ""
}

func (r TrackTableRow) PlayedAtValue() string {
	if r.Listen != nil {
		return fmt.Sprintf("%d", r.Listen.PlayedAt.Unix())
	}
	return "0"
}

func (r TrackTableRow) DurationValue() string {
	if ms := r.DurationMs(); ms != nil {
		return fmt.Sprintf("%d", *ms)
	}
	return "0"
}

func (r TrackTableRow) PopularityValue() string {
	if pop := r.Popularity(); pop != nil {
		return fmt.Sprintf("%d", *pop)
	}
	return "0"
}

func (r TrackTableRow) Album() *ent.Album {
	if r.Track != nil && r.Track.Edges.Album != nil {
		return r.Track.Edges.Album
	}
	if r.Listen != nil && r.Listen.Edges.Album != nil {
		return r.Listen.Edges.Album
	}
	return nil
}

func (r TrackTableRow) LidarrStatus() string {
	var track *ent.Track
	if r.Track != nil {
		track = r.Track
	} else if r.Listen != nil && r.Listen.Edges.Track != nil {
		track = r.Listen.Edges.Track
	}
	if track == nil || track.LidarrStatus == nil {
		return ""
	}
	return *track.LidarrStatus
}

// LidarrAlbumURL returns the Lidarr deep link URL for the artist page.
// Lidarr's web UI routes artists by their foreignArtistId (= MusicBrainz artist ID),
// e.g. /artist/1964494f-9f1a-41c1-b054-80ef3b95025c.
// We confirm the artist is tracked in Lidarr (LidarrID set) before building the link.
func (r TrackTableRow) LidarrAlbumURL() string {
	if r.LidarrBaseURL == "" {
		return ""
	}
	var artist *ent.Artist
	if r.Track != nil && r.Track.Edges.Artist != nil {
		artist = r.Track.Edges.Artist
	} else if r.Listen != nil && r.Listen.Edges.Artist != nil {
		artist = r.Listen.Edges.Artist
	}
	if artist == nil || artist.LidarrID == "" || artist.MusicbrainzID == "" {
		return ""
	}
	return fmt.Sprintf("%s/artist/%s", r.LidarrBaseURL, artist.MusicbrainzID)
}

func formatDuration(ms *int) string {
	if ms == nil || *ms <= 0 {
		return "-"
	}
	seconds := *ms / 1000
	minutes := seconds / 60
	secs := seconds % 60
	return fmt.Sprintf("%d:%02d", minutes, secs)
}

func contains(slice []string, item string) bool {
	for _, s := range slice {
		if s == item {
			return true
		}
	}
	return false
}

func getHiddenClass(cols []string, col string) string {
	if !contains(cols, col) {
		return "hidden"
	}
	return ""
}

// SortConfig holds the current sort state for the table
type SortConfig struct {
	Column    string // Current sort column
	Direction string // "asc" or "desc"
	BaseURL   string // Base URL for building sort links (e.g., "/recent", "/library/tracks")
}

func buildSortURL(baseURL, column, currentCol, currentDir string) string {
	// If clicking the same column, toggle direction; otherwise default to desc
	newDir := "desc"
	if column == currentCol && currentDir == "desc" {
		newDir = "asc"
	}

	// Preserve any existing query params (like page, artist filter)
	if strings.Contains(baseURL, "?") {
		return fmt.Sprintf("%s&sort=%s&dir=%s", baseURL, column, newDir)
	}
	return fmt.Sprintf("%s?sort=%s&dir=%s", baseURL, column, newDir)
}

func sortIndicator(column, currentCol, currentDir string) string {
	if column != currentCol {
		return ""
	}
	if currentDir == "asc" {
		return " ↑"
	}
	return " ↓"
}

// TrackTable renders a table of tracks with toggleable columns.
// initialColumns specifies which columns are visible by default.
// Available columns: "#", "source", "played_at", "track", "artist", "album", "duration", "popularity", "plays"
templ TrackTable(tableID string, rows []TrackTableRow, initialColumns []string, tbodyAttrs templ.Attributes, sort SortConfig) {
	<div class="track-table-component" data-initial-columns={ strings.Join(initialColumns, ",") }>
		<div class="overflow-x-auto">
			<table class="table table-zebra w-full" id={ tableID }>
				<thead>
					<tr>
						<th class={ "col-index w-12", getHiddenClass(initialColumns, "#") }>#</th>
						<th class={ "col-source cursor-pointer hover:bg-base-200", getHiddenClass(initialColumns, "source") }>
							<a href={ templ.URL(buildSortURL(sort.BaseURL, "source", sort.Column, sort.Direction)) } class="flex items-center gap-1">
								Source{ sortIndicator("source", sort.Column, sort.Direction) }
							</a>
						</th>
						<th class={ "col-played_at cursor-pointer hover:bg-base-200", getHiddenClass(initialColumns, "played_at") }>
							<a href={ templ.URL(buildSortURL(sort.BaseURL, "played_at", sort.Column, sort.Direction)) } class="flex items-center gap-1">
								Played At{ sortIndicator("played_at", sort.Column, sort.Direction) }
							</a>
						</th>
						<th class={ "col-track cursor-pointer hover:bg-base-200", getHiddenClass(initialColumns, "track") }>
							<a href={ templ.URL(buildSortURL(sort.BaseURL, "track", sort.Column, sort.Direction)) } class="flex items-center gap-1">
								Track{ sortIndicator("track", sort.Column, sort.Direction) }
							</a>
						</th>
						<th class={ "col-artist cursor-pointer hover:bg-base-200", getHiddenClass(initialColumns, "artist") }>
							<a href={ templ.URL(buildSortURL(sort.BaseURL, "artist", sort.Column, sort.Direction)) } class="flex items-center gap-1">
								Artist{ sortIndicator("artist", sort.Column, sort.Direction) }
							</a>
						</th>
						<th class={ "col-album cursor-pointer hover:bg-base-200", getHiddenClass(initialColumns, "album") }>
							<a href={ templ.URL(buildSortURL(sort.BaseURL, "album", sort.Column, sort.Direction)) } class="flex items-center gap-1">
								Album{ sortIndicator("album", sort.Column, sort.Direction) }
							</a>
						</th>
						<th class={ "col-duration cursor-pointer hover:bg-base-200", getHiddenClass(initialColumns, "duration") }>
							<a href={ templ.URL(buildSortURL(sort.BaseURL, "duration", sort.Column, sort.Direction)) } class="flex items-center gap-1">
								Duration{ sortIndicator("duration", sort.Column, sort.Direction) }
							</a>
						</th>
						<th class={ "col-popularity cursor-pointer hover:bg-base-200", getHiddenClass(initialColumns, "popularity") }>
							<a href={ templ.URL(buildSortURL(sort.BaseURL, "popularity", sort.Column, sort.Direction)) } class="flex items-center gap-1">
								Popularity{ sortIndicator("popularity", sort.Column, sort.Direction) }
							</a>
						</th>
						<th class={ "col-plays text-right cursor-pointer hover:bg-base-200", getHiddenClass(initialColumns, "plays") }>
							<a href={ templ.URL(buildSortURL(sort.BaseURL, "plays", sort.Column, sort.Direction)) } class="flex items-center gap-1 justify-end">
								Plays{ sortIndicator("plays", sort.Column, sort.Direction) }
							</a>
						</th>
					</tr>
				</thead>
				<tbody { tbodyAttrs... }>
					for i, row := range rows {
						@TrackTableRowRender(row, initialColumns, i+1)
					}
				</tbody>
			</table>
		</div>
	</div>
}

templ TrackTableRowRender(row TrackTableRow, initialColumns []string, index int) {
	<tr class="hover">
		<td class={ "col-index text-base-content/50", getHiddenClass(initialColumns, "#") } data-value={ fmt.Sprintf("%d", index) }>
			if row.Index > 0 {
				{ fmt.Sprintf("%d", row.Index) }
			} else {
				{ fmt.Sprintf("%d", index) }
			}
		</td>
		<td class={ "col-source", getHiddenClass(initialColumns, "source") } data-value={ row.SourceValue() }>
			if row.Listen != nil {
				if row.Listen.Source == "spotify" {
					<div class="badge badge-success gap-2">
						<span class="icon-[simple-icons--spotify] w-3 h-3"></span>
						Spotify
					</div>
				} else if row.Listen.Source == "navidrome" {
					<div class="badge badge-primary gap-2">
						<span class="icon-[heroicons--musical-note] w-3 h-3"></span>
						Navidrome
					</div>
				} else if row.Listen.Source == "lastfm" {
					<div class="badge badge-error gap-2">
						<span class="icon-[simple-icons--lastdotfm] w-3 h-3"></span>
						Last.fm
					</div>
				} else {
					<div class="badge badge-ghost">{ row.Listen.Source }</div>
				}
			} else {
				<span class="text-base-content/30">-</span>
			}
		</td>
		<td class={ "col-played_at whitespace-nowrap", getHiddenClass(initialColumns, "played_at") } data-value={ row.PlayedAtValue() }>
			if row.Listen != nil {
				<time class="text-sm text-base-content/60" datetime={ row.Listen.PlayedAt.Format(time.RFC3339) } title={ row.Listen.PlayedAt.Local().Format(time.RFC822) }>
					{ row.Listen.PlayedAt.Local().Format("Jan 02, 3:04 PM") }
				</time>
			} else {
				<span class="text-base-content/30">-</span>
			}
		</td>
		<td class={ "col-track", getHiddenClass(initialColumns, "track") } data-value={ row.TrackName() }>
			<div class="flex items-center gap-3">
				<div class="avatar track-artwork">
					<figure class="w-10 h-10 rounded">
						if album := row.Album(); album != nil {
							@AlbumImage(album, "w-full h-full")
						} else {
							<div class="bg-base-300 w-full h-full flex items-center justify-center">
								<span class="icon-[heroicons--musical-note] w-1/2 h-1/2 text-base-content/40"></span>
							</div>
						}
					</figure>
				</div>
				<div class="flex items-center">
					<div class="min-w-0 max-w-xs">
						if url := row.TrackURL(); url != "" {
							<p class="font-medium hover:text-primary hover:underline truncate" title={ row.TrackName() }>
								<a href={ templ.URL(url) }>{ row.TrackName() }</a>
							</p>
						} else {
							<p class="font-medium text-base-content/60 truncate" title={ row.TrackName() }>{ row.TrackName() }</p>
						}
					</div>
					<div class="flex items-center flex-shrink-0 ml-1.5">
						// AI Tags Hint
						if (row.Track != nil && len(row.Track.AiTags) > 0) || (row.Listen != nil && row.Listen.Edges.Track != nil && len(row.Listen.Edges.Track.AiTags) > 0) {
							<div class="tooltip" data-tip="Has AI Insights">
								<span class="icon-[heroicons--sparkles] w-4 h-4 text-accent"></span>
							</div>
						}
						// Matched Metadata Hint
						if row.Track != nil || (row.Listen != nil && row.Listen.Edges.Track != nil) {
							<div class="tooltip" data-tip="Matched with metadata">
								<span class="icon-[heroicons--check-circle-solid] w-4 h-4 text-success ml-1.5"></span>
							</div>
						} else if row.Listen != nil {
							<div class="tooltip" data-tip="Not yet matched">
								<span class="icon-[heroicons--question-mark-circle] w-4 h-4 text-base-content/30 ml-1.5"></span>
							</div>
						}
					</div>
				</div>
			</div>
		</td>
		<td class={ "col-artist", getHiddenClass(initialColumns, "artist") } data-value={ row.ArtistName() }>
			<div class="flex items-center gap-1.5 max-w-xs">
				<div class="min-w-0 max-w-xs">
					if url := row.ArtistURL(); url != "" {
						<p class="text-base-content/70 hover:text-primary hover:underline truncate" title={ row.ArtistName() }>
							<a href={ templ.URL(url) }>{ row.ArtistName() }</a>
						</p>
					} else {
						<p class="text-base-content/50 truncate" title={ row.ArtistName() }>{ row.ArtistName() }</p>
					}
				</div>
				<div class="flex items-center flex-shrink-0 ml-1.5">
					// AI Tags Hint
					if row.Track != nil && row.Track.Edges.Artist != nil && len(row.Track.Edges.Artist.AiTags) > 0 {
						<div class="tooltip" data-tip="Has AI Insights">
							<span class="icon-[heroicons--sparkles] w-4 h-4 text-accent"></span>
						</div>
					}
					// Matched Artist Hint
					if (row.Track != nil && row.Track.Edges.Artist != nil) || (row.Listen != nil && row.Listen.Edges.Artist != nil) {
						<div class="tooltip" data-tip="Matched with metadata">
							<span class="icon-[heroicons--check-circle-solid] w-4 h-4 text-success ml-1.5"></span>
						</div>
					} else if row.Listen != nil {
						<div class="tooltip" data-tip="Not yet matched">
							<span class="icon-[heroicons--question-mark-circle] w-4 h-4 text-base-content/30"></span>
						</div>
					}
				</div>
			</div>
		</td>
		<td class={ "col-album", getHiddenClass(initialColumns, "album") } data-value={ row.AlbumName() }>
			<div class="flex items-center gap-1.5 max-w-xs">
				<div class="min-w-0 max-w-xs">
					if url := row.AlbumURL(); url != "" {
						<p class="text-base-content/60 hover:text-secondary hover:underline truncate" title={ row.AlbumName() }>
							<a href={ templ.URL(url) }>{ row.AlbumName() }</a>
						</p>
					} else {
						<p class="text-base-content/50 truncate" title={ row.AlbumName() }>{ row.AlbumName() }</p>
					}
				</div>
				<div class="flex items-center flex-shrink-0 ml-1.5">
					// AI Tags Hint
					if row.Track != nil && row.Track.Edges.Album != nil && len(row.Track.Edges.Album.AiTags) > 0 {
						<div class="tooltip" data-tip="Has AI Insights">
							<span class="icon-[heroicons--sparkles] w-4 h-4 text-accent"></span>
						</div>
					}
					// Matched Album Hint
					if (row.Track != nil && row.Track.Edges.Album != nil) || (row.Listen != nil && row.Listen.Edges.Album != nil) {
						<div class="tooltip" data-tip="Matched with metadata">
							<span class="icon-[heroicons--check-circle-solid] w-4 h-4 text-success ml-1.5"></span>
						</div>
					} else if row.Listen != nil {
						<div class="tooltip" data-tip="Not yet matched">
							<span class="icon-[heroicons--question-mark-circle] w-4 h-4 text-base-content/30"></span>
						</div>
					}
					// Lidarr Status (album-level, links to Lidarr album page)
					if row.LidarrStatus() != "" {
						@LidarrStatus(row.LidarrStatus(), row.LidarrAlbumURL())
					}
				</div>
			</div>
		</td>
		<td class={ "col-duration font-mono text-sm", getHiddenClass(initialColumns, "duration") } data-value={ row.DurationValue() }>
			{ formatDuration(row.DurationMs()) }
		</td>
		<td class={ "col-popularity", getHiddenClass(initialColumns, "popularity") } data-value={ row.PopularityValue() }>
			if pop := row.Popularity(); pop != nil && *pop > 0 {
				<div class="flex items-center gap-2">
					<progress class="progress progress-primary w-16" value={ fmt.Sprintf("%d", *pop) } max="100"></progress>
					<span class="text-xs text-base-content/60">{ fmt.Sprintf("%d", *pop) }</span>
				</div>
			} else {
				<span class="text-base-content/50">-</span>
			}
		</td>
		<td class={ "col-plays text-right font-mono", getHiddenClass(initialColumns, "plays") } data-value={ fmt.Sprintf("%d", row.PlayCount) }>
			if row.PlayCount > 0 {
				{ fmt.Sprintf("%d", row.PlayCount) }
			} else {
				<span class="text-base-content/30">-</span>
			}
		</td>
	</tr>
}
