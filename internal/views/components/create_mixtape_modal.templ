package components

import (
	"fmt"
	"spotter/ent"
)

// MixtapeSeedType defines the type of entity used to seed a mixtape.
type MixtapeSeedType string

const (
	SeedArtist MixtapeSeedType = "artist"
	SeedAlbum  MixtapeSeedType = "album"
)

// CreateMixtapeParams holds the data needed to render the mixtape creation modal.
type CreateMixtapeParams struct {
	SeedType MixtapeSeedType
	SeedID   int
	SeedName string
	DJs      []*ent.DJ
}

// CreateMixtapeModal provides an empty dialog shell for HTMX to target.
templ CreateMixtapeModal() {
	<dialog id="create-mixtape-modal" class="modal"></dialog>
}

// CreateMixtapeModalContent renders the inner content of the mixtape modal.
templ CreateMixtapeModalContent(params CreateMixtapeParams) {
	<div class="modal-box">
		<form method="dialog">
			<button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
		</form>
		<h3 class="font-bold text-lg flex items-center gap-2">
			<span class="icon-[heroicons--musical-note] w-5 h-5 text-primary"></span>
			Create Mixtape from { params.SeedName }
		</h3>
		<p class="text-sm text-base-content/60 py-2">
			Generate a mixtape inspired by this { string(params.SeedType) } using AI.
		</p>
		<form
			hx-post={ fmt.Sprintf("/library/%s/%d/create-mixtape", params.SeedType, params.SeedID) }
			hx-swap="none"
			_="on htmx:afterRequest if this.closest('dialog') this.closest('dialog').close()"
		>
			<div class="form-control mb-4">
				<label class="label">
					<span class="label-text">Mixtape Name</span>
				</label>
				<input
					type="text"
					name="name"
					class="input input-bordered"
					placeholder={ params.SeedName + " Mix" }
				/>
			</div>
			<div class="form-control mb-4">
				<label class="label">
					<span class="label-text">
						DJ Persona
						<span class="text-error">*</span>
					</span>
				</label>
				<select name="dj_id" class="select select-bordered w-full" required>
					<option value="" disabled selected>Select a DJ</option>
					for _, d := range params.DJs {
						<option value={ fmt.Sprintf("%d", d.ID) }>{ d.Name }</option>
					}
				</select>
				<label class="label">
					<span class="label-text-alt">The DJ's personality will influence track selection</span>
				</label>
			</div>
			<div class="form-control mb-4">
				<label class="label">
					<span class="label-text">Number of Tracks</span>
				</label>
				<input
					type="number"
					name="max_tracks"
					class="input input-bordered"
					min="5"
					max="100"
					value="25"
				/>
			</div>
			<div class="modal-action">
				<button type="button" class="btn btn-ghost" onclick="this.closest('dialog').close()">Cancel</button>
				<button type="submit" class="btn btn-primary gap-2">
					<span class="icon-[heroicons--sparkles] w-4 h-4"></span>
					Create Mixtape
				</button>
			</div>
		</form>
	</div>
	<form method="dialog" class="modal-backdrop">
		<button>close</button>
	</form>
}
