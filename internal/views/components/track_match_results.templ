package components

import "fmt"

// TrackMatchDisplayConfig defines the configuration for track match result components.
type TrackMatchDisplayConfig struct {
	TotalTracks     int
	MatchedTracks   int
	UnmatchedTracks []UnmatchedTrackInfo
}

// UnmatchedTrackInfo contains information about a track that couldn't be matched.
type UnmatchedTrackInfo struct {
	Name   string
	Artist string
	Album  string
	Reason string // e.g., "Not in library", "Multiple matches", "Low confidence"
}

// getMatchPercentageForTracks calculates the match percentage
func getMatchPercentageForTracks(matched, total int) int {
	if total == 0 {
		return 0
	}
	return int(float64(matched) / float64(total) * 100)
}

// TrackMatchSummary renders a compact summary of track matching results.
// Shows matched/unmatched counts with a progress indicator.
templ TrackMatchSummary(config TrackMatchDisplayConfig) {
	<div class="flex items-center gap-4">
		<!-- Match Stats -->
		<div class="flex items-center gap-2">
			<span class="icon-[heroicons--check-circle] w-5 h-5 text-success"></span>
			<span class="text-sm font-medium">
				{ fmt.Sprintf("%d/%d", config.MatchedTracks, config.TotalTracks) } tracks matched
			</span>
		</div>
		<!-- Percentage Badge -->
		if config.TotalTracks > 0 {
			<span class={ "badge badge-sm", templ.KV("badge-success", getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks) >= 80), templ.KV("badge-warning", getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks) >= 50 && getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks) < 80), templ.KV("badge-error", getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks) < 50) }>
				{ fmt.Sprintf("%d%%", getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks)) }
			</span>
		}
		<!-- Unmatched Count -->
		if len(config.UnmatchedTracks) > 0 {
			<span class="text-sm text-warning">
				{ fmt.Sprintf("%d unmatched", len(config.UnmatchedTracks)) }
			</span>
		}
	</div>
}

// TrackMatchDetails renders a detailed expandable list of match results.
// Shows all unmatched tracks with their reasons.
templ TrackMatchDetails(config TrackMatchDisplayConfig) {
	<div class="card bg-base-100 shadow-lg">
		<div class="card-body">
			<div class="flex items-center justify-between">
				<h3 class="card-title text-base">
					<span class="icon-[heroicons--musical-note] w-5 h-5 text-primary"></span>
					Track Matching Results
				</h3>
				@TrackMatchSummary(config)
			</div>
			<!-- Progress Bar -->
			if config.TotalTracks > 0 {
				<div class="mt-4">
					<progress
						class={ "progress w-full", templ.KV("progress-success", getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks) >= 80), templ.KV("progress-warning", getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks) >= 50 && getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks) < 80), templ.KV("progress-error", getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks) < 50) }
						value={ fmt.Sprintf("%d", config.MatchedTracks) }
						max={ fmt.Sprintf("%d", config.TotalTracks) }
					></progress>
				</div>
			}
			<!-- Unmatched Tracks List -->
			if len(config.UnmatchedTracks) > 0 {
				<div class="divider my-3"></div>
				<div class="collapse collapse-arrow bg-base-200 rounded-lg">
					<input type="checkbox" aria-label="Toggle Unmatched Tracks section"/>
					<div class="collapse-title font-medium flex items-center gap-2">
						<span class="icon-[heroicons--exclamation-triangle] w-5 h-5 text-warning"></span>
						{ fmt.Sprintf("Unmatched Tracks (%d)", len(config.UnmatchedTracks)) }
					</div>
					<div class="collapse-content">
						<div class="overflow-x-auto">
							<table class="table table-sm">
								<thead>
									<tr>
										<th>Track</th>
										<th>Artist</th>
										<th>Album</th>
										<th>Reason</th>
									</tr>
								</thead>
								<tbody>
									for _, track := range config.UnmatchedTracks {
										<tr class="hover">
											<td class="font-medium">{ track.Name }</td>
											<td class="text-base-content/70">{ track.Artist }</td>
											<td class="text-base-content/70">
												if track.Album != "" {
													{ track.Album }
												} else {
													<span class="text-base-content/40">—</span>
												}
											</td>
											<td>
												<span class="badge badge-ghost badge-sm">
													if track.Reason != "" {
														{ track.Reason }
													} else {
														Not in library
													}
												</span>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				</div>
			} else if config.TotalTracks > 0 {
				<div class="alert alert-success mt-4">
					<span class="icon-[heroicons--check-circle] w-5 h-5"></span>
					<span>All tracks were successfully matched to your Navidrome library!</span>
				</div>
			}
		</div>
	</div>
}

// TrackMatchCompact renders a compact inline version suitable for cards or list items.
templ TrackMatchCompact(config TrackMatchDisplayConfig) {
	<div class="flex items-center gap-2 text-sm">
		if config.TotalTracks > 0 {
			<div class="radial-progress text-primary text-xs" style={ fmt.Sprintf("--value:%d; --size:2rem;", getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks)) } role="progressbar">
				{ fmt.Sprintf("%d%%", getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks)) }
			</div>
			<div class="flex flex-col">
				<span class="font-medium">{ fmt.Sprintf("%d/%d", config.MatchedTracks, config.TotalTracks) }</span>
				<span class="text-xs text-base-content/60">tracks matched</span>
			</div>
		} else {
			<span class="text-base-content/60">No tracks</span>
		}
	</div>
}

// TrackMatchAlert renders an alert-style notification about match results.
// Suitable for displaying after a sync operation.
templ TrackMatchAlert(config TrackMatchDisplayConfig, showDetails bool) {
	if config.TotalTracks > 0 {
		if len(config.UnmatchedTracks) == 0 {
			<div class="alert alert-success">
				<span class="icon-[heroicons--check-circle] w-6 h-6"></span>
				<div>
					<h4 class="font-bold">Sync Complete</h4>
					<p class="text-sm">All { fmt.Sprintf("%d", config.TotalTracks) } tracks were matched to your library.</p>
				</div>
			</div>
		} else if getMatchPercentageForTracks(config.MatchedTracks, config.TotalTracks) >= 50 {
			<div class="alert alert-warning">
				<span class="icon-[heroicons--exclamation-triangle] w-6 h-6"></span>
				<div>
					<h4 class="font-bold">Sync Complete with Missing Tracks</h4>
					<p class="text-sm">
						{ fmt.Sprintf("%d of %d", config.MatchedTracks, config.TotalTracks) } tracks matched.
						{ fmt.Sprintf("%d", len(config.UnmatchedTracks)) } tracks are not in your library.
					</p>
					if showDetails && len(config.UnmatchedTracks) <= 5 {
						<ul class="mt-2 text-xs list-disc list-inside">
							for _, track := range config.UnmatchedTracks {
								<li>{ track.Artist } - { track.Name }</li>
							}
						</ul>
					}
				</div>
			</div>
		} else {
			<div class="alert alert-error">
				<span class="icon-[heroicons--x-circle] w-6 h-6"></span>
				<div>
					<h4 class="font-bold">Low Match Rate</h4>
					<p class="text-sm">
						Only { fmt.Sprintf("%d of %d", config.MatchedTracks, config.TotalTracks) } tracks matched.
						Many tracks may be missing from your library.
					</p>
				</div>
			</div>
		}
	}
}
