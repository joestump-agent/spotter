package vibes

import (
	"fmt"
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/layouts"
	"time"
)

func formatMixtapeTime(t time.Time) string {
	return t.Local().Format("Jan 02, 2006 at 3:04 PM")
}

func formatMixtapeTimeISO(t time.Time) string {
	return t.UTC().Format(time.RFC3339)
}

func scheduleLabel(schedule string) string {
	switch schedule {
	case "daily":
		return "Daily"
	case "weekly":
		return "Weekly"
	case "monthly":
		return "Monthly"
	default:
		return "Manual"
	}
}

templ scheduleBadge(schedule string) {
	switch schedule {
		case "daily":
			<div class="badge badge-info gap-1">
				<span class="icon-[heroicons--arrow-path] w-3 h-3"></span>
				Daily
			</div>
		case "weekly":
			<div class="badge badge-info gap-1">
				<span class="icon-[heroicons--arrow-path] w-3 h-3"></span>
				Weekly
			</div>
		case "monthly":
			<div class="badge badge-info gap-1">
				<span class="icon-[heroicons--arrow-path] w-3 h-3"></span>
				Monthly
			</div>
		default:
			<div class="badge badge-ghost gap-1">
				<span class="icon-[heroicons--hand-raised] w-3 h-3"></span>
				Manual
			</div>
	}
}

templ MixtapesIndex(mixtapes []*ent.Mixtape, djs []*ent.DJ, currentPage int, totalPages int, cfg *config.Config) {
	@layouts.Dashboard("Mixtapes | Vibes | Spotter", cfg, "/vibes/mixtapes") {
		<div class="max-w-7xl mx-auto">
			<div class="flex items-center justify-between mb-8">
				<div>
					<h2 class="text-3xl font-bold">Mixtapes</h2>
					<p class="text-base-content/60 mt-2">AI-generated playlists powered by your DJs</p>
				</div>
				if len(mixtapes) > 0 {
					<div class="flex items-center gap-4">
						<!-- View Toggle -->
						<div class="join">
							<button
								id="table-view-btn"
								class="join-item btn btn-sm btn-square"
								onclick="setView('table')"
								title="Table view"
							>
								<span class="icon-[heroicons--table-cells] w-4 h-4"></span>
							</button>
							<button
								id="tile-view-btn"
								class="join-item btn btn-sm btn-square btn-active"
								onclick="setView('tile')"
								title="Tile view"
							>
								<span class="icon-[heroicons--squares-2x2] w-4 h-4"></span>
							</button>
						</div>
						if len(djs) > 0 {
							<button
								class="btn btn-primary gap-2"
								onclick="document.getElementById('create-mixtape-modal').showModal()"
							>
								<span class="icon-[heroicons--plus] w-5 h-5"></span>
								Create Mixtape
							</button>
						} else {
							<div class="tooltip tooltip-left" data-tip="Create a DJ first">
								<button class="btn btn-primary gap-2" disabled>
									<span class="icon-[heroicons--plus] w-5 h-5"></span>
									Create Mixtape
								</button>
							</div>
						}
					</div>
				}
			</div>
			if len(mixtapes) == 0 {
				<div class="card bg-base-200">
					<div class="card-body items-center text-center">
						<span class="icon-[heroicons--musical-note] w-16 h-16 text-base-content/30"></span>
						<h3 class="card-title">No mixtapes yet</h3>
						if len(djs) == 0 {
							<p class="text-base-content/60">Create a DJ first, then come back to create mixtapes.</p>
							<a href="/vibes/djs" class="btn btn-primary mt-4">
								Create a DJ
							</a>
						} else {
							<p class="text-base-content/60">Create a mixtape and let your DJs curate the perfect playlist.</p>
							<button
								class="btn btn-primary mt-4"
								onclick="document.getElementById('create-mixtape-modal').showModal()"
							>
								Create Your First Mixtape
							</button>
						}
					</div>
				</div>
			} else {
				<!-- Table View -->
				<div id="table-view" class="hidden card bg-base-100 shadow-xl">
					<div class="card-body p-0">
						<div class="overflow-x-auto">
							<table class="table table-zebra">
								<thead>
									<tr>
										<th class="w-12"></th>
										<th>Name</th>
										<th>DJ</th>
										<th>Tracks</th>
										<th>Schedule</th>
										<th>Navidrome</th>
										<th>Last Generated</th>
										<th class="w-12"></th>
									</tr>
								</thead>
								<tbody>
									for _, m := range mixtapes {
										<tr class="hover">
											<td>
												<div class="avatar">
													<div class="w-10 h-10 rounded">
														if m.ImageURL != "" {
															<img src={ m.ImageURL } alt={ m.Name }/>
														} else {
															<div class="bg-gradient-to-br from-primary to-secondary w-full h-full flex items-center justify-center">
																<span class="icon-[heroicons--musical-note] w-5 h-5 text-white"></span>
															</div>
														}
													</div>
												</div>
											</td>
											<td>
												<a href={ templ.URL(fmt.Sprintf("/vibes/mixtapes/%d", m.ID)) } class="font-medium link link-hover link-primary">
													{ m.Name }
												</a>
												if m.Description != "" {
													<div class="text-sm text-base-content/60 max-w-md truncate">
														{ m.Description }
													</div>
												}
											</td>
											<td>
												if m.Edges.Dj != nil {
													<span class="badge badge-outline">{ m.Edges.Dj.Name }</span>
												}
											</td>
											<td>
												<div class="text-sm font-medium">{ fmt.Sprintf("%d", m.TrackCount) }</div>
											</td>
											<td>
												@scheduleBadge(string(m.Schedule))
											</td>
											<td>
												<label class="swap">
													<input
														type="checkbox"
														checked?={ m.SyncToNavidrome }
														hx-post={ fmt.Sprintf("/vibes/mixtapes/%d/toggle-sync", m.ID) }
														hx-swap="none"
													/>
													<span class="swap-on text-success">
														<span class="icon-[heroicons--check-circle] w-5 h-5"></span>
													</span>
													<span class="swap-off text-base-content/30">
														<span class="icon-[heroicons--x-circle] w-5 h-5"></span>
													</span>
												</label>
											</td>
											<td class="whitespace-nowrap">
												if m.LastGeneratedAt != nil {
													<span class="timeago text-sm text-base-content/60" datetime={ formatMixtapeTimeISO(*m.LastGeneratedAt) } title={ formatMixtapeTime(*m.LastGeneratedAt) }>
														{ formatMixtapeTime(*m.LastGeneratedAt) }
													</span>
												} else {
													<span class="text-sm text-base-content/40 italic">Never</span>
												}
											</td>
											<td>
												<button
													onclick={ showDeleteMixtapeModal(m.ID, m.Name) }
													class="btn btn-ghost btn-sm btn-square text-error hover:bg-error/10"
													title="Delete Mixtape"
												>
													<span class="icon-[heroicons--trash] w-5 h-5"></span>
												</button>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				</div>
				<!-- Tile View -->
				<div id="tile-view" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
					for _, m := range mixtapes {
						<div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all">
							<!-- Cover Art -->
							<figure class="aspect-square bg-gradient-to-br from-primary to-secondary relative">
								if m.ImageURL != "" {
									<img src={ m.ImageURL } alt={ m.Name } class="w-full h-full object-cover"/>
								} else {
									<div class="w-full h-full flex items-center justify-center">
										<span class="icon-[heroicons--musical-note] w-16 h-16 text-white/50"></span>
									</div>
								}
								<!-- Sync indicator overlay -->
								if m.SyncToNavidrome {
									<div class="absolute top-2 right-2 badge badge-success gap-1">
										<span class="icon-[heroicons--arrow-path] w-3 h-3"></span>
										Synced
									</div>
								}
							</figure>
							<div class="card-body p-4">
								<!-- Title & DJ -->
								<div class="flex items-start justify-between gap-2">
									<a href={ templ.URL(fmt.Sprintf("/vibes/mixtapes/%d", m.ID)) } class="card-title text-base line-clamp-1 hover:text-primary">
										{ m.Name }
									</a>
									@scheduleBadge(string(m.Schedule))
								</div>
								<!-- DJ -->
								if m.Edges.Dj != nil {
									<div class="flex items-center gap-2 text-sm text-base-content/60">
										<span class="icon-[heroicons--user-circle] w-4 h-4"></span>
										{ m.Edges.Dj.Name }
									</div>
								}
								<!-- Description -->
								<p class="text-sm text-base-content/60 line-clamp-2 min-h-[2.5rem]">
									if m.Description != "" {
										{ m.Description }
									} else {
										<span class="italic opacity-50">No description</span>
									}
								</p>
								<!-- Stats -->
								<div class="divider my-2"></div>
								<div class="flex items-center justify-between">
									<div class="text-center">
										<div class="text-lg font-bold">{ fmt.Sprintf("%d", m.TrackCount) }</div>
										<div class="text-xs text-base-content/60">Tracks</div>
									</div>
									<div class="flex gap-2">
										<button
											hx-post={ fmt.Sprintf("/vibes/mixtapes/%d/generate", m.ID) }
											hx-swap="none"
											class="btn btn-sm btn-ghost btn-square tooltip"
											data-tip="Generate tracks"
										>
											<span class="icon-[heroicons--sparkles] w-4 h-4"></span>
										</button>
										<button
											onclick={ showDeleteMixtapeModal(m.ID, m.Name) }
											class="btn btn-sm btn-ghost btn-square text-error hover:bg-error/10 tooltip"
											data-tip="Delete"
										>
											<span class="icon-[heroicons--trash] w-4 h-4"></span>
										</button>
									</div>
								</div>
								<!-- Navidrome Sync Toggle -->
								<div class="flex items-center justify-between mt-2 pt-2 border-t border-base-300">
									<span class="text-sm text-base-content/60">Sync to Navidrome</span>
									<input
										type="checkbox"
										class="toggle toggle-primary toggle-sm"
										checked?={ m.SyncToNavidrome }
										hx-post={ fmt.Sprintf("/vibes/mixtapes/%d/toggle-sync", m.ID) }
										hx-swap="none"
									/>
								</div>
								<!-- Last Generated -->
								<div class="text-xs text-base-content/50 mt-2 text-center">
									if m.LastGeneratedAt != nil {
										Generated <span class="timeago" datetime={ formatMixtapeTimeISO(*m.LastGeneratedAt) } title={ formatMixtapeTime(*m.LastGeneratedAt) }>{ formatMixtapeTime(*m.LastGeneratedAt) }</span>
									} else {
										<span class="italic">Not yet generated</span>
									}
								</div>
							</div>
						</div>
					}
				</div>
				if totalPages > 1 {
					<div class="flex justify-center mt-8">
						<div class="join">
							if currentPage > 1 {
								<a href={ templ.URL(fmt.Sprintf("/vibes/mixtapes?page=%d", currentPage-1)) } class="join-item btn btn-sm">«</a>
							} else {
								<button class="join-item btn btn-sm btn-disabled">«</button>
							}
							for i := 1; i <= totalPages; i++ {
								if i == currentPage {
									<button class="join-item btn btn-sm btn-active">{ fmt.Sprintf("%d", i) }</button>
								} else if i == 1 || i == totalPages || (i >= currentPage-2 && i <= currentPage+2) {
									<a href={ templ.URL(fmt.Sprintf("/vibes/mixtapes?page=%d", i)) } class="join-item btn btn-sm">{ fmt.Sprintf("%d", i) }</a>
								} else if i == currentPage-3 || i == currentPage+3 {
									<button class="join-item btn btn-sm btn-disabled">...</button>
								}
							}
							if currentPage < totalPages {
								<a href={ templ.URL(fmt.Sprintf("/vibes/mixtapes?page=%d", currentPage+1)) } class="join-item btn btn-sm">»</a>
							} else {
								<button class="join-item btn btn-sm btn-disabled">»</button>
							}
						</div>
					</div>
				}
			}
		</div>
		<!-- Create Mixtape Modal -->
		<dialog id="create-mixtape-modal" class="modal">
			<div class="modal-box w-11/12 max-w-2xl">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
				</form>
				<h3 class="font-bold text-lg mb-4">
					<span class="icon-[heroicons--musical-note] w-6 h-6 inline-block mr-2"></span>
					Create New Mixtape
				</h3>
				<form hx-post="/vibes/mixtapes" hx-swap="none" class="space-y-4">
					@MixtapeFormFields(nil, djs)
					<div class="modal-action">
						<button type="button" class="btn" onclick="document.getElementById('create-mixtape-modal').close()">Cancel</button>
						<button type="submit" class="btn btn-primary gap-2">
							<span class="icon-[heroicons--check] w-5 h-5"></span>
							Create Mixtape
						</button>
					</div>
				</form>
			</div>
			<form method="dialog" class="modal-backdrop">
				<button>close</button>
			</form>
		</dialog>
		<!-- Edit Mixtape Modal -->
		<dialog id="edit-mixtape-modal" class="modal">
			<div class="modal-box w-11/12 max-w-2xl">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
				</form>
				<h3 class="font-bold text-lg mb-4">
					<span class="icon-[heroicons--pencil-square] w-6 h-6 inline-block mr-2"></span>
					Edit Mixtape
				</h3>
				<form id="edit-mixtape-form" hx-swap="none" class="space-y-4">
					<input type="hidden" name="id" id="edit-mixtape-id"/>
					@MixtapeFormFields(nil, djs)
					<div class="modal-action">
						<button type="button" class="btn" onclick="document.getElementById('edit-mixtape-modal').close()">Cancel</button>
						<button type="submit" class="btn btn-primary gap-2">
							<span class="icon-[heroicons--check] w-5 h-5"></span>
							Save Changes
						</button>
					</div>
				</form>
			</div>
			<form method="dialog" class="modal-backdrop">
				<button>close</button>
			</form>
		</dialog>
		<!-- Delete Confirmation Modal -->
		<dialog id="delete-mixtape-modal" class="modal">
			<div class="modal-box">
				<h3 class="font-bold text-lg text-error">
					<span class="icon-[heroicons--exclamation-triangle] w-6 h-6 inline-block mr-2"></span>
					Delete Mixtape
				</h3>
				<p class="py-4">Are you sure you want to delete <span id="delete-mixtape-name" class="font-bold"></span>? This action cannot be undone.</p>
				if true {
					<p class="text-sm text-base-content/60">If this mixtape is synced to Navidrome, the playlist will also be removed.</p>
				}
				<div class="modal-action">
					<button class="btn" onclick="document.getElementById('delete-mixtape-modal').close()">Cancel</button>
					<button
						id="confirm-delete-mixtape-btn"
						class="btn btn-error gap-2"
						hx-swap="none"
					>
						<span class="icon-[heroicons--trash] w-5 h-5"></span>
						Delete
					</button>
				</div>
			</div>
			<form method="dialog" class="modal-backdrop">
				<button>close</button>
			</form>
		</dialog>
		<script>
			// View toggle functionality
			function setView(view) {
				const tableView = document.getElementById('table-view');
				const tileView = document.getElementById('tile-view');
				const tableBtn = document.getElementById('table-view-btn');
				const tileBtn = document.getElementById('tile-view-btn');

				if (view === 'table') {
					tableView.classList.remove('hidden');
					tileView.classList.add('hidden');
					tableBtn.classList.add('btn-active');
					tileBtn.classList.remove('btn-active');
				} else {
					tableView.classList.add('hidden');
					tileView.classList.remove('hidden');
					tableBtn.classList.remove('btn-active');
					tileBtn.classList.add('btn-active');
				}

				// Save preference
				localStorage.setItem('spotter-mixtapes-view', view);
			}

			// Restore saved preference (default is tile)
			(function() {
				const savedView = localStorage.getItem('spotter-mixtapes-view');
				if (savedView === 'table') {
					setView('table');
				}
			})();

			// Initialize timeago
			(function() {
				if (typeof timeago !== 'undefined') {
					const nodes = document.querySelectorAll('.timeago');
					if (nodes.length > 0) {
						timeago.render(nodes);
					}
				}
			})();

			// Handle form submissions
			document.body.addEventListener('htmx:afterRequest', function(event) {
				if (event.detail.successful) {
					// Close modals and refresh page
					var createModal = document.getElementById('create-mixtape-modal');
					var editModal = document.getElementById('edit-mixtape-modal');
					var deleteModal = document.getElementById('delete-mixtape-modal');
					if (createModal) createModal.close();
					if (editModal) editModal.close();
					if (deleteModal) deleteModal.close();
					window.location.reload();
				}
			});
		</script>
	}
}

script showEditMixtapeModal(m *ent.Mixtape, djs []*ent.DJ) {
	const modal = document.getElementById('edit-mixtape-modal');
	const form = document.getElementById('edit-mixtape-form');

	// Set form action
	form.setAttribute('hx-put', '/vibes/mixtapes/' + m.ID);
	htmx.process(form);

	// Populate fields
	document.getElementById('edit-mixtape-id').value = m.ID;
	document.getElementById('edit-mixtape-name').value = m.Name;
	document.getElementById('edit-mixtape-description').value = m.Description || '';
	document.getElementById('edit-mixtape-dj').value = m.Edges.Dj ? m.Edges.Dj.ID : '';
	document.getElementById('edit-mixtape-schedule').value = m.Schedule;
	document.getElementById('edit-mixtape-sync').checked = m.SyncToNavidrome;

	modal.showModal();
}

script showDeleteMixtapeModal(id int, name string) {
	const modal = document.getElementById('delete-mixtape-modal');
	const nameSpan = document.getElementById('delete-mixtape-name');
	const deleteBtn = document.getElementById('confirm-delete-mixtape-btn');

	nameSpan.textContent = name;
	deleteBtn.setAttribute('hx-delete', '/vibes/mixtapes/' + id);
	htmx.process(deleteBtn);

	modal.showModal();
}

templ MixtapeFormFields(m *ent.Mixtape, djs []*ent.DJ) {
	<!-- Name -->
	<div class="form-control">
		<label class="label">
			<span class="label-text font-medium">Name <span class="text-error">*</span></span>
		</label>
		<input
			type="text"
			name="name"
			id={ mixtapeFieldID("name", m) }
			class="input input-bordered w-full"
			placeholder="e.g., Late Night Coding, Sunday Morning Chill"
			required
			if m != nil {
				value={ m.Name }
			}
		/>
	</div>
	<!-- Description -->
	<div class="form-control">
		<label class="label">
			<span class="label-text font-medium">Description</span>
		</label>
		<textarea
			name="description"
			id={ mixtapeFieldID("description", m) }
			class="textarea textarea-bordered h-20 w-full"
			placeholder="What's this mixtape for?"
		>
			if m != nil {
				{ m.Description }
			}
		</textarea>
	</div>
	<!-- DJ Selection -->
	<div class="form-control">
		<label class="label">
			<span class="label-text font-medium">DJ <span class="text-error">*</span></span>
		</label>
		<select
			name="dj_id"
			id={ mixtapeFieldID("dj", m) }
			class="select select-bordered w-full"
			required
		>
			<option value="" disabled selected?={ m == nil }>Select a DJ</option>
			for _, dj := range djs {
				<option
					value={ fmt.Sprintf("%d", dj.ID) }
					selected?={ m != nil && m.Edges.Dj != nil && m.Edges.Dj.ID == dj.ID }
				>
					{ dj.Name }
				</option>
			}
		</select>
		<label class="label">
			<span class="label-text-alt text-base-content/60">The DJ personality that will curate this mixtape</span>
		</label>
	</div>
	<!-- Max Tracks -->
	<div class="form-control">
		<label class="label">
			<span class="label-text font-medium">Maximum Tracks</span>
		</label>
		<input
			type="number"
			name="max_tracks"
			id={ mixtapeFieldID("max_tracks", m) }
			class="input input-bordered w-full"
			min="1"
			max="100"
			if m != nil {
				value={ fmt.Sprintf("%d", m.MaxTracks) }
			} else {
				value="25"
			}
		/>
		<label class="label">
			<span class="label-text-alt text-base-content/60">Maximum number of tracks for the AI to select (1-100)</span>
		</label>
	</div>
	<!-- Schedule -->
	<div class="form-control">
		<label class="label">
			<span class="label-text font-medium">Update Schedule</span>
		</label>
		<select
			name="schedule"
			id={ mixtapeFieldID("schedule", m) }
			class="select select-bordered w-full"
		>
			<option value="none" selected?={ m == nil || m.Schedule == "none" }>Manual (no automatic updates)</option>
			<option value="daily" selected?={ m != nil && m.Schedule == "daily" }>Daily</option>
			<option value="weekly" selected?={ m != nil && m.Schedule == "weekly" }>Weekly</option>
			<option value="monthly" selected?={ m != nil && m.Schedule == "monthly" }>Monthly</option>
		</select>
		<label class="label">
			<span class="label-text-alt text-base-content/60">How often should the AI regenerate tracks?</span>
		</label>
	</div>
	<!-- Sync to Navidrome -->
	<div class="form-control">
		<label class="label cursor-pointer justify-start gap-4">
			<input
				type="checkbox"
				name="sync_to_navidrome"
				id={ mixtapeFieldID("sync", m) }
				class="toggle toggle-primary"
				checked?={ m != nil && m.SyncToNavidrome }
			/>
			<div>
				<span class="label-text font-medium">Sync to Navidrome</span>
				<p class="text-xs text-base-content/60">Automatically create and update a playlist in Navidrome</p>
			</div>
		</label>
	</div>
}

func mixtapeFieldID(field string, m *ent.Mixtape) string {
	if m != nil {
		return "edit-mixtape-" + field
	}
	return "create-mixtape-" + field
}
