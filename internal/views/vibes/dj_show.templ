package vibes

import (
	"fmt"
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
)

templ DJShow(dj *ent.DJ, cfg *config.Config) {
	@layouts.Dashboard(dj.Name+" | DJs | Spotter", cfg, "/vibes/djs") {
		<div class="max-w-7xl mx-auto">
			<!-- Breadcrumb -->
			<div class="text-sm breadcrumbs mb-4">
				<ul>
					<li><a href="/vibes/djs">DJs</a></li>
					<li>{ dj.Name }</li>
				</ul>
			</div>
			<!-- Header -->
			<div class="flex flex-col lg:flex-row gap-6 mb-8">
				<!-- Avatar -->
				<div class="flex-shrink-0">
					<div class="w-48 h-48 rounded-lg shadow-lg overflow-hidden bg-gradient-to-br from-primary to-secondary flex items-center justify-center">
						<span class="icon-[heroicons--user-circle] w-24 h-24 text-white/50"></span>
					</div>
				</div>
				<!-- Info -->
				<div class="flex-1">
					<div class="flex items-start justify-between gap-4">
						<div>
							<h1 class="text-3xl font-bold">{ dj.Name }</h1>
							if dj.SystemPrompt != "" {
								<p class="text-base-content/60 mt-2 max-w-2xl">{ dj.SystemPrompt }</p>
							}
						</div>
						<button
							onclick="document.getElementById('edit-dj-modal').showModal()"
							class="btn btn-ghost btn-square"
							title="Edit DJ"
						>
							<span class="icon-[heroicons--pencil] w-5 h-5"></span>
						</button>
					</div>
					<!-- Meta Info -->
					<div class="flex flex-wrap gap-4 mt-4">
						<!-- Mixtape Count -->
						<div class="flex items-center gap-2">
							<span class="icon-[heroicons--musical-note] w-5 h-5 text-base-content/60"></span>
							<span>{ fmt.Sprintf("%d", len(dj.Edges.Mixtapes)) } mixtape(s)</span>
						</div>
						<!-- Created -->
						<div class="flex items-center gap-2">
							<span class="icon-[heroicons--calendar] w-5 h-5 text-base-content/60"></span>
							<span>Created <span class="timeago" datetime={ formatDJTimeISO(dj.CreatedAt) } title={ formatDJTime(dj.CreatedAt) }>{ formatDJTime(dj.CreatedAt) }</span></span>
						</div>
					</div>
				</div>
			</div>
			<!-- Configuration Card -->
			<div class="card bg-base-100 shadow-xl mb-6">
				<div class="card-body">
					<h2 class="card-title">
						<span class="icon-[heroicons--adjustments-horizontal] w-6 h-6"></span>
						Configuration
					</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-4">
						<!-- Genres Include -->
						<div>
							<h3 class="text-sm font-medium text-base-content/60 mb-2">
								<span class="icon-[heroicons--plus-circle] w-4 h-4 inline-block text-success"></span>
								Included Genres
							</h3>
							<div class="flex flex-wrap gap-1">
								if len(dj.GenresInclude) > 0 {
									for _, genre := range dj.GenresInclude {
										<span class="badge badge-success">{ genre }</span>
									}
								} else {
									<span class="text-base-content/40 text-sm italic">Any genre</span>
								}
							</div>
						</div>
						<!-- Genres Exclude -->
						<div>
							<h3 class="text-sm font-medium text-base-content/60 mb-2">
								<span class="icon-[heroicons--minus-circle] w-4 h-4 inline-block text-error"></span>
								Excluded Genres
							</h3>
							<div class="flex flex-wrap gap-1">
								if len(dj.GenresExclude) > 0 {
									for _, genre := range dj.GenresExclude {
										<span class="badge badge-error">{ genre }</span>
									}
								} else {
									<span class="text-base-content/40 text-sm italic">None excluded</span>
								}
							</div>
						</div>
						<!-- Vibes -->
						<div>
							<h3 class="text-sm font-medium text-base-content/60 mb-2">
								<span class="icon-[heroicons--sparkles] w-4 h-4 inline-block text-primary"></span>
								Vibes
							</h3>
							<div class="flex flex-wrap gap-1">
								if len(dj.Vibes) > 0 {
									for _, vibe := range dj.Vibes {
										<span class="badge badge-primary">{ vibe }</span>
									}
								} else {
									<span class="text-base-content/40 text-sm italic">No vibes set</span>
								}
							</div>
						</div>
						<!-- Artists Include -->
						<div>
							<h3 class="text-sm font-medium text-base-content/60 mb-2">
								<span class="icon-[heroicons--plus-circle] w-4 h-4 inline-block text-success"></span>
								Included Artists
							</h3>
							<div class="flex flex-wrap gap-1">
								if len(dj.ArtistsInclude) > 0 {
									for _, artist := range dj.ArtistsInclude {
										<span class="badge badge-outline">{ artist }</span>
									}
								} else {
									<span class="text-base-content/40 text-sm italic">Any artist</span>
								}
							</div>
						</div>
						<!-- Artists Exclude -->
						<div>
							<h3 class="text-sm font-medium text-base-content/60 mb-2">
								<span class="icon-[heroicons--minus-circle] w-4 h-4 inline-block text-error"></span>
								Excluded Artists
							</h3>
							<div class="flex flex-wrap gap-1">
								if len(dj.ArtistsExclude) > 0 {
									for _, artist := range dj.ArtistsExclude {
										<span class="badge badge-outline badge-error">{ artist }</span>
									}
								} else {
									<span class="text-base-content/40 text-sm italic">None excluded</span>
								}
							</div>
						</div>
					</div>
				</div>
			</div>
			<!-- Mixtapes Card -->
			<div class="card bg-base-100 shadow-xl">
				<div class="card-body">
					<div class="flex items-center justify-between">
						<h2 class="card-title">
							<span class="icon-[heroicons--musical-note] w-6 h-6"></span>
							Mixtapes
						</h2>
						<a href="/vibes/mixtapes" class="btn btn-sm btn-ghost gap-1">
							View All
							<span class="icon-[heroicons--arrow-right] w-4 h-4"></span>
						</a>
					</div>
					if len(dj.Edges.Mixtapes) == 0 {
						<div class="text-center py-12">
							<span class="icon-[heroicons--musical-note] w-12 h-12 text-base-content/20 mx-auto"></span>
							<p class="text-base-content/60 mt-4">No mixtapes yet. Create a mixtape and assign it to this DJ.</p>
							<a href="/vibes/mixtapes" class="btn btn-primary mt-4 gap-2">
								<span class="icon-[heroicons--plus] w-5 h-5"></span>
								Create Mixtape
							</a>
						</div>
					} else {
						<div class="overflow-x-auto">
							<table class="table">
								<thead>
									<tr>
										<th>Name</th>
										<th>Tracks</th>
										<th>Schedule</th>
										<th>Synced</th>
									</tr>
								</thead>
								<tbody>
									for _, m := range dj.Edges.Mixtapes {
										<tr class="hover">
											<td>
												<a href={ templ.URL(fmt.Sprintf("/vibes/mixtapes/%d", m.ID)) } class="link link-hover link-primary font-medium">
													{ m.Name }
												</a>
											</td>
											<td>{ fmt.Sprintf("%d", m.TrackCount) }</td>
											<td>
												@scheduleBadge(string(m.Schedule))
											</td>
											<td>
												if m.SyncToNavidrome {
													<span class="icon-[heroicons--check-circle] w-5 h-5 text-success"></span>
												} else {
													<span class="icon-[heroicons--x-circle] w-5 h-5 text-base-content/30"></span>
												}
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</div>
			</div>
		</div>
		<!-- Edit DJ Modal -->
		<dialog id="edit-dj-modal" class="modal">
			<div class="modal-box w-11/12 max-w-3xl">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
				</form>
				<h3 class="font-bold text-lg mb-4">
					<span class="icon-[heroicons--pencil-square] w-6 h-6 inline-block mr-2"></span>
					Edit DJ
				</h3>
				<form id="edit-dj-form" hx-put={ fmt.Sprintf("/vibes/djs/%d", dj.ID) } hx-swap="none" class="space-y-4">
					<input type="hidden" name="id" value={ fmt.Sprintf("%d", dj.ID) }/>
					@DJShowFormFields(dj)
					<div class="modal-action">
						<button type="button" class="btn" onclick="document.getElementById('edit-dj-modal').close()">Cancel</button>
						<button type="submit" class="btn btn-primary gap-2">
							<span class="icon-[heroicons--check] w-5 h-5"></span>
							Save Changes
						</button>
					</div>
				</form>
			</div>
			<form method="dialog" class="modal-backdrop">
				<button>close</button>
			</form>
		</dialog>
		<script>
			// Initialize timeago
			(function() {
				if (typeof timeago !== 'undefined') {
					const nodes = document.querySelectorAll('.timeago');
					if (nodes.length > 0) {
						timeago.render(nodes);
					}
				}
			})();

			// Handle form submissions
			document.body.addEventListener('htmx:afterRequest', function(event) {
				if (event.detail.successful) {
					var editModal = document.getElementById('edit-dj-modal');
					if (editModal) editModal.close();
					window.location.reload();
				}
			});
		</script>
	}
}

// DJShowFormFields is a version of the form fields for the show page edit modal
// where we always have a DJ to populate
templ DJShowFormFields(dj *ent.DJ) {
	<!-- Name -->
	<div class="form-control">
		<label class="label">
			<span class="label-text font-medium">Name <span class="text-error">*</span></span>
		</label>
		<input
			type="text"
			name="name"
			class="input input-bordered w-full"
			placeholder="e.g., Chill Vibes DJ, Party Starter"
			required
			value={ dj.Name }
		/>
		<label class="label">
			<span class="label-text-alt text-base-content/60">A memorable name for this DJ personality</span>
		</label>
	</div>
	<!-- System Prompt -->
	<div class="form-control">
		<label class="label">
			<span class="label-text font-medium">System Prompt</span>
		</label>
		<textarea
			name="system_prompt"
			class="textarea textarea-bordered h-24 w-full font-mono text-sm"
			placeholder="You are a DJ who specializes in creating the perfect mood..."
		>{ dj.SystemPrompt }</textarea>
		<label class="label">
			<span class="label-text-alt text-base-content/60">Custom instructions for how this DJ should behave</span>
		</label>
	</div>
	<div class="divider">Filters</div>
	<!-- Genres Include/Exclude -->
	<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
		@components.TagInput(components.TagInputConfig{
			ID:             "edit-genres_include",
			Name:           "genres_include",
			Label:          "Include Genres",
			LabelIcon:      "icon-[heroicons--plus-circle]",
			LabelIconClass: "text-success",
			Placeholder:    "Type to search genres...",
			HelpText:       "Genres to prioritize from your listening history",
			SuggestionsURL: "/vibes/djs/suggestions/genres",
			InitialTags:    dj.GenresInclude,
		})
		@components.TagInput(components.TagInputConfig{
			ID:             "edit-genres_exclude",
			Name:           "genres_exclude",
			Label:          "Exclude Genres",
			LabelIcon:      "icon-[heroicons--minus-circle]",
			LabelIconClass: "text-error",
			Placeholder:    "Type to search genres...",
			HelpText:       "Genres to exclude from selections",
			SuggestionsURL: "/vibes/djs/suggestions/genres",
			InitialTags:    dj.GenresExclude,
		})
	</div>
	<!-- Vibes -->
	@components.TagInput(components.TagInputConfig{
		ID:             "edit-vibes",
		Name:           "vibes",
		Label:          "Vibes",
		LabelIcon:      "icon-[heroicons--sparkles]",
		LabelIconClass: "text-primary",
		Placeholder:    "Type a vibe and press Enter...",
		HelpText:       "Emotions or adjectives like chill, energetic, nostalgic, uplifting",
		SuggestionsURL: "",
		InitialTags:    dj.Vibes,
	})
	<!-- Artists Include/Exclude -->
	<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
		@components.TagInput(components.TagInputConfig{
			ID:             "edit-artists_include",
			Name:           "artists_include",
			Label:          "Include Artists",
			LabelIcon:      "icon-[heroicons--plus-circle]",
			LabelIconClass: "text-success",
			Placeholder:    "Type to search artists...",
			HelpText:       "Artists to prioritize from your library",
			SuggestionsURL: "/vibes/djs/suggestions/artists",
			InitialTags:    dj.ArtistsInclude,
		})
		@components.TagInput(components.TagInputConfig{
			ID:             "edit-artists_exclude",
			Name:           "artists_exclude",
			Label:          "Exclude Artists",
			LabelIcon:      "icon-[heroicons--minus-circle]",
			LabelIconClass: "text-error",
			Placeholder:    "Type to search artists...",
			HelpText:       "Artists to exclude from selections",
			SuggestionsURL: "/vibes/djs/suggestions/artists",
			InitialTags:    dj.ArtistsExclude,
		})
	</div>
}
