package vibes

import (
	"fmt"
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
	"strconv"
	"time"
)

// MixtapeTrackRow converts a track to a TrackTableRow for display
func mixtapeTrackRow(t *ent.Track, index int, lidarrBaseURL string) components.TrackTableRow {
	row := components.TrackTableRow{
		Track:         t,
		Index:         index + 1,
		LidarrBaseURL: lidarrBaseURL,
	}
	return row
}

// toMixtapeTrackRows converts tracks to TrackTableRows
func toMixtapeTrackRows(tracks []*ent.Track, lidarrBaseURL string) []components.TrackTableRow {
	rows := make([]components.TrackTableRow, len(tracks))
	for i, t := range tracks {
		rows[i] = mixtapeTrackRow(t, i, lidarrBaseURL)
	}
	return rows
}

func getMixtapeImage(m *ent.Mixtape) string {
	if m.ImageURL != "" {
		return m.ImageURL
	}
	return ""
}

func getSeedDescription(m *ent.Mixtape) string {
	if m.SeedType == "" || m.SeedType == "none" {
		return ""
	}
	switch m.SeedType {
	case "artist":
		return "Seeded from artist"
	case "album":
		return "Seeded from album"
	case "tracks":
		return "Seeded from tracks"
	default:
		return ""
	}
}

templ MixtapeShow(m *ent.Mixtape, tracks []*ent.Track, djs []*ent.DJ, cfg *config.Config) {
	@layouts.Dashboard(m.Name+" | Mixtapes | Spotter", cfg, "/vibes/mixtapes") {
		<!-- Hero Section with Background -->
		<div class="relative -mx-6 lg:-mx-8 -mt-6 lg:-mt-8 mb-8">
			<!-- Background Gradient -->
			<div class="absolute inset-0 h-80 overflow-hidden">
				<div class="w-full h-full bg-gradient-to-br from-primary/30 via-secondary/20 to-accent/30"></div>
				<div class="absolute inset-0 bg-gradient-to-b from-transparent via-base-200/80 to-base-200"></div>
			</div>
			<!-- Actions Menu (Top Right) -->
			<div class="absolute top-4 right-4 z-10">
				<details class="dropdown dropdown-end">
					<summary class="btn btn-sm btn-ghost bg-base-100/50 hover:bg-base-100/80 gap-1 list-none cursor-pointer">
						<span class="icon-[heroicons--sparkles] w-4 h-4 text-accent"></span>
						<span class="hidden sm:inline">Actions</span>
						<span class="icon-[heroicons--chevron-down] w-3 h-3"></span>
					</summary>
					<ul class="dropdown-content z-[1] menu p-2 shadow-lg bg-base-100 rounded-box w-56">
						<li>
							<button
								hx-post={ fmt.Sprintf("/vibes/mixtapes/%d/generate", m.ID) }
								hx-swap="none"
								hx-indicator="#generate-indicator"
								onclick="this.closest('details').removeAttribute('open');"
							>
								<span class="icon-[heroicons--sparkles] w-4 h-4"></span>
								Generate Tracks
								<span id="generate-indicator" class="htmx-indicator loading loading-spinner loading-xs"></span>
							</button>
						</li>
						<li>
							<button onclick="document.getElementById('edit-mixtape-modal').showModal(); this.closest('details').removeAttribute('open');">
								<span class="icon-[heroicons--pencil] w-4 h-4"></span>
								Edit Mixtape
							</button>
						</li>
						<li class="menu-title pt-2">
							<span>Sync</span>
						</li>
						<li>
							<button
								hx-post={ fmt.Sprintf("/vibes/mixtapes/%d/toggle-sync", m.ID) }
								hx-swap="none"
								onclick="this.closest('details').removeAttribute('open');"
							>
								if m.SyncToNavidrome {
									<span class="icon-[heroicons--cloud-arrow-down] w-4 h-4"></span>
									Disable Navidrome Sync
								} else {
									<span class="icon-[heroicons--cloud-arrow-up] w-4 h-4"></span>
									Enable Navidrome Sync
								}
							</button>
						</li>
					</ul>
				</details>
			</div>
			<!-- Mixtape Info -->
			<div class="relative pt-8 px-6 lg:px-8 pb-8">
				<div class="max-w-7xl mx-auto">
					<!-- Breadcrumb -->
					<div class="text-sm breadcrumbs mb-4">
						<ul>
							<li><a href="/vibes/mixtapes" class="link link-hover">Mixtapes</a></li>
							<li>{ m.Name }</li>
						</ul>
					</div>
					<div class="flex flex-col md:flex-row items-start gap-8">
						<!-- Cover Art -->
						<div class="flex-shrink-0">
							<div class="w-48 h-48 md:w-56 md:h-56 rounded-xl shadow-2xl ring ring-base-100 ring-offset-base-200 ring-offset-2 overflow-hidden bg-gradient-to-br from-primary to-secondary">
								if m.ImageURL != "" {
									<img src={ m.ImageURL } alt={ m.Name } class="w-full h-full object-cover"/>
								} else {
									<div class="w-full h-full flex items-center justify-center">
										<span class="icon-[heroicons--musical-note] w-20 h-20 text-white/50"></span>
									</div>
								}
							</div>
						</div>
						<!-- Details -->
						<div class="flex-1 min-w-0">
							<h1 class="text-4xl md:text-5xl font-bold mb-2 text-base-content">{ m.Name }</h1>
							<!-- DJ Link -->
							if m.Edges.Dj != nil {
								<a href={ templ.URL(fmt.Sprintf("/vibes/djs/%d", m.Edges.Dj.ID)) } class="text-xl text-base-content/70 hover:text-primary hover:underline flex items-center gap-2 mb-3">
									<span class="icon-[heroicons--user-circle] w-5 h-5"></span>
									{ m.Edges.Dj.Name }
								</a>
							}
							<!-- Description -->
							if m.Description != "" {
								<p class="text-base-content/60 mb-4">{ m.Description }</p>
							}
							<!-- Meta Badges -->
							<div class="flex flex-wrap gap-2 mb-4">
								<!-- Track Count -->
								<span class="badge badge-lg gap-1.5">
									<span class="icon-[heroicons--musical-note] w-4 h-4"></span>
									{ fmt.Sprintf("%d / %d tracks", m.TrackCount, m.MaxTracks) }
								</span>
								<!-- Schedule -->
								@scheduleBadge(string(m.Schedule))
								<!-- Sync Status -->
								if m.SyncToNavidrome {
									<span class="badge badge-lg badge-success gap-1.5">
										<span class="icon-[heroicons--check-circle] w-4 h-4"></span>
										Synced to Navidrome
									</span>
								}
								<!-- Seed Info -->
								if seed := getSeedDescription(m); seed != "" {
									<span class="badge badge-lg badge-secondary gap-1.5">
										<span class="icon-[heroicons--sparkles] w-4 h-4"></span>
										{ seed }
									</span>
								}
							</div>
							<!-- Generation Info -->
							<div class="text-sm text-base-content/60 space-y-1">
								if m.LastGeneratedAt != nil {
									<div class="flex items-center gap-2">
										<span class="icon-[heroicons--clock] w-4 h-4"></span>
										Last generated <span class="timeago font-medium" datetime={ formatMixtapeTimeISO(*m.LastGeneratedAt) } title={ formatMixtapeTime(*m.LastGeneratedAt) }>{ formatMixtapeTime(*m.LastGeneratedAt) }</span>
									</div>
								} else {
									<div class="flex items-center gap-2">
										<span class="icon-[heroicons--clock] w-4 h-4"></span>
										<span class="italic">Not yet generated</span>
									</div>
								}
								if m.GenerationModel != "" {
									<div class="flex items-center gap-2">
										<span class="icon-[heroicons--cpu-chip] w-4 h-4"></span>
										Model: { m.GenerationModel }
										if m.GenerationTokensUsed != nil {
											<span class="text-base-content/40">({ strconv.Itoa(*m.GenerationTokensUsed) } tokens)</span>
										}
									</div>
								}
							</div>
							<!-- Error Display -->
							if m.GenerationError != "" {
								<div class="alert alert-error mt-4">
									<span class="icon-[heroicons--exclamation-circle] w-5 h-5"></span>
									<div>
										<h3 class="font-bold">Generation Error</h3>
										<p class="text-sm">{ m.GenerationError }</p>
									</div>
								</div>
							}
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="max-w-7xl mx-auto">
			<!-- DJ Configuration Card -->
			if m.Edges.Dj != nil {
				<div class="card bg-base-100 shadow-xl mb-8">
					<div class="card-body">
						<h2 class="card-title">
							<span class="icon-[heroicons--cog-6-tooth] w-6 h-6"></span>
							DJ Configuration
						</h2>
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-4">
							<!-- Genres Include -->
							<div>
								<h3 class="text-sm font-medium text-base-content/60 mb-2 flex items-center gap-1.5">
									<span class="icon-[heroicons--plus-circle] w-4 h-4 text-success"></span>
									Included Genres
								</h3>
								<div class="flex flex-wrap gap-1.5">
									if len(m.Edges.Dj.GenresInclude) > 0 {
										for _, genre := range m.Edges.Dj.GenresInclude {
											<span class="badge badge-success badge-outline">{ genre }</span>
										}
									} else {
										<span class="text-base-content/40 text-sm italic">Any genre</span>
									}
								</div>
							</div>
							<!-- Genres Exclude -->
							<div>
								<h3 class="text-sm font-medium text-base-content/60 mb-2 flex items-center gap-1.5">
									<span class="icon-[heroicons--minus-circle] w-4 h-4 text-error"></span>
									Excluded Genres
								</h3>
								<div class="flex flex-wrap gap-1.5">
									if len(m.Edges.Dj.GenresExclude) > 0 {
										for _, genre := range m.Edges.Dj.GenresExclude {
											<span class="badge badge-error badge-outline">{ genre }</span>
										}
									} else {
										<span class="text-base-content/40 text-sm italic">None excluded</span>
									}
								</div>
							</div>
							<!-- Vibes -->
							<div>
								<h3 class="text-sm font-medium text-base-content/60 mb-2 flex items-center gap-1.5">
									<span class="icon-[heroicons--sparkles] w-4 h-4 text-primary"></span>
									Vibes
								</h3>
								<div class="flex flex-wrap gap-1.5">
									if len(m.Edges.Dj.Vibes) > 0 {
										for _, vibe := range m.Edges.Dj.Vibes {
											<span class="badge badge-primary">{ vibe }</span>
										}
									} else {
										<span class="text-base-content/40 text-sm italic">No specific vibes</span>
									}
								</div>
							</div>
							<!-- Artists Include -->
							<div>
								<h3 class="text-sm font-medium text-base-content/60 mb-2 flex items-center gap-1.5">
									<span class="icon-[heroicons--plus-circle] w-4 h-4 text-success"></span>
									Included Artists
								</h3>
								<div class="flex flex-wrap gap-1.5">
									if len(m.Edges.Dj.ArtistsInclude) > 0 {
										for _, artist := range m.Edges.Dj.ArtistsInclude {
											<span class="badge badge-outline">{ artist }</span>
										}
									} else {
										<span class="text-base-content/40 text-sm italic">Any artist</span>
									}
								</div>
							</div>
							<!-- Artists Exclude -->
							<div>
								<h3 class="text-sm font-medium text-base-content/60 mb-2 flex items-center gap-1.5">
									<span class="icon-[heroicons--minus-circle] w-4 h-4 text-error"></span>
									Excluded Artists
								</h3>
								<div class="flex flex-wrap gap-1.5">
									if len(m.Edges.Dj.ArtistsExclude) > 0 {
										for _, artist := range m.Edges.Dj.ArtistsExclude {
											<span class="badge badge-error badge-outline">{ artist }</span>
										}
									} else {
										<span class="text-base-content/40 text-sm italic">None excluded</span>
									}
								</div>
							</div>
							<!-- System Prompt -->
							if m.Edges.Dj.SystemPrompt != "" {
								<div class="md:col-span-2 lg:col-span-3">
									<h3 class="text-sm font-medium text-base-content/60 mb-2 flex items-center gap-1.5">
										<span class="icon-[heroicons--chat-bubble-left-ellipsis] w-4 h-4"></span>
										System Prompt
									</h3>
									<div class="bg-base-200 rounded-lg p-4 text-sm font-mono whitespace-pre-wrap max-h-40 overflow-y-auto">{ m.Edges.Dj.SystemPrompt }</div>
								</div>
							}
						</div>
					</div>
				</div>
			}
			<!-- Generation Prompt (collapsible) -->
			// Governing: SPEC user-authentication REQ "Input Validation"
			// GenerationPrompt rendered via Templ string interpolation {}, which auto-escapes HTML
			if m.GenerationPrompt != "" {
				<div class="collapse collapse-arrow bg-base-100 shadow-xl mb-8">
					<input type="checkbox" aria-label="Toggle Generation Prompt section"/>
					<div class="collapse-title text-lg font-medium flex items-center gap-2">
						<span class="icon-[heroicons--document-text] w-5 h-5"></span>
						Generation Prompt
						<span class="badge badge-ghost badge-sm">Debug Info</span>
					</div>
					<div class="collapse-content">
						<div class="bg-base-200 rounded-lg p-4 text-sm font-mono whitespace-pre-wrap max-h-96 overflow-y-auto">{ m.GenerationPrompt }</div>
					</div>
				</div>
			}
			<!-- Tracks Section -->
			<div class="card bg-base-100 shadow-xl mb-8">
				<div class="card-body">
					<div class="flex items-center justify-between">
						<h2 class="card-title">
							<span class="icon-[heroicons--queue-list] w-6 h-6"></span>
							Tracks
							if len(tracks) > 0 {
								<span class="badge badge-neutral">{ strconv.Itoa(len(tracks)) }</span>
							}
						</h2>
						if len(tracks) > 0 {
							@components.TrackTableToolbar(components.TrackTableToolbarConfig{
								TableID:           "mixtape-tracks-table",
								ShowArtworkToggle: true,
								ArtworkDefault:    false,
								ColumnOptions: []components.ColumnOption{
									{Value: "col-index", Label: "#", DefaultVisible: true},
									{Value: "col-track", Label: "Track", DefaultVisible: true},
									{Value: "col-artist", Label: "Artist", DefaultVisible: true},
									{Value: "col-album", Label: "Album", DefaultVisible: true},
									{Value: "col-duration", Label: "Duration", DefaultVisible: true},
									{Value: "col-popularity", Label: "Popularity", DefaultVisible: false},
								},
							})
						}
					</div>
					if len(tracks) == 0 {
						<div class="text-center py-16">
							<div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-base-200 mb-4">
								<span class="icon-[heroicons--musical-note] w-10 h-10 text-base-content/30"></span>
							</div>
							<h3 class="text-lg font-semibold mb-2">No tracks yet</h3>
							<p class="text-base-content/60 mb-6 max-w-md mx-auto">
								Click "Generate Tracks" to let { getDJDisplayName(m.Edges.Dj) } curate the perfect mixtape for you.
							</p>
							<button
								hx-post={ fmt.Sprintf("/vibes/mixtapes/%d/generate", m.ID) }
								hx-swap="none"
								hx-indicator="#generate-tracks-btn-indicator"
								class="btn btn-primary gap-2"
							>
								<span id="generate-tracks-btn-indicator" class="htmx-indicator loading loading-spinner loading-sm"></span>
								<span class="icon-[heroicons--sparkles] w-5 h-5"></span>
								Generate Tracks
							</button>
						</div>
					} else {
						@components.TrackTable("mixtape-tracks-table", toMixtapeTrackRows(tracks, cfg.Lidarr.BaseURL), []string{"#", "track", "artist", "album", "duration"}, nil, components.SortConfig{})
					}
				</div>
			</div>
			<!-- Metadata Card -->
			<div class="card bg-base-100 shadow-xl mb-8">
				<div class="card-body">
					<h2 class="card-title">
						<span class="icon-[heroicons--information-circle] w-6 h-6"></span>
						Metadata
					</h2>
					@components.MetadataTable([]components.MetadataRow{
						{Label: "Name", Value: m.Name},
						{Label: "Description", Value: getMetaDescription(m.Description)},
						{Label: "DJ", Value: getDJName(m.Edges.Dj), Link: getDJLink(m.Edges.Dj)},
						{Label: "Schedule", Value: scheduleLabel(string(m.Schedule))},
						{Label: "Max Tracks", Value: strconv.Itoa(m.MaxTracks)},
						{Label: "Track Count", Value: strconv.Itoa(m.TrackCount)},
						{Label: "Navidrome Sync", Value: getSyncStatus(m.SyncToNavidrome)},
						{Label: "Navidrome Playlist ID", Value: getMetaDescription(m.NavidromePlaylistID)},
						{Label: "Seed Type", Value: getMetaDescription(m.SeedType)},
						{Label: "Model Used", Value: getMetaDescription(m.GenerationModel)},
						{Label: "Tokens Used", Value: getTokensUsed(m.GenerationTokensUsed)},
						{Label: "Last Generated", Value: getLastGenerated(m.LastGeneratedAt)},
						{Label: "Created", Value: formatMixtapeTime(m.CreatedAt)},
						{Label: "Updated", Value: formatMixtapeTime(m.UpdatedAt)},
					})
				</div>
			</div>
		</div>
		<!-- Edit Mixtape Modal -->
		<dialog id="edit-mixtape-modal" class="modal">
			<div class="modal-box w-11/12 max-w-2xl">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
				</form>
				<h3 class="font-bold text-lg mb-4 flex items-center gap-2">
					<span class="icon-[heroicons--pencil-square] w-6 h-6"></span>
					Edit Mixtape
				</h3>
				<form id="edit-mixtape-form" hx-put={ fmt.Sprintf("/vibes/mixtapes/%d", m.ID) } hx-swap="none" class="space-y-4">
					<input type="hidden" name="id" value={ fmt.Sprintf("%d", m.ID) }/>
					@MixtapeFormFields(m, djs)
					<div class="modal-action">
						<button type="button" class="btn" onclick="document.getElementById('edit-mixtape-modal').close()">Cancel</button>
						<button type="submit" class="btn btn-primary gap-2">
							<span class="icon-[heroicons--check] w-5 h-5"></span>
							Save Changes
						</button>
					</div>
				</form>
			</div>
			<form method="dialog" class="modal-backdrop">
				<button>close</button>
			</form>
		</dialog>
		<script>
			// Initialize timeago
			(function() {
				if (typeof timeago !== 'undefined') {
					const nodes = document.querySelectorAll('.timeago');
					if (nodes.length > 0) {
						timeago.render(nodes);
					}
				}
			})();

			// Handle form submissions and generation events
			document.body.addEventListener('htmx:afterRequest', function(event) {
				if (event.detail.successful) {
					var editModal = document.getElementById('edit-mixtape-modal');
					if (editModal && editModal.open) {
						editModal.close();
					}
					// Reload page after successful mutation
					if (event.detail.xhr.getResponseHeader('HX-Trigger')) {
						setTimeout(function() {
							window.location.reload();
						}, 1000);
					}
				}
			});

			// Listen for mixtape generation events via SSE to trigger reload
			document.body.addEventListener('mixtape-generated', function() {
				window.location.reload();
			});
		</script>
	}
}

func getMetaDescription(s string) string {
	if s == "" {
		return "—"
	}
	return s
}

func getDJName(dj *ent.DJ) string {
	if dj == nil {
		return "—"
	}
	return dj.Name
}

func getDJLink(dj *ent.DJ) string {
	if dj == nil {
		return ""
	}
	return fmt.Sprintf("/vibes/djs/%d", dj.ID)
}

func getSyncStatus(synced bool) string {
	if synced {
		return "Enabled"
	}
	return "Disabled"
}

func getTokensUsed(tokens *int) string {
	if tokens == nil {
		return "—"
	}
	return strconv.Itoa(*tokens)
}

func getLastGenerated(t *time.Time) string {
	if t == nil {
		return "Never"
	}
	return formatMixtapeTime(*t)
}

func getDJDisplayName(dj *ent.DJ) string {
	if dj != nil {
		return dj.Name
	}
	return "the DJ"
}
