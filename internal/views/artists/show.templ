package artists

import (
	"encoding/json"
	"fmt"
	"net/url"
	"spotter/ent"
	"spotter/internal/config"
	"spotter/internal/views/components"
	"spotter/internal/views/layouts"
	"time"
)

// ArtistStats holds statistics for an artist
type ArtistStats struct {
	TotalListens       int
	UniqueAlbums       int
	UniqueTracks       int
	FirstListen        time.Time
	LastListen         time.Time
	ListensByProvider  []components.ChartDataPoint
	ListensByHour      []components.ChartDataPoint
	ListensByDayOfWeek []components.ChartDataPoint
	ListensByMonth     []components.ChartDataPoint
	ProviderHistory    components.StackedChartData
	TopTracks          []TrackListenCount
}

// TrackListenCount represents a track with its listen count
type TrackListenCount struct {
	Track       *ent.Track
	ListenCount int
}

// PlaylistWithArtist represents a playlist containing tracks from this artist
type PlaylistWithArtist struct {
	Playlist   *ent.Playlist
	TrackCount int
}

// SimilarArtistInfo holds information about a similar artist
type SimilarArtistInfo struct {
	Artist     *ent.Artist
	Provider   string
	Confidence float64
	Reason     string
}

func toTrackRowsFromStats(tracks []TrackListenCount, lidarrBaseURL string) []components.TrackTableRow {
	rows := make([]components.TrackTableRow, len(tracks))
	for i, t := range tracks {
		rows[i] = components.TrackTableRow{
			Track:         t.Track,
			PlayCount:     t.ListenCount,
			LidarrBaseURL: lidarrBaseURL,
		}
	}
	return rows
}

func showFormatNumber(n int) string {
	return fmt.Sprintf("%d", n)
}

func getArtistListensURL(artistName string) string {
	return fmt.Sprintf("/recent?artist=%s", url.QueryEscape(artistName))
}

func showFormatDate(t time.Time) string {
	if t.IsZero() {
		return "N/A"
	}
	return t.Local().Format("Jan 2 '06")
}

func getArtistImage(artist *ent.Artist) string {
	if artist.Edges.Images == nil || len(artist.Edges.Images) == 0 {
		return ""
	}
	return fmt.Sprintf("/library/artist/%d.png", artist.ID)
}

func getAnyArtistImage(artist *ent.Artist) string {
	return getArtistImage(artist)
}

func getBackgroundImage(artist *ent.Artist) string {
	return getArtistImage(artist)
}

func hasBothBios(artist *ent.Artist) bool {
	return artist.Bio != "" && artist.AiBiography != "" && artist.Bio != artist.AiBiography
}

// collectTrackTags collects all unique tags from tracks
func collectTrackTags(albums []*ent.Album) []string {
	tagMap := make(map[string]bool)
	for _, album := range albums {
		if album.Edges.Tracks != nil {
			for _, track := range album.Edges.Tracks {
				for _, tag := range track.Tags {
					tagMap[tag] = true
				}
			}
		}
	}
	tags := make([]string, 0, len(tagMap))
	for tag := range tagMap {
		tags = append(tags, tag)
	}
	return tags
}

// collectTrackGenres collects all unique genres from tracks
func collectTrackGenres(albums []*ent.Album) []string {
	genreMap := make(map[string]bool)
	for _, album := range albums {
		if album.Edges.Tracks != nil {
			for _, track := range album.Edges.Tracks {
				for _, genre := range track.Genres {
					genreMap[genre] = true
				}
			}
		}
	}
	genres := make([]string, 0, len(genreMap))
	for genre := range genreMap {
		genres = append(genres, genre)
	}
	return genres
}

// collectTrackAITags collects all unique AI tags from tracks
func collectTrackAITags(albums []*ent.Album) []string {
	tagMap := make(map[string]bool)
	for _, album := range albums {
		if album.Edges.Tracks != nil {
			for _, track := range album.Edges.Tracks {
				for _, tag := range track.AiTags {
					tagMap[tag] = true
				}
			}
		}
	}
	tags := make([]string, 0, len(tagMap))
	for tag := range tagMap {
		tags = append(tags, tag)
	}
	return tags
}

templ Show(artist *ent.Artist, albums []*ent.Album, playlists []PlaylistWithArtist, stats *ArtistStats, similarArtists []SimilarArtistInfo, djs []*ent.DJ, cfg *config.Config, currentTimeframe string) {
	@layouts.Dashboard(fmt.Sprintf("%s | Artists | Spotter", artist.Name), cfg, "/library/artist") {
		<!-- AI Regenerate Modal -->
		<dialog id="ai-regenerate-modal" class="modal">
			<div class="modal-box">
				<h3 class="font-bold text-lg flex items-center gap-2">
					<span class="icon-[heroicons--sparkles] w-5 h-5 text-accent"></span>
					Regenerate AI Insights
				</h3>
				<p class="py-4">
					This will regenerate all AI-generated content for <strong>{ artist.Name }</strong>, including the summary, biography, and tags.
				</p>
				<p class="text-sm text-base-content/60">
					This may take a few moments and will use your OpenAI API credits.
				</p>
				<div class="modal-action">
					<form method="dialog">
						<button class="btn btn-ghost">Cancel</button>
					</form>
					<button
						class="btn btn-primary"
						hx-post={ fmt.Sprintf("/library/artist/%d/regenerate-ai", artist.ID) }
						hx-swap="none"
						hx-indicator="#ai-regenerate-indicator"
						onclick="document.getElementById('ai-regenerate-modal').close()"
					>
						<span id="ai-regenerate-indicator" class="htmx-indicator loading loading-spinner loading-sm"></span>
						<span class="icon-[heroicons--sparkles] w-4 h-4"></span>
						Regenerate
					</button>
				</div>
			</div>
			<form method="dialog" class="modal-backdrop">
				<button>close</button>
			</form>
		</dialog>
		<!-- Hero Section with Background -->
		<div class="relative -mx-6 lg:-mx-8 -mt-6 lg:-mt-8 mb-8">
			<!-- Background Image -->
			<div class="absolute inset-0 h-80 overflow-hidden">
				@components.ArtistImage(artist, "w-full h-full object-cover opacity-30")
				<div class="absolute inset-0 bg-gradient-to-b from-transparent via-base-200/80 to-base-200"></div>
			</div>
			<!-- AI Menu (Top Right) -->
			<div class="absolute top-4 right-4 z-10">
				<details class="dropdown dropdown-end">
					<summary class="btn btn-sm btn-ghost bg-base-100/50 hover:bg-base-100/80 gap-1 list-none cursor-pointer">
						<span class="icon-[heroicons--sparkles] w-4 h-4 text-accent"></span>
						<span class="hidden sm:inline">AI</span>
						<span class="icon-[heroicons--chevron-down] w-3 h-3"></span>
					</summary>
					<ul class="dropdown-content z-[1] menu p-2 shadow-lg bg-base-100 rounded-box w-56">
						<li>
							<button onclick="document.getElementById('ai-regenerate-modal').showModal(); this.closest('details').removeAttribute('open');">
								<span class="icon-[heroicons--arrow-path] w-4 h-4"></span>
								Regenerate AI Enrichment
							</button>
						</li>
						<li>
							<button
								hx-post={ fmt.Sprintf("/library/artist/%d/find-similar", artist.ID) }
								hx-swap="none"
								onclick="this.closest('details').removeAttribute('open');"
							>
								<span class="icon-[heroicons--users] w-4 h-4"></span>
								Find Similar Artists
							</button>
						</li>
						<li class="menu-title pt-2">
							<span>Create</span>
						</li>
						<li>
							if len(djs) > 0 {
								<button
									hx-get={ fmt.Sprintf("/library/artist/%d/mixtape-modal", artist.ID) }
									hx-target="#create-mixtape-modal"
									hx-swap="innerHTML"
									onclick="this.closest('details').removeAttribute('open')"
									_="on htmx:afterRequest document.getElementById('create-mixtape-modal').showModal()"
								>
									<span class="icon-[heroicons--musical-note] w-4 h-4"></span>
									Create Mixtape
								</button>
							} else {
								<a href="/vibes/djs" class="opacity-60">
									<span class="icon-[heroicons--musical-note] w-4 h-4"></span>
									Create Mixtape
									<span class="badge badge-xs">Create DJ first</span>
								</a>
							}
						</li>
					</ul>
				</details>
			</div>
			<!-- Artist Info -->
			<div class="relative pt-8 px-6 lg:px-8 pb-8">
				<div class="max-w-7xl mx-auto">
					<div class="flex flex-col md:flex-row items-start gap-8">
						<!-- Artist Image -->
						<div class="flex-shrink-0">
							<div class="avatar">
								<div class="w-48 h-48 rounded-xl shadow-2xl ring ring-base-100 ring-offset-base-200 ring-offset-2">
									@components.ArtistImage(artist, "w-full h-full object-cover")
								</div>
							</div>
						</div>
						<!-- Artist Details -->
						<div class="flex-1 min-w-0">
							<h1 class="text-4xl md:text-5xl font-bold mb-2 text-base-content">{ artist.Name }</h1>
							// TODO(SPEC-0014): Replace with TypedTagBadge after Tag schema PR #255 merges
							<!-- Genres and AI Tags -->
							if len(artist.Genres) > 0 || len(artist.AiTags) > 0 {
								<div class="flex flex-wrap gap-2 mb-6">
									for i, genre := range artist.Genres {
										if i < 6 {
											<span class="badge badge-neutral h-auto py-2 px-3 border-0 text-sm">{ genre }</span>
										}
									}
									for _, tag := range artist.AiTags {
										<span class="badge badge-secondary h-auto py-2 px-3 gap-1.5 border-0 text-sm">
											<span class="icon-[heroicons--sparkles] w-3.5 h-3.5"></span>
											{ tag }
										</span>
									}
									if len(artist.Genres) > 6 {
										<span class="badge badge-ghost h-auto py-2 px-3 border-0 text-sm">+{ fmt.Sprintf("%d", len(artist.Genres)-6) } more</span>
									}
								</div>
							}
							<!-- External Links -->
							<div class="flex flex-wrap gap-2">
								if artist.SpotifyID != "" {
									@components.ExternalLinkBadge("Spotify", fmt.Sprintf("https://open.spotify.com/artist/%s", artist.SpotifyID), "icon-[simple-icons--spotify]", "badge-success")
								}
								if artist.MusicbrainzID != "" {
									@components.ExternalLinkBadge("MusicBrainz", fmt.Sprintf("https://musicbrainz.org/artist/%s", artist.MusicbrainzID), "icon-[heroicons--globe-alt]", "badge-warning")
								}
								if artist.LastfmURL != "" {
									@components.ExternalLinkBadge("Last.fm", artist.LastfmURL, "icon-[simple-icons--lastdotfm]", "badge-error")
								}
								if artist.LidarrID != "" && artist.LidarrID != "0" && artist.MusicbrainzID != "" {
									@components.ExternalLinkBadge("Lidarr", fmt.Sprintf("%s/artist/%s", cfg.Lidarr.BaseURL, artist.MusicbrainzID), "icon-[heroicons--check-badge]", "badge-success")
								}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="max-w-7xl mx-auto">
			<!-- Stats Grid -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
				@components.StatCardLink("Total Listens", showFormatNumber(stats.TotalListens), "all time", "icon-[heroicons--play-circle]", "text-primary", getArtistListensURL(artist.Name))
				@components.StatCardLink("Albums", showFormatNumber(stats.UniqueAlbums), "in your library", "icon-[heroicons--square-3-stack-3d]", "text-secondary", fmt.Sprintf("/library/albums?artist=%s", url.QueryEscape(artist.Name)))
				@components.StatCardLink("Tracks", showFormatNumber(stats.UniqueTracks), "unique songs", "icon-[heroicons--musical-note]", "text-accent", fmt.Sprintf("/library/tracks?artist=%s", url.QueryEscape(artist.Name)))
				@components.StatCard("First Listen", showFormatDate(stats.FirstListen), "discovered", "icon-[heroicons--calendar]", "text-info")
			</div>
			<!-- AI Summary Card -->
			@components.AISummaryCard(artist.AiSummary, "AI Insights")
			<!-- Similar Artists Section -->
			if len(similarArtists) > 0 {
				<div class="mb-8">
					<div class="flex items-center justify-between mb-6">
						<h3 class="text-2xl font-bold flex items-center gap-2">
							<span class="icon-[heroicons--users] w-6 h-6"></span>
							Similar Artists
							<span class="badge badge-accent badge-sm gap-1">
								<span class="icon-[heroicons--sparkles] w-3 h-3"></span>
								AI
							</span>
						</h3>
						<button
							class="btn btn-sm btn-ghost gap-1"
							hx-post={ fmt.Sprintf("/library/artist/%d/find-similar", artist.ID) }
							hx-swap="none"
							title="Refresh similar artists"
						>
							<span class="icon-[heroicons--arrow-path] w-4 h-4"></span>
							Refresh
						</button>
					</div>
					<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
						for _, sa := range similarArtists {
							@components.SimilarArtistTile(sa.Artist, sa.Provider, sa.Reason, sa.Confidence)
						}
					</div>
				</div>
			}
			<!-- Biography Section with AI Toggle -->
			if artist.Bio != "" || artist.AiBiography != "" {
				<div id="bio-card" class={ "card bg-base-100 border-l-4 shadow-xl mb-8", templ.KV("border-accent shadow-accent/10", artist.AiBiography != ""), templ.KV("border-base-content/20", artist.AiBiography == "") }>
					<div class="card-body">
						<div class="flex items-center justify-between">
							<h3 class="card-title">
								<span class="icon-[heroicons--document-text] w-5 h-5"></span>
								Biography
							</h3>
							<!-- AI Toggle Button (only if both bios exist and are different) -->
							if hasBothBios(artist) {
								<button
									id="bio-toggle-btn"
									class="btn btn-sm btn-square btn-accent"
									onclick="toggleBio()"
									title="Toggle between AI and original biography"
								>
									<span id="bio-toggle-icon-ai" class="icon-[heroicons--sparkles] w-4 h-4"></span>
									<span id="bio-toggle-icon-web" class="icon-[heroicons--globe-alt] w-4 h-4 hidden"></span>
								</button>
							}
						</div>
						<!-- AI Biography (shown by default if available) -->
						if artist.AiBiography != "" {
							<div id="ai-bio" class="prose prose-sm max-w-none text-base-content/80 mt-4">
								{ artist.AiBiography }
								<p class="text-xs text-base-content/40 mt-4 flex items-center gap-1 not-prose">
									<span class="icon-[heroicons--sparkles] w-3 h-3 text-accent"></span>
									AI-generated biography
									if artist.LastAiEnrichedAt != nil {
										• Generated { showFormatEnrichedTime(artist.LastAiEnrichedAt) }
									}
								</p>
							</div>
						}
						<!-- Original Biography (hidden by default if AI bio exists) -->
						if artist.Bio != "" {
							<div id="original-bio" class={ "prose prose-sm max-w-none text-base-content/80 mt-4", templ.KV("hidden", artist.AiBiography != "") }>
								{ artist.Bio }
								<p class="text-xs text-base-content/40 mt-4 not-prose">
									Original biography from Last.fm
								</p>
							</div>
						}
					</div>
				</div>
				if hasBothBios(artist) {
					<script>
						function toggleBio() {
							const aiBio = document.getElementById('ai-bio');
							const originalBio = document.getElementById('original-bio');
							const toggleBtn = document.getElementById('bio-toggle-btn');
							const bioCard = document.getElementById('bio-card');
							const iconAi = document.getElementById('bio-toggle-icon-ai');
							const iconWeb = document.getElementById('bio-toggle-icon-web');

							if (aiBio.classList.contains('hidden')) {
								// Show AI bio
								aiBio.classList.remove('hidden');
								originalBio.classList.add('hidden');
								toggleBtn.classList.add('btn-accent');
								toggleBtn.classList.remove('btn-ghost');
								bioCard.classList.add('border-accent', 'shadow-accent/10');
								bioCard.classList.remove('border-base-content/20');
								iconAi.classList.remove('hidden');
								iconWeb.classList.add('hidden');
							} else {
								// Show original bio
								aiBio.classList.add('hidden');
								originalBio.classList.remove('hidden');
								toggleBtn.classList.remove('btn-accent');
								toggleBtn.classList.add('btn-ghost');
								bioCard.classList.remove('border-accent', 'shadow-accent/10');
								bioCard.classList.add('border-base-content/20');
								iconAi.classList.add('hidden');
								iconWeb.classList.remove('hidden');
							}
						}
					</script>
				}
			}
			<!-- Top Tracks -->
			if len(stats.TopTracks) > 0 {
				<div class="card bg-base-100 shadow-xl mb-8">
					<div class="card-body">
						<div class="flex items-center justify-between">
							<h3 class="card-title">
								<span class="icon-[heroicons--fire] w-5 h-5 text-error"></span>
								Top Tracks
							</h3>
							@components.TrackTableToolbar(components.TrackTableToolbarConfig{
								TableID:           "top-tracks-table",
								ShowArtworkToggle: true,
								ArtworkDefault:    true,
								ColumnOptions: []components.ColumnOption{
									{Value: "col-index", Label: "#", DefaultVisible: true},
									{Value: "col-track", Label: "Track", DefaultVisible: true},
									{Value: "col-artist", Label: "Artist", DefaultVisible: false},
									{Value: "col-album", Label: "Album", DefaultVisible: true},
									{Value: "col-duration", Label: "Duration", DefaultVisible: true},
									{Value: "col-popularity", Label: "Popularity", DefaultVisible: true},
									{Value: "col-plays", Label: "Plays", DefaultVisible: true},
								},
							})
						</div>
						@components.TrackTable("top-tracks-table", toTrackRowsFromStats(stats.TopTracks, cfg.Lidarr.BaseURL), []string{"#", "track", "album", "duration", "popularity", "plays"}, nil, components.SortConfig{})
					</div>
				</div>
			}
			// TODO(SPEC-0014): Replace with TypedTagGroup after Tag schema PR #255 merges
			<!-- Track Tags & Genres Section -->
			if trackTags := collectTrackTags(albums); len(trackTags) > 0 || len(collectTrackGenres(albums)) > 0 || len(collectTrackAITags(albums)) > 0 {
				<div class="card bg-base-100 shadow-xl mb-8">
					<div class="card-body">
						<h3 class="card-title">
							<span class="icon-[heroicons--tag] w-5 h-5"></span>
							Tags & Genres from Tracks
						</h3>
						<!-- Track Genres -->
						if trackGenres := collectTrackGenres(albums); len(trackGenres) > 0 {
							<div class="mb-4">
								<h4 class="text-sm font-medium text-base-content/60 mb-2">Genres</h4>
								<div class="flex flex-wrap gap-1.5">
									for _, genre := range trackGenres {
										<span class="badge badge-sm badge-primary px-2 py-0.5">{ genre }</span>
									}
								</div>
							</div>
						}
						<!-- Track Tags (ID3) -->
						if len(trackTags) > 0 {
							<div class="mb-4">
								<h4 class="text-sm font-medium text-base-content/60 mb-2">ID3 Tags</h4>
								<div class="flex flex-wrap gap-1.5">
									for _, tag := range trackTags {
										<span class="badge badge-sm badge-secondary px-2 py-0.5">{ tag }</span>
									}
								</div>
							</div>
						}
						<!-- Track AI Tags -->
						if trackAITags := collectTrackAITags(albums); len(trackAITags) > 0 {
							<div>
								<h4 class="text-sm font-medium text-base-content/60 mb-2 flex items-center gap-1">
									<span class="icon-[heroicons--sparkles] w-3 h-3 text-accent"></span>
									AI-Generated Tags
								</h4>
								<div class="flex flex-wrap gap-1.5">
									for _, tag := range trackAITags {
										<span class="badge badge-sm badge-accent gap-1 px-2 py-0.5">
											<span class="icon-[heroicons--sparkles] w-2.5 h-2.5"></span>
											{ tag }
										</span>
									}
								</div>
							</div>
						}
					</div>
				</div>
			}
			<!-- Albums Grid -->
			if len(albums) > 0 {
				<div class="mb-8">
					<h3 class="text-2xl font-bold mb-6 flex items-center gap-2">
						<span class="icon-[heroicons--square-3-stack-3d] w-6 h-6"></span>
						Albums
					</h3>
					<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
						for _, album := range albums {
							@components.AlbumTile(album)
						}
					</div>
				</div>
			}
			<!-- Playlists with this Artist -->
			if len(playlists) > 0 {
				<div class="mb-8">
					<h3 class="text-2xl font-bold mb-6 flex items-center gap-2">
						<span class="icon-[heroicons--queue-list] w-6 h-6"></span>
						In Playlists
					</h3>
					<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
						for _, pl := range playlists {
							@components.PlaylistTile(pl.Playlist, fmt.Sprintf("%d tracks by this artist", pl.TrackCount))
						}
					</div>
				</div>
			}
			<!-- Metadata Table -->
			<div class="card bg-base-100 shadow-xl mb-8">
				<div class="card-body">
					<h3 class="card-title">
						<span class="icon-[heroicons--information-circle] w-5 h-5"></span>
						Metadata
					</h3>
					@components.MetadataTable([]components.MetadataRow{
						{Label: "Sort Name", Value: showGetOrDefault(artist.SortName, artist.Name)},
						{Label: "MusicBrainz ID", Value: showGetOrDefault(artist.MusicbrainzID, "N/A"), Link: getMBLink(artist.MusicbrainzID)},
						{Label: "Spotify ID", Value: showGetOrDefault(artist.SpotifyID, "N/A"), Link: getSpotifyArtistLink(artist.SpotifyID)},
						{Label: "Navidrome ID", Value: showGetOrDefault(artist.NavidromeID, "N/A")},
						{Label: "Last Enriched", Value: showFormatEnrichedTime(artist.LastEnrichedAt)},
						{Label: "AI Enriched", Value: showFormatEnrichedTime(artist.LastAiEnrichedAt)},
						{Label: "Created", Value: showFormatDate(artist.CreatedAt)},
						{Label: "Updated", Value: showFormatDate(artist.UpdatedAt)},
					})
				</div>
			</div>
		</div>
		<!-- Create Mixtape Modal -->
		@components.CreateMixtapeModal()
	}
}

// CreateMixtapeModalContent renders just the modal content for HTMX requests.
templ CreateMixtapeModalContent(artist *ent.Artist, djs []*ent.DJ) {
	@components.CreateMixtapeModalContent(components.CreateMixtapeParams{
		SeedType: components.SeedArtist,
		SeedID:   artist.ID,
		SeedName: artist.Name,
		DJs:      djs,
	})
}

templ ProviderHistoryChart(artistID int, data components.StackedChartData, currentTimeframe string) {
	<div class="card bg-base-100 shadow-xl">
		<div class="card-body">
			<div class="flex items-center justify-between mb-4">
				<h3 class="card-title">
					<span class="icon-[heroicons--chart-bar] w-5 h-5"></span>
					Listens Over Time
				</h3>
				<select
					class="select select-bordered select-sm w-40"
					hx-get={ fmt.Sprintf("/library/artist/%d/chart", artistID) }
					hx-target="#provider-history-chart"
					hx-swap="innerHTML"
					name="timeframe"
				>
					<option value="30d" selected?={ currentTimeframe == "30d" }>Last 30 days</option>
					<option value="90d" selected?={ currentTimeframe == "90d" }>Last 90 days</option>
					<option value="6m" selected?={ currentTimeframe == "6m" }>Last 6 months</option>
					<option value="1y" selected?={ currentTimeframe == "1y" }>Last year</option>
					<option value="all" selected?={ currentTimeframe == "all" }>All time</option>
				</select>
			</div>
			<div id="provider-history-chart">
				@ProviderHistoryChartContent(artistID, data)
			</div>
		</div>
	</div>
}

templ ProviderHistoryChartContent(artistID int, data components.StackedChartData) {
	<div class="w-full" style="height: 300px">
		<canvas id={ fmt.Sprintf("artist-%d-provider-history", artistID) }></canvas>
	</div>
	@providerHistoryScript(artistID, data)
}

templ providerHistoryScript(artistID int, data components.StackedChartData) {
	<script>
		(function() {
			const ctx = document.getElementById('artist-' + {{ artistID }} + '-provider-history');
			if (!ctx) return;

			// Destroy existing chart if any
			const existingChart = Chart.getChart(ctx);
			if (existingChart) {
				existingChart.destroy();
			}

			const chartData = JSON.parse('{{ toJSON(data) }}');

			new Chart(ctx, {
				type: 'bar',
				data: {
					labels: chartData.labels,
					datasets: chartData.datasets.map(ds => ({
						label: ds.label,
						data: ds.data,
						backgroundColor: ds.backgroundColor,
						borderColor: ds.borderColor,
						borderWidth: 1,
						borderRadius: 2
					}))
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					plugins: {
						legend: {
							display: true,
							position: 'bottom',
							labels: {
								color: 'oklch(var(--bc))',
								usePointStyle: true,
								padding: 20
							}
						}
					},
					scales: {
						y: {
							stacked: true,
							beginAtZero: true,
							ticks: {
								color: 'oklch(var(--bc) / 0.7)'
							},
							grid: {
								color: 'oklch(var(--bc) / 0.1)'
							}
						},
						x: {
							stacked: true,
							ticks: {
								color: 'oklch(var(--bc) / 0.7)',
								maxRotation: 45,
								minRotation: 0
							},
							grid: {
								display: false
							}
						}
					}
				}
			});
		})();
	</script>
}

func toJSON(v interface{}) string {
	b, err := json.Marshal(v)
	if err != nil {
		return "[]"
	}
	return string(b)
}

func showGetOrDefault(value, defaultVal string) string {
	if value == "" {
		return defaultVal
	}
	return value
}

func getMBLink(mbid string) string {
	if mbid == "" {
		return ""
	}
	return fmt.Sprintf("https://musicbrainz.org/artist/%s", mbid)
}

func getSpotifyArtistLink(spotifyID string) string {
	if spotifyID == "" {
		return ""
	}
	return fmt.Sprintf("https://open.spotify.com/artist/%s", spotifyID)
}

func showFormatEnrichedTime(t *time.Time) string {
	if t == nil || t.IsZero() {
		return "Never"
	}
	return t.Local().Format("Jan 02, 2006 at 3:04 PM")
}
