# Security - AES-256 encryption key (32 bytes = 64 hex characters)
# Generate with: openssl rand -hex 32
SPOTTER_SECURITY_ENCRYPTION_KEY=

# Security - JWT signing secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
SPOTTER_SECURITY_JWT_SECRET=

# Security - Secure cookies (set to false for local HTTP development)
SPOTTER_SECURITY_SECURE_COOKIES=true

# Navidrome Configuration (REQUIRED)
SPOTTER_NAVIDROME_BASE_URL=https://your-navidrome-instance.com

# Spotify Configuration (optional - for playlist sync)
SPOTTER_SPOTIFY_CLIENT_ID=
SPOTTER_SPOTIFY_CLIENT_SECRET=

# Last.fm Configuration (optional - for metadata enrichment)
SPOTTER_LASTFM_API_KEY=
SPOTTER_LASTFM_SHARED_SECRET=

# OpenAI Configuration (REQUIRED for AI features)
SPOTTER_OPENAI_API_KEY=
SPOTTER_OPENAI_BASE_URL=https://api.openai.com/v1
SPOTTER_OPENAI_MODEL=gpt-4o

# Fanart.tv Configuration (optional - for artist/album images)
SPOTTER_METADATA_FANART_API_KEY=

# Lidarr Configuration (REQUIRED)
SPOTTER_LIDARR_BASE_URL=https://your-lidarr-instance.com
SPOTTER_LIDARR_API_KEY=
